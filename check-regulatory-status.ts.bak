import * as dotenv from 'dotenv';
dotenv.config();

import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

async function checkRegulatoryStatus() {
  console.log('📊 Checking Regulatory Document Processing Status...\n');
  
  // Get all regulatory documents
  const docs = await prisma.regulatoryDocument.findMany({
    include: {
      chunks: {
        select: {
          id: true,
          pageNumber: true,
        }
      }
    },
    orderBy: {
      standard: 'asc'
    }
  });
  
  for (const doc of docs) {
    console.log(`\n📄 ${doc.standard} (${doc.version || 'N/A'})`);
    console.log(`   Type: ${doc.type}`);
    console.log(`   Processed: ${doc.processed ? '✅ Yes' : '❌ No'}`);
    console.log(`   Processor: ${doc.processorType || 'N/A'}`);
    console.log(`   Pages Processed: ${doc.pagesProcessed || 0}`);
    console.log(`   Cost: $${(doc.processingCost || 0).toFixed(2)}`);
    console.log(`   Chunks: ${doc.chunks.length}`);
    
    if (doc.chunks.length > 0) {
      const pageNumbers = doc.chunks.map((c: any) => c.pageNumber).filter((p: any): p is number => p !== null);
      const uniquePages = new Set(pageNumbers);
      console.log(`   Unique Pages in DB: ${uniquePages.size}`);
      
      if (uniquePages.size > 0) {
        const minPage = Math.min(...Array.from(uniquePages) as number[]);
        const maxPage = Math.max(...Array.from(uniquePages) as number[]);
        console.log(`   Page Range: ${minPage} - ${maxPage}`);
      }
    }
  }
  
  await prisma.$disconnect();
}

checkRegulatoryStatus().catch(console.error);
