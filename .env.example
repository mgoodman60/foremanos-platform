# ===========================================
# ForemanOS Environment Variables Template
# ===========================================
# Copy this file to .env and fill in your values

# ============ DATABASE ============
# PostgreSQL connection string
DATABASE_URL='postgresql://USER:PASSWORD@HOST:5432/DATABASE?connect_timeout=15&connection_limit=10'

# ============ AUTHENTICATION ============
# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_random_32_char_secret_here

# Base URL for NextAuth (change for production)
NEXTAUTH_URL=http://localhost:3000

# ============ AWS S3 (File Storage) ============
AWS_REGION=us-west-2
AWS_BUCKET_NAME=your-bucket-name
AWS_FOLDER_PREFIX=your-prefix/
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key

# ============ AI/LLM APIs ============
# OpenAI (primary)
OPENAI_API_KEY=sk-proj-...

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini (document extraction pipeline)
GOOGLE_API_KEY=your_google_api_key
# Gemini primary model for extraction pass 1
GEMINI_PRIMARY_MODEL=gemini-2.0-flash

# ============ AUTODESK (CAD/BIM) ============
AUTODESK_CLIENT_ID=your_client_id
AUTODESK_CLIENT_SECRET=your_client_secret

# ============ ONEDRIVE INTEGRATION ============
ONEDRIVE_CLIENT_ID=your_client_id
ONEDRIVE_CLIENT_SECRET=your_client_secret
ONEDRIVE_TENANT_ID=common

# ============ TOKEN ENCRYPTION ============
# AES-256-GCM key for encrypting OAuth tokens at rest (32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ============ STRIPE (Payments) ============
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============ REDIS (Caching) ============
REDIS_URL=redis://localhost:6379

# ============ WEATHER API ============
OPENWEATHERMAP_API_KEY=your_api_key

# ============ EMAIL (Notifications) ============
RESEND_API_KEY=re_...

# ============ ERROR MONITORING (Sentry) ============
# Sentry DSN for error tracking (leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ============ INTERNAL ============
CRON_SECRET=your_internal_secret
POOL_MAX_SIZE=10
POOL_MIN_SIZE=2
POOL_IDLE_TIMEOUT=60
POOL_LIFETIME=1800
