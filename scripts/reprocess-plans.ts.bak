import { PrismaClient } from '@prisma/client';
import * as dotenv from 'dotenv';
import { processDocument } from '../lib/document-processor';

// Load environment variables
dotenv.config();

const prisma = new PrismaClient();

async function reprocessProjectDocuments() {
  const startTime = Date.now();
  
  console.log('🔄 Starting document reprocessing...');
  console.log('');
  
  try {
    // Find the One Senior Care project
    const project = await prisma.project.findUnique({
      where: { slug: 'one-senior-care' },
    });
    
    if (!project) {
      console.error('❌ Project "one-senior-care" not found');
      process.exit(1);
    }
    
    console.log(`📂 Project: ${project.name} (${project.slug})`);
    console.log('');
    
    // Get all PDF documents that have been processed
    const documents = await prisma.document.findMany({
      where: {
        projectId: project.id,
        processed: true,
        fileName: { endsWith: '.pdf' },
        deletedAt: null,
      },
      orderBy: { name: 'asc' },
    });
    
    if (documents.length === 0) {
      console.log('ℹ️  No processed PDF documents found to reprocess');
      await prisma.$disconnect();
      return;
    }
    
    console.log(`📄 Found ${documents.length} processed PDF documents:`);
    documents.forEach((doc: any, i: number) => {
      console.log(`   ${i + 1}. ${doc.name} (${doc.pagesProcessed || 0} pages, ${doc.processingCost?.toFixed(4) || '0.0000'} cost)`);
    });
    console.log('');
    
    // Confirm before proceeding
    console.log('⚠️  This will:');
    console.log('   1. Delete all existing chunks for these documents');
    console.log('   2. Mark documents as unprocessed');
    console.log('   3. Re-run vision processing with enhanced prompts (including zone extraction)');
    console.log('');
    console.log('💰 Estimated cost: ~$0.45 (0.01/page × ~45 pages)');
    console.log('⏱️  Estimated time: 15-20 minutes');
    console.log('');
    
    // Process each document
    let totalPages = 0;
    let totalCost = 0;
    let successCount = 0;
    let failCount = 0;
    
    for (const doc of documents) {
      try {
        console.log(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`);
        console.log(`🔧 Processing: ${doc.name}`);
        console.log('');
        
        // Delete existing chunks
        const deletedChunks = await prisma.documentChunk.deleteMany({
          where: { documentId: doc.id },
        });
        
        console.log(`   ✅ Deleted ${deletedChunks.count} existing chunks`);
        
        // Mark as unprocessed and reset counters
        await prisma.document.update({
          where: { id: doc.id },
          data: {
            processed: false,
            pagesProcessed: 0,
            processingCost: 0,
          },
        });
        
        console.log(`   ✅ Marked as unprocessed`);
        console.log(`   🔄 Starting vision processing...`);
        console.log('');
        
        // Re-process the document
        await processDocument(doc.id);
        
        // Get updated document stats
        const updatedDoc = await prisma.document.findUnique({
          where: { id: doc.id },
          include: { _count: { select: { chunks: true } } },
        });
        
        if (updatedDoc) {
          totalPages += updatedDoc.pagesProcessed || 0;
          totalCost += updatedDoc.processingCost || 0;
          
          console.log('');
          console.log(`   ✅ Completed: ${updatedDoc.pagesProcessed} pages, ${updatedDoc._count.chunks} chunks, $${(updatedDoc.processingCost || 0).toFixed(4)}`);
          successCount++;
        }
        
      } catch (error) {
        console.error(`   ❌ Failed to reprocess ${doc.name}:`, error);
        failCount++;
      }
      
      console.log('');
    }
    
    // Summary
    const elapsedSeconds = Math.floor((Date.now() - startTime) / 1000);
    const elapsedMinutes = Math.floor(elapsedSeconds / 60);
    const remainingSeconds = elapsedSeconds % 60;
    
    console.log(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`);
    console.log(`✅ REPROCESSING COMPLETE`);
    console.log('');
    console.log(`📊 Summary:`);
    console.log(`   ✅ Successful: ${successCount}`);
    console.log(`   ❌ Failed: ${failCount}`);
    console.log(`   📄 Total Pages: ${totalPages}`);
    console.log(`   💰 Total Cost: $${totalCost.toFixed(4)}`);
    console.log(`   ⏱️  Time: ${elapsedMinutes}m ${remainingSeconds}s`);
    console.log('');
    
    await prisma.$disconnect();
    
  } catch (error) {
    console.error('❌ Error during reprocessing:', error);
    await prisma.$disconnect();
    process.exit(1);
  }
}

// Run the reprocessing
reprocessProjectDocuments();
