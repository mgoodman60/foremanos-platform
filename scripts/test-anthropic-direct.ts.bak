/**
 * Direct test of Anthropic API to diagnose model access issues
 */

async function testAnthropicDirect() {
  console.log('='.repeat(60));
  console.log('Anthropic API Direct Test');
  console.log('='.repeat(60));
  console.log('');
  
  // Get API key
  const apiKey = process.env.ANTHROPIC_API_KEY;
  if (!apiKey) {
    // Try from secrets file
    const fs = await import('fs');
    try {
      const secrets = JSON.parse(fs.readFileSync('/home/ubuntu/.config/abacusai_auth_secrets.json', 'utf8'));
      const anthropicKey = secrets?.anthropic?.secrets?.api_key?.value;
      if (anthropicKey) {
        process.env.ANTHROPIC_API_KEY = anthropicKey;
        console.log('✅ API Key loaded from secrets file');
        console.log(`   Key prefix: ${anthropicKey.substring(0, 15)}...`);
      }
    } catch (e) {
      console.log('❌ Could not load API key');
      return;
    }
  }
  
  const key = process.env.ANTHROPIC_API_KEY;
  console.log('');
  
  // Test different model names
  const modelsToTest = [
    'claude-3-5-sonnet-20241022',  // Latest (Oct 2024)
    'claude-3-5-sonnet-20240620',  // Previous stable
    'claude-3-opus-20240229',      // Opus (most capable)
    'claude-3-sonnet-20240229',    // Regular Sonnet
    'claude-3-haiku-20240307',     // Haiku (fastest)
    'claude-2.1',                  // Claude 2.1
    'claude-2.0',                  // Claude 2.0
  ];
  
  console.log('Testing models with different API versions...');
  console.log('');
  
  for (const model of modelsToTest) {
    console.log(`Testing: ${model}`);
    
    // Try with current API version (2023-06-01)
    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'content-type': 'application/json',
          'x-api-key': key!,
          'anthropic-version': '2023-06-01',
        },
        body: JSON.stringify({
          model: model,
          max_tokens: 10,
          messages: [{ role: 'user', content: 'Hi' }],
        }),
      });
      
      if (response.ok) {
        console.log(`  ✅ SUCCESS with ${model}!`);
        const data = await response.json();
        console.log(`     Response: ${JSON.stringify(data).substring(0, 100)}`);
        console.log('');
        return { success: true, model };
      } else {
        const errorData = await response.json();
        const errorType = errorData?.error?.type;
        const errorMsg = errorData?.error?.message;
        
        if (response.status === 404) {
          console.log(`  ❌ 404 Not Found`);
        } else if (response.status === 401) {
          console.log(`  ❌ 401 Unauthorized - API key issue`);
        } else if (response.status === 403) {
          console.log(`  ❌ 403 Forbidden - Access denied`);
        } else if (errorType === 'permission_error') {
          console.log(`  ❌ Permission Error: ${errorMsg}`);
        } else {
          console.log(`  ❌ ${response.status}: ${errorType || 'Unknown'}`);
        }
      }
    } catch (error: any) {
      console.log(`  ❌ Request failed: ${error.message}`);
    }
  }
  
  console.log('');
  console.log('='.repeat(60));
  console.log('No working models found');
  console.log('='.repeat(60));
  console.log('');
  console.log('🔍 Diagnostics:');
  console.log('');
  console.log('1. Check your Anthropic Console:');
  console.log('   https://console.anthropic.com/settings/keys');
  console.log('');
  console.log('2. Verify your API key:');
  console.log('   - Is it active?');
  console.log('   - Does it have model access?');
  console.log('   - Is it for the correct workspace?');
  console.log('');
  console.log('3. Check your billing:');
  console.log('   https://console.anthropic.com/settings/billing');
  console.log('   - Are credits available?');
  console.log('   - Is billing method valid?');
  console.log('');
  console.log('4. Check workspace access:');
  console.log('   https://console.anthropic.com/settings/workspaces');
  console.log('   - Is your API key in the right workspace?');
  console.log('   - Does the workspace have model access?');
  console.log('');
}

testAnthropicDirect()
  .then(() => {
    console.log('Test complete');
    process.exit(0);
  })
  .catch((error) => {
    console.error('Fatal error:', error);
    process.exit(1);
  });
