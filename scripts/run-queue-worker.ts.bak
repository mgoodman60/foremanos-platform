#!/usr/bin/env tsx
/**
 * Queue Worker Script
 * Processes one batch from the processing queue
 */

import { processNextQueuedBatch } from '../lib/document-processing-queue';

async function main() {
  console.log('\n=== Starting Queue Worker ===');
  console.log('Processing next batch from queue...\n');

  const hasMore = await processNextQueuedBatch();

  if (hasMore) {
    console.log('\n✅ Batch processed successfully');
    console.log('More batches remain in queue');
  } else {
    console.log('\n✅ Queue is empty or all processing complete');
  }
}

main()
  .catch((error) => {
    console.error('\n❌ Worker error:', error);
    process.exit(1);
  })
  .finally(() => {
    console.log('\n=== Queue Worker Complete ===\n');
    process.exit(0);
  });
