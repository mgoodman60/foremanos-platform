import { PrismaClient } from '@prisma/client';
import * as dotenv from 'dotenv';

dotenv.config();

const prisma = new PrismaClient();

async function checkStatus() {
  const docs = await prisma.regulatoryDocument.findMany({
    select: {
      standard: true,
      processed: true,
      pagesProcessed: true,
      _count: {
        select: { chunks: true }
      }
    },
    orderBy: { standard: 'asc' }
  });
  
  console.log('\n📊 Regulatory Document Processing Status:');
  console.log('=========================================\n');
  
  docs.forEach((doc: any) => {
    console.log(`${doc.standard}:`);
    console.log(`  Status: ${doc.processed ? '✅ Complete' : '⏳ In Progress'}`);
    console.log(`  Pages Processed: ${doc.pagesProcessed}`);
    console.log(`  Chunks Stored: ${doc._count.chunks}`);
    console.log('');
  });
  
  await prisma.$disconnect();
}

checkStatus().catch(console.error);
