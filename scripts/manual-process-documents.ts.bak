import 'dotenv/config';
import { prisma } from '../lib/db';
import { processDocument } from '../lib/document-processor';

async function manualProcess() {
  try {
    console.log('🔍 Finding unprocessed documents...\n');
    
    const unprocessed = await prisma.document.findMany({
      where: { 
        processed: false,
        fileType: { in: ['pdf', 'docx'] }
      },
      select: {
        id: true,
        name: true,
        fileName: true,
        processorType: true,
        fileType: true,
        project: {
          select: {
            name: true
          }
        }
      },
      orderBy: { createdAt: 'desc' }
    });

    if (unprocessed.length === 0) {
      console.log('✅ No documents need processing!');
      return;
    }

    console.log(`📄 Found ${unprocessed.length} unprocessed documents:\n`);
    for (const doc of unprocessed) {
      console.log(`  - ${doc.name} (${doc.fileName}) - ${doc.project?.name || 'Unknown'}`);
    }

    console.log(`\n🚀 Starting processing...\n`);

    for (const doc of unprocessed) {
      console.log(`\n${'='.repeat(80)}`);
      console.log(`🔄 Processing: ${doc.name} (${doc.fileName})`);
      console.log(`   Project: ${doc.project?.name || 'Unknown'}`);
      console.log(`   Processor: ${doc.processorType}`);
      console.log(`${'='.repeat(80)}\n`);

      try {
        const classification = {
          processorType: doc.processorType,
          fileType: doc.fileType,
          category: 'other'
        };

        await processDocument(doc.id, classification as any);
        console.log(`✅ Successfully processed: ${doc.name}\n`);
      } catch (error: any) {
        console.error(`❌ Failed to process ${doc.name}:`, error.message);
        console.error(`   Stack:`, error.stack);
      }
    }

    console.log(`\n\n✨ Processing complete!\n`);

  } catch (error: any) {
    console.error('❌ Error:', error);
    console.error('Stack:', error.stack);
  } finally {
    await prisma.$disconnect();
  }
}

manualProcess();
