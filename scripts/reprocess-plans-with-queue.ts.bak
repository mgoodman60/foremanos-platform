/**
 * Reprocess Plans.pdf with new queue system
 */

import { prisma } from '../lib/db';
import { queueDocumentForProcessing } from '../lib/document-processing-queue';
import { processNextQueuedBatch } from '../lib/document-processing-queue';

async function main() {
  try {
    const documentId = 'cmk633er50001n508fpe1licm'; // Plans.pdf

    console.log('\n=== REPROCESSING PLANS.PDF ===\n');

    // Get document info
    const document = await prisma.document.findUnique({
      where: { id: documentId },
      select: {
        id: true,
        name: true,
        fileName: true,
        pagesProcessed: true,
        _count: {
          select: { chunks: true },
        },
      },
    });

    if (!document) {
      throw new Error('Document not found');
    }

    console.log('Document:', document.name);
    console.log('Current progress:', document.pagesProcessed, 'pages');
    console.log('Current chunks:', document._count.chunks);

    // Check if already in queue
    const existingQueue = await prisma.processingQueue.findFirst({
      where: { documentId },
      orderBy: { createdAt: 'desc' },
    });

    if (existingQueue) {
      console.log('\n⚠️  Document already in queue:');
      console.log('  Status:', existingQueue.status);
      console.log('  Progress:', existingQueue.pagesProcessed, '/', existingQueue.totalPages);
      console.log('  Current batch:', existingQueue.currentBatch, '/', existingQueue.totalBatches);
      
      if (existingQueue.status === 'failed' || existingQueue.status === 'completed') {
        console.log('\nDeleting old queue entry...');
        await prisma.processingQueue.delete({
          where: { id: existingQueue.id },
        });
      } else {
        console.log('\nDocument is already processing. Exiting...');
        return;
      }
    }

    // Delete existing chunks to start fresh
    console.log('\nDeleting existing chunks...');
    const deleted = await prisma.documentChunk.deleteMany({
      where: { documentId },
    });
    console.log(`Deleted ${deleted.count} chunks`);

    // Reset document status
    await prisma.document.update({
      where: { id: documentId },
      data: {
        processed: false,
        pagesProcessed: 0,
      },
    });

    // Queue for processing (45 pages total)
    console.log('\nQueuing document for processing...');
    await queueDocumentForProcessing(documentId, 45, 5); // 5 pages per batch = 9 batches

    console.log('✅ Document queued successfully');
    console.log('\nTo process the queue, run:');
    console.log('  yarn tsx scripts/queue-worker.ts');
    console.log('\nOr call the API:');
    console.log('  POST /api/admin/process-queue');

    // Optionally, process first batch now
    console.log('\nTo process the queue now, run:');
    console.log('  yarn tsx --require dotenv/config scripts/queue-worker.ts');

  } catch (error: any) {
    console.error('\n❌ Error:', error.message);
    console.error(error);
  } finally {
    await prisma.$disconnect();
  }
}

main();
