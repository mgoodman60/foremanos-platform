import { PrismaClient } from '@prisma/client';
import bcrypt from 'bcryptjs';

const prisma = new PrismaClient();

async function main() {
  console.log('🚀 Starting multi-project migration...');

  // Step 1: Create test accounts
  console.log('\n📝 Creating test accounts...');
  
  // Admin account
  const adminPassword = await bcrypt.hash('123', 10);
  const admin = await prisma.user.upsert({
    where: { username: 'Admin' },
    update: {
      role: "admin",
      approved: true,
      password: adminPassword,
    },
    create: {
      username: 'Admin',
      email: 'admin@foremanos.com',
      password: adminPassword,
      role: "admin",
      approved: true,
    },
  });
  console.log('✅ Admin account created/updated: Admin / 123');

  // Client account (wp)
  const wpPassword = await bcrypt.hash('825', 10);
  const wp = await prisma.user.upsert({
    where: { username: 'wp' },
    update: {
      role: "client",
      approved: true,
      password: wpPassword,
      approvedBy: admin.id,
    },
    create: {
      username: 'wp',
      email: 'wp@foremanos.com',
      password: wpPassword,
      role: "client",
      approved: true,
      approvedBy: admin.id,
    },
  });
  console.log('✅ Client account created/updated: wp / 825');

  // Step 2: Create "One Senior Care" project
  console.log('\n📁 Creating "One Senior Care" project...');
  const project = await prisma.project.upsert({
    where: { slug: 'one-senior-care' },
    update: {
      name: 'One Senior Care',
      ownerId: wp.id,
      guestUsername: '825',
      guestPassword: null,
    },
    create: {
      name: 'One Senior Care',
      slug: 'one-senior-care',
      ownerId: wp.id,
      guestUsername: '825',
      guestPassword: null,
    },
  });
  console.log(`✅ Project created: ${project.name} (slug: ${project.slug})`);

  // Guest account (825) - password-less, assigned to One Senior Care
  const guest = await prisma.user.upsert({
    where: { username: '825' },
    update: {
      role: "guest",
      approved: true,
      password: null,
      assignedProjectId: project.id,
    },
    create: {
      username: '825',
      email: null,
      password: null,
      role: "guest",
      approved: true,
      assignedProjectId: project.id,
    },
  });
  console.log('✅ Guest account created/updated: 825 (password-less)');

  // Step 3: Create ProjectMember entries
  console.log('\n👥 Creating project memberships...');
  
  // Owner membership for wp
  await prisma.projectMember.upsert({
    where: {
      userId_projectId: {
        userId: wp.id,
        projectId: project.id,
      },
    },
    update: { role: 'owner' },
    create: {
      userId: wp.id,
      projectId: project.id,
      role: 'owner',
    },
  });
  console.log('✅ Owner membership created for wp');

  // Guest membership for 825
  await prisma.projectMember.upsert({
    where: {
      userId_projectId: {
        userId: guest.id,
        projectId: project.id,
      },
    },
    update: { role: 'guest' },
    create: {
      userId: guest.id,
      projectId: project.id,
      role: 'guest',
    },
  });
  console.log('✅ Guest membership created for 825');

  // Step 4: Migrate all existing documents to One Senior Care project
  console.log('\n📄 Migrating existing documents to project...');
  const documentsWithoutProject = await prisma.document.findMany({
    where: {
      projectId: null,
    },
  });

  if (documentsWithoutProject.length > 0) {
    await prisma.document.updateMany({
      where: {
        projectId: null,
      },
      data: {
        projectId: project.id,
      },
    });
    console.log(`✅ Migrated ${documentsWithoutProject.length} documents to project`);
  } else {
    console.log('ℹ️  No documents need migration (already have projectId)');
  }

  // Step 5: Verify data integrity
  console.log('\n🔍 Verifying data integrity...');
  
  const totalDocs = await prisma.document.count({
    where: { projectId: project.id },
  });
  console.log(`✅ Total documents in project: ${totalDocs}`);

  const totalChunks = await prisma.documentChunk.count();
  console.log(`✅ Total document chunks preserved: ${totalChunks}`);

  const projectMembers = await prisma.projectMember.count({
    where: { projectId: project.id },
  });
  console.log(`✅ Total project members: ${projectMembers}`);

  console.log('\n✨ Migration complete!');
  console.log('\n📋 Test Account Summary:');
  console.log('  • Admin: username="Admin", password="123" (role: admin)');
  console.log('  • Client: username="wp", password="825" (role: client, owns One Senior Care)');
  console.log('  • Guest: username="825", password=<none> (role: guest, assigned to One Senior Care)');
}

main()
  .catch((e) => {
    console.error('❌ Migration failed:', e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
