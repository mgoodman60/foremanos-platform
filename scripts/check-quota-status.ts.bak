import * as dotenv from 'dotenv';
dotenv.config();

import { prisma } from '../lib/db';
import { getProcessingLimits } from '../lib/processing-limits';

async function checkQuotas() {
  const users = await prisma.user.findMany({
    where: {
      role: { not: 'guest' }
    },
    select: {
      email: true,
      username: true,
      role: true,
      subscriptionTier: true,
      pagesProcessedThisMonth: true,
      processingResetAt: true,
    }
  });

  console.log('\n📊 USER QUOTA STATUS:\n');
  users.forEach((user: any) => {
    const limits = getProcessingLimits(user.subscriptionTier);
    const resetDate = new Date(user.processingResetAt);
    const now = new Date();
    const daysUntilReset = Math.ceil((resetDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
    const shouldReset = daysUntilReset <= 0;
    
    console.log(`User: ${user.email || user.username}`);
    console.log(`  Role: ${user.role}`);
    console.log(`  Tier: ${user.subscriptionTier}`);
    console.log(`  Quota Limit: ${1000} pages/month`);
    console.log(`  Pages Used: ${user.pagesProcessedThisMonth}`);
    console.log(`  Pages Remaining: ${Math.max(0, 1000 - user.pagesProcessedThisMonth)}`);
    console.log(`  Reset Date: ${resetDate.toISOString()}`);
    console.log(`  Days Until Reset: ${daysUntilReset}`);
    console.log(`  Should Reset: ${shouldReset ? '⚠️  YES - QUOTA PAST DUE' : 'No'}`);
    console.log('');
  });

  await prisma.$disconnect();
}

checkQuotas().catch(console.error);
