/**
 * Simple test to verify fast failover from Abacus AI to Claude
 */

import { analyzeWithMultiProvider } from '../lib/vision-api-multi-provider';

async function testFailover() {
  console.log('======================================');
  console.log('Provider Failover Test');
  console.log('======================================');
  console.log('');
  
  // Create a simple test image (1x1 pixel white PNG)
  const testImage = Buffer.from([
    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
    0x00, 0x00, 0x00, 0x0D, 0x49, 0x48, 0x44, 0x52,
    0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
    0x08, 0x06, 0x00, 0x00, 0x00, 0x1F, 0x15, 0xC4,
    0x89, 0x00, 0x00, 0x00, 0x0A, 0x49, 0x44, 0x41,
    0x54, 0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00,
    0x05, 0x00, 0x01, 0x0D, 0x0A, 0x2D, 0xB4, 0x00,
    0x00, 0x00, 0x00, 0x49, 0x45, 0x4E, 0x44, 0xAE,
  ]).toString('base64');
  
  const prompt = 'Describe this test image';
  
  console.log('Starting failover test...');
  console.log('Expected: Abacus AI will timeout (10s) then Claude will succeed');
  console.log('');
  
  const startTime = Date.now();
  
  try {
    const result = await analyzeWithMultiProvider(testImage, prompt);
    
    const durationMs = Date.now() - startTime;
    const durationSec = durationMs / 1000;
    const durationStr = durationSec.toFixed(1);
    
    console.log('');
    console.log('======================================');
    console.log('Test Results');
    console.log('======================================');
    console.log('');
    console.log('✅ Processing completed');
    console.log(`⏱️  Total time: ${durationStr}s`);
    console.log('🔄 Provider used:', result.provider);
    console.log('🎯 Attempts:', result.attempts);
    console.log('📊 Content length:', result.content?.length || 0, 'chars');
    console.log('');
    
    if (durationSec < 15) {
      console.log('✅ PASS: Fast failover working (< 15s)');
    } else {
      console.log('⚠️  WARN: Slower than expected (> 15s)');
    }
    
    if (result.provider !== 'gpt-5.2') {
      console.log('✅ PASS: Fallback provider used (not Abacus AI)');
    } else {
      console.log('⚠️  UNEXPECTED: Abacus AI worked in dev environment');
    }
    
  } catch (error: any) {
    const durationSec = (Date.now() - startTime) / 1000;
    const durationStr = durationSec.toFixed(1);
    console.log('');
    console.log('❌ Test failed after', durationStr + 's');
    console.log('Error:', error.message);
  }
}

testFailover()
  .then(() => {
    console.log('');
    console.log('Test complete');
    process.exit(0);
  })
  .catch((error) => {
    console.error('Test error:', error);
    process.exit(1);
  });
