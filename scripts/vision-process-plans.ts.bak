      "title": "DOOR SCHEDULE or other title",
      "headers": ["Mark", "Type", "Size", "Material", "Hardware"],
      "rows": [
        {"Mark": "101", "Type": "A", "Size": "3070", "Material": "Wood", "Hardware": "Set 1"}
      ],
      "notes": ["table-specific notes"],
      "continuedFrom": "Sheet A-100 or null",
      "continuedTo": "Sheet A-102 or null"
    }
  ],
  "specDocument": {
