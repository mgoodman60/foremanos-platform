/**
 * Vision-Based Construction Document Processor
 * 
 * This script uses GPT-4o vision to analyze each page of a construction document (plans,
 * schedules, specifications, reports, etc.) as an image, extracting scale information,
 * dimensions (labeled and unlabeled), spatial relationships, schedules, and specifications.
 * The enriched data is stored in the database for RAG retrieval.
 * 
 * Usage:
 * - With arguments: yarn tsx scripts/vision-process-plans.ts <pdfPath> <documentId>
 * - Without arguments: Processes legacy Plans.pdf from public directory
 */

import { PrismaClient } from '@prisma/client';
import { execSync } from 'child_process';
import fs from 'fs';
import path from 'path';
import { PDFDocument } from 'pdf-lib';
import { extractTitleBlock, storeTitleBlockData } from '../lib/title-block-extractor';
import { detectLegendRegion, extractLegendEntries } from '../lib/legend-extractor';

const prisma = new PrismaClient();

// Check for required API key
if (!process.env.ABACUSAI_API_KEY) {
  console.error('❌ ABACUSAI_API_KEY not found in environment');
  process.exit(1);
}

interface VisionAnalysisResult {
  sheetNumber: string | null;
  scale: string | null;
  labeledDimensions: string[];
  derivedDimensions: string[];
  spatialElements: string[];
  legend?: string[];
  titleBlock?: {
    projectName?: string | null;
    projectNumber?: string | null;
    architect?: string | null;
    engineer?: string | null;
    contractor?: string | null;
    issueDate?: string | null;
    revisions?: string[];
    sheetTitle?: string | null;
  };
  notes: string[];
  hatchPatterns?: string[];
  zones?: Array<{
    name: string;
    description?: string;
    quantities?: string[];
    dimensions?: string[];
    notes?: string[];
  }>;
  crossReferences?: string[];
  detailCallouts?: Array<{
    type: 'section' | 'detail' | 'elevation';
    marker: string;
    description?: string;
    referenceSheet?: string;
  }>;
  gridLines?: {
    horizontal?: string[];
    vertical?: string[];
    description?: string;
  };
  roomNumbers?: Array<{
    number: string;
    name?: string;
    area?: string;
  }>;
  doorWindowTags?: Array<{
    type: 'door' | 'window';
    tag: string;
    location?: string;
    size?: string;
  }>;
  structuralCallouts?: string[];
  mepCallouts?: {
    electrical?: string[];
    plumbing?: string[];
    hvac?: string[];
  };
  elevationMarkers?: Array<{
    marker: string;
    elevation: string;
    location?: string;
  }>;
  orientation?: {
    northArrow?: string;
    direction?: string;
  };
  addendaReferences?: string[];
  phasingInfo?: Array<{
    phase: string;
    description?: string;
    scope?: string;
  }>;
  specReferences?: string[];
  schedules?: Array<{
    type: 'door' | 'window' | 'finish' | 'equipment' | 'room' | 'fixture' | 'other';
    title?: string;
    headers: string[];
    rows: Array<{
      [key: string]: string;
    }>;
    notes?: string[];
    continuedFrom?: string;
    continuedTo?: string;
  }>;
  specDocument?: {
    division?: string;
    divisionName?: string;
    section?: string;
    sectionName?: string;
    parts?: Array<{
      partNumber: string;
      partName: string;
      subsections?: Array<{
        title: string;
        content: string;
      }>;
    }>;
    submittals?: string[];
    qualityAssurance?: string[];
    testing?: string[];
    warranties?: string[];
    productReferences?: string[];
    substitutionRules?: string[];
  };
  // PHASE 1: Critical for Cost & Schedule Management
  materialQuantities?: Array<{
    material: string;
    zone?: string;
    quantity: string;
    specification?: string;
    location?: string;
    unit?: string;
  }>;
  submittals?: Array<{
    item: string;
    action: string; // shop drawings, product data, samples, mockups
    csiSection?: string;
    dueDate?: string;
    approvalBy?: string;
    copies?: number;
    deliveryMethod?: string;
  }>;
  inspections?: Array<{
    type: string; // special inspection, material testing, third-party
    item: string;
    standard?: string; // ASTM, ACI, AWS
    frequency?: string;
    inspector?: string;
    documentation?: string;
    testingRequired?: string;
    submittedTo?: string;
  }>;
  equipmentSpecs?: Array<{
    tag: string;
    type: string;
    manufacturer?: string;
    model?: string;
    capacity?: string;
    electrical?: string; // voltage, phase, amperage
    mechanical?: string; // BTU, CFM, GPM
    mounting?: string;
    clearances?: string;
    weight?: string;
    warranty?: string;
    maintenance?: string;
    location?: string;
  }>;
  rawAnalysis: string;
}

/**
 * Convert PDF page to PNG image using pdftoppm
 */
async function convertPdfPageToImage(pdfPath: string, pageNumber: number, outputDir: string): Promise<string> {
  const outputPrefix = path.join(outputDir, `page-${pageNumber}`);
  
  // Use pdftoppm to convert specific page to PNG
  // -png: output as PNG
  // -f: first page to convert
  // -l: last page to convert  
  // -singlefile: don't add page number suffix
  try {
    execSync(`pdftoppm -png -f ${pageNumber} -l ${pageNumber} -singlefile "${pdfPath}" "${outputPrefix}"`,{      stdio: 'pipe'
    });
    
    const imagePath = `${outputPrefix}.png`;
    
    if (!fs.existsSync(imagePath)) {
      throw new Error(`Image not created at ${imagePath}`);
    }
    
    // Read image and convert to base64
    const imageBuffer = fs.readFileSync(imagePath);
    const base64 = imageBuffer.toString('base64');
    
    // Clean up temp file
    fs.unlinkSync(imagePath);
    
    return `data:image/png;base64,${base64}`;
  } catch (error) {
    console.error(`Error converting page ${pageNumber}:`, error);
    throw error;
  }
}

/**
 * Analyze a plan page using GPT-5.2 vision (upgraded from GPT-4o for 30% better accuracy)
 */
async function analyzePlanPage(
  imageData: string,
  pageNumber: number,
  documentId: string,
  model: string = 'gpt-5.2'
): Promise<VisionAnalysisResult> {
  const apiKey = process.env.ABACUSAI_API_KEY!;
  
  const prompt = `You are analyzing a construction document page (plan sheet, schedule, specification, report, etc.). Extract the following information systematically and comprehensively:

1. SHEET NUMBER: Identify the sheet number or document identifier (e.g., A-001, S-001, C-102, E-101, Schedule 1)

2. SCALE: Look for and identify the scale notation (if applicable)
   - Graphic scale bar (e.g., shows 0, 10', 20', 40')
   - Text notation (e.g., "SCALE: 1\" = 20'-0\"" or "1:100")
   - State the scale clearly (or null if not applicable for this document type)

3. LABELED DIMENSIONS: List ALL explicitly labeled dimensions visible on the drawing
   - Include dimension callouts with units (e.g., "40'-0\"", "2'×2'", "24\"")
   - Note what each dimension describes (e.g., "Building width: 60'-0\"")
   - For schedules: extract quantities, sizes, and specifications from table cells

4. DERIVED DIMENSIONS: Using the identified scale, calculate unlabeled dimensions for major elements
   - Measure visual elements against the scale
   - Calculate real-world dimensions  
   - List these as "[Element]: approximately [dimension] (derived from scale)"
   - For non-scaled documents: extract calculated values or totals from tables

5. SPATIAL ELEMENTS: Identify major elements shown on this page
   - For plans: Parking lots, buildings, walls, rooms, structural elements, etc. with relative positions
   - For schedules: List items in the schedule (doors, windows, fixtures, equipment, etc.)
   - For specifications: Key materials, products, or systems specified

6. LEGEND/KEY INTERPRETATION (CRITICAL):
   - Locate any legend, key, or material index on the sheet
   - Extract ALL hatch pattern definitions (e.g., "diagonal lines = hardwood flooring", "dots = carpet")
   - Document line type meanings (dashed, dotted, solid with varying widths)
   - Note symbol definitions (door swings, electrical symbols, plumbing fixtures)
   - Map visual patterns on the drawing to their legend entries
   - Identify material zones by their hatch patterns and associate with legend meanings
   - If no legend exists on this sheet, state "No legend on this sheet"

7. TITLE BLOCK & BORDER INFORMATION:
   - Project name and project number
   - Contractor/Architect/Engineer firm names
   - Professional stamps or seals (PE, RA, etc.)
   - Sheet issue date and revision dates
   - Drawing title and sheet description
   - Approval signatures (if visible)
   - Consultant information (structural, MEP, civil engineers)
   - Sheet index or sheet count (e.g., "Sheet 5 of 12")

8. NOTES & ANNOTATIONS (COMPREHENSIVE):
   - General notes (numbered or bulleted lists)
   - Structural notes (load requirements, material specs, connections)
   - Architectural notes (finishes, clearances, accessibility)
   - MEP notes (electrical loads, plumbing fixtures, HVAC requirements)
   - Civil/site notes (grading, drainage, paving)
   - Material specifications and product callouts
   - Code references (IBC, ADA, NFPA, local codes)
   - Installation instructions and construction sequences
   - Coordination notes between trades
   - Quality control or testing requirements
   - Safety requirements or OSHA references
   - Special conditions or exceptions
   - Reference to other sheets or details
   - **Extract EVERY note visible on the sheet, even if it seems minor**

9. VISUAL PATTERN ANALYSIS:
   - Identify distinct hatch patterns used in the drawing (describe each pattern)
   - Match observed patterns to legend entries (e.g., "Area A uses diagonal hatch = wood flooring per legend")
   - Note material zones indicated by patterns (e.g., "Northwest room: crosshatch pattern")
   - Identify any color coding (though grayscale in OCR, note if colors are referenced in legend)
   - Describe boundary lines between different pattern zones

10. ZONE/AREA IDENTIFICATION & QUANTITY SEPARATION (CRITICAL):
   - Identify distinct zones or areas on the plan (e.g., "Building Slab", "Parking Lot", "Sidewalk", "Phase 1", "Phase 2")
   - For EACH labeled zone/area, extract its specific dimensions, quantities, and materials separately
   - Map quantities to specific zones: If you see "120 CY concrete - Building" and "40 CY concrete - Parking", list them separately
   - Look for area labels, callouts, or annotations that distinguish different construction zones
   - Extract material quantities PER ZONE when available (e.g., "Building Slab: 80 CY", "Parking Lot: 40 CY")
   - Identify spatial boundaries between zones (dotted lines, labels, hatching differences)
   - For schedules with zone columns: Extract quantities broken down by area/location
   - **IMPORTANT**: Do NOT combine quantities from different zones into one total
   - **IMPORTANT**: Do NOT attempt to calculate quantities from dimensions - only extract quantities that are explicitly labeled
   - If zones are visible but quantities are not labeled per zone, list the zones and note "quantities not specified per zone"

11. CROSS-REFERENCES (CRITICAL):
   - Extract ALL references to other sheets (e.g., "See detail A/Sheet 3.2", "Refer to S-101", "Typical detail 4/A-201")
   - Note specification references (e.g., "See spec section 03300", "Per Division 7")
   - Document drawing references (e.g., "As shown on civil drawings", "Coordinate with MEP plans")
   - Include "See Note X" or "Refer to Schedule Y" callouts

12. DETAIL CALLOUTS & SECTION MARKERS (CRITICAL):
   - Identify section cut symbols with markers (e.g., "Section 1/A-102" - arrow showing cut direction)
   - Extract detail callout bubbles (e.g., "Detail 3/A-201", "Detail A" with scale notation)
   - Note elevation markers (e.g., "Elevation B/A-301")
   - Document matchlines (e.g., "Match line - see sheet A-002")
   - Include grid bubble references at section cuts

13. GRID LINES & COORDINATE SYSTEM (CRITICAL):
   - Extract column grid lines: Letters (A, B, C, etc.) and Numbers (1, 2, 3, etc.)
   - Note grid dimensions between lines (e.g., "Grid A to B: 30'-0\"")
   - Document grid offsets (e.g., "Column at Grid 3 offset 2' north")
   - Include coordinate callouts if present (e.g., "N 1,234,567 E 7,654,321")

14. ROOM/SPACE NUMBERS & NAMES (CRITICAL):
   - Extract room numbers (e.g., "101", "Room 205", "Area 3B")
   - Include room names (e.g., "Conference Room", "Storage", "Mechanical Room")
   - Document room areas if labeled (e.g., "450 SF", "12.5 SM")
   - Note occupancy classifications (e.g., "Assembly A-2", "Business B")

15. DOOR & WINDOW TAGS (CRITICAL):
   - Identify door tags/numbers (e.g., "101", "102A", "D-1")
   - Extract window marks (e.g., "W1", "W-2", "Type A")
   - Note hardware sets if visible (e.g., "HDW Set 3")
   - Include frame types (e.g., "HM frame", "Wood frame")
   - Document sizes if labeled on plan (e.g., "3070", "6'-0\" x 7'-0\"")

16. STRUCTURAL CALLOUTS (CRITICAL):
   - Extract beam designations (e.g., "W12x26", "C10x15.3", "HSS4x4x1/4")
   - Document rebar callouts (e.g., "#5@12\" O.C.", "#4 dowels @ 24\" O.C.")
   - Note column sizes (e.g., "12\" dia. column", "W14x90")
   - Include footing callouts (e.g., "F-1: 4'x4'x18\"", "Spread footing - typ.")
   - Document slab specifications (e.g., "6\" slab on grade w/ #4@18\" O.C. E.W.")

17. MEP SYSTEM CALLOUTS (CRITICAL):
   - ELECTRICAL: Panel designations (e.g., "Panel A-1", "Circuit 12"), conduit sizes (e.g., "2\" EMT"), fixture types (e.g., "Type A - LED 2x4")
   - PLUMBING: Pipe sizes (e.g., "4\" PVC DWV", "3/4\" CW"), fixture callouts (e.g., "WC-1", "LAV-2"), cleanout locations
   - HVAC: Ductwork sizes (e.g., "18x12", "24\" Ø"), diffuser types (e.g., "SD-1: 12x12 supply"), unit tags (e.g., "AHU-1", "RTU-2")

18. ELEVATION MARKERS & BENCHMARKS (CRITICAL):
   - Extract elevation callouts (e.g., "ELEV. 100.0'", "FF 102'-6\"", "Top of wall 108'-3\"")
   - Document floor finish elevations (e.g., "FFE +0'-0\"", "Finish Floor 100.50")
   - Note benchmark references (e.g., "BM = 100.00' (City datum)", "Assumed datum")
   - Include spot elevations (e.g., "99.75 (top of curb)")

19. NORTH ARROW & ORIENTATION (CRITICAL):
   - Identify north arrow symbol and direction
   - Note if true north or magnetic north
   - Document rotation/bearing if specified (e.g., "N 15° E")
   - Include project north vs. true north notes

20. ADDENDA & BULLETIN REFERENCES (CRITICAL):
   - Extract addendum callouts (e.g., "Per Addendum #3", "Added per Addendum 5 dated 3/15/24")
   - Document bulletin references (e.g., "Revised per Bulletin 002", "See ASI #7")
   - Note change orders mentioned (e.g., "CO #12", "Field change #3")

21. CONSTRUCTION PHASING & SEQUENCING (CRITICAL):
   - Identify phase boundaries (e.g., "Phase 1 - Demo", "Phase 2 - New Construction", "Phase 3 - Site work")
   - Extract sequencing notes (e.g., "Install after MEP rough-in", "Coordinate with GC schedule")
   - Document temporary facilities/construction (e.g., "Temp fence line", "Construction access")
   - Note milestone markers (e.g., "Substantial completion - Area A")

22. SPECIFICATION SECTION REFERENCES (CRITICAL):
   - Extract CSI division references (e.g., "See spec 03300", "Per Division 7 - Thermal/Moisture")
   - Document specific section callouts (e.g., "Refer to spec 09 51 00 - Acoustical Ceilings")
   - Include product references (e.g., "As manufactured by ABC Corp or equal")

23. TABLE/SCHEDULE EXTRACTION (CRITICAL):
   **Purpose**: Construction schedules (door, window, finish, equipment, room schedules) are complex tables that require structured parsing.
   
   **Identify Table Type**:
   - Door Schedule: Columns like "Mark", "Type", "Size", "Material", "Hardware", "Fire Rating", "Location"
   - Window Schedule: Columns like "Mark", "Type", "Size", "Glazing", "Frame", "U-Value", "Location"
   - Finish Schedule: Columns like "Room", "Floor", "Base", "Walls", "Ceiling", "Notes"
   - Equipment Schedule: Columns like "Tag", "Description", "Model", "Capacity", "Voltage", "Location"
   - Room Schedule: Columns like "Number", "Name", "Area", "Finish", "Occupancy", "Notes"
   - Fixture Schedule: Columns like "Type", "Manufacturer", "Model", "Quantity", "Location"
   
   **Extract Table Structure**:
   - Table title (e.g., "DOOR SCHEDULE", "FINISH SCHEDULE")
   - Column headers (exact text from header row)
   - All data rows with cell values mapped to headers
   - Merged cells (note which cells span multiple columns)
   - Table notes or legends below the table
   - Continuation markers (e.g., "Continued on Sheet A-102" or "Continued from Sheet A-100")
   
   **Table Parsing Rules**:
   - Preserve exact cell values (don't interpret or convert)
   - Empty cells should be noted as empty/null
   - For multi-page tables, note continuation information
   - Extract table-specific notes separate from general notes
   - Map each row to its header structure as key-value pairs
   
   **Example Door Schedule Extraction**:
   Example JSON structure:
   {
     "type": "door",
     "title": "DOOR SCHEDULE",
     "headers": ["Mark", "Type", "Size", "Material", "Hardware", "Fire Rating"],
     "rows": [
       {"Mark": "101", "Type": "A", "Size": "3070", "Material": "Wood", "Hardware": "Set 1", "Fire Rating": "20 min"},
       {"Mark": "102", "Type": "B", "Size": "3068", "Material": "HM", "Hardware": "Set 2", "Fire Rating": "90 min"}
     ],
     "notes": ["See detail 3/A-301 for frame types", "All doors to be ADA compliant"],
     "continuedTo": "Sheet A-102"
   }
   
   **CRITICAL**: If you see a table/schedule on the page, you MUST extract it completely with all rows and columns.

24. SPECIFICATION DOCUMENT STRUCTURE (CRITICAL):
   **Purpose**: Technical specifications follow CSI MasterFormat structure with specific hierarchy and organization.
   
   **Identify Document Type**:
   - If you see "Division XX" or "Section XX XX XX" at the top → This is a SPECIFICATION DOCUMENT
   - Common indicators: "PART 1", "PART 2", "PART 3" sections
   
   **Extract CSI MasterFormat Structure**:
   
   **Division & Section**:
   - Division number (e.g., "03", "07", "09")
   - Division name (e.g., "Concrete", "Thermal and Moisture Protection", "Finishes")
   - Section number (e.g., "03 30 00", "07 21 00", "09 51 00")
   - Section name (e.g., "Cast-in-Place Concrete", "Thermal Insulation", "Acoustical Ceilings")
   
   **Part Structure** (extract each part separately):
   - **PART 1 - GENERAL**:
     - Summary (scope of work, related sections)
     - References (standards, codes)
     - Submittals (product data, shop drawings, samples, test reports)
     - Quality assurance (certifications, testing requirements)
     - Delivery, storage, and handling
     - Project conditions
     - Warranty requirements
   
   - **PART 2 - PRODUCTS**:
     - Manufacturers (acceptable manufacturers list)
     - Materials (specifications for each material)
     - Mixes/Formulations
     - Equipment (if applicable)
     - Fabrication requirements
     - Source quality control
   
   - **PART 3 - EXECUTION**:
     - Examination (site conditions)
     - Preparation (surface prep, priming)
     - Installation/Application/Performance
     - Field quality control (testing, inspections)
     - Adjusting/Cleaning
     - Protection
     - Schedules (if included)
   
   **Extract Key Requirements**:
   - Submittals: List all submittal requirements (e.g., "Submit product data for...", "Submit shop drawings showing...")
   - Quality Assurance: Testing requirements, certifications needed (e.g., "ASTM C123 compliance", "UL listed")
   - Testing: Field testing requirements (e.g., "Slump test every 50 CY", "Air content test per ASTM C231")
   - Warranties: Warranty terms (e.g., "5-year manufacturer warranty", "2-year installation warranty")
   - Product References: Specific products or "or equal" clauses (e.g., "ABC Corp Model 123 or approved equal")
   - Substitution Rules: Rules for product substitutions (e.g., "Submit substitution requests 30 days prior")
   
   **Example Spec Document Extraction**:
   Example JSON structure:
   {
     "division": "03",
     "divisionName": "Concrete",
     "section": "03 30 00",
     "sectionName": "Cast-in-Place Concrete",
     "parts": [
       {
         "partNumber": "1",
         "partName": "GENERAL",
         "subsections": [
           {"title": "Summary", "content": "This section includes cast-in-place concrete for foundations, slabs, walls..."},
           {"title": "References", "content": "ACI 301, ACI 318, ASTM C94"}
         ]
       },
       {
         "partNumber": "2",
         "partName": "PRODUCTS",
         "subsections": [
           {"title": "Concrete Mix", "content": "4000 psi @ 28 days, max slump 4 inches, air content 4-6%"}
         ]
       }
     ],
     "submittals": [
       "Submit product data for admixtures and curing compounds",
       "Submit mix designs for each concrete class",
       "Submit test reports for compressive strength"
     ],
     "qualityAssurance": [
       "ACI 301 compliance required",
       "Testing laboratory shall be certified per ASTM C1077"
     ],
     "testing": [
       "Slump test: 1 per 100 CY or 1 per day",
       "Compressive strength: 1 set of cylinders per 50 CY"
     ],
     "warranties": [
       "Manufacturer's warranty: 5 years against defects",
       "Installation warranty: 2 years"
     ],
     "productReferences": [
       "Portland Cement: ASTM C150 Type I/II",
       "Admixtures: ABC Corp Super Plasticizer or approved equal"
     ],
     "substitutionRules": [
       "Submit substitution requests minimum 30 days before procurement",
       "Substitutions must provide equal or better performance"
     ]
   }
   
   **CRITICAL**: 
   - If this is a spec document, extract the full CSI structure
   - Pay special attention to submittal requirements and testing
   - Note ALL product references and "or equal" clauses
   - Extract warranty durations explicitly

25. MATERIAL QUANTITY TAKEOFFS (PHASE 1 - CRITICAL):
   **Purpose**: Extract explicitly labeled material quantities for automated cost estimation and material ordering.
   
   **Extract Labeled Quantities ONLY** (do NOT calculate):
   - Concrete quantities by zone (CY, CF) - e.g., "Building Slab: 120 CY", "Parking Lot: 40 CY"
   - Rebar quantities by size (tons, linear feet) - e.g., "#5 @ 12\" O.C.: 2.4 tons"
   - Formwork/falsework areas (SF) - e.g., "Wall forms: 850 SF"
   - Masonry counts (units, SF) - e.g., "CMU: 1,200 units"
   - Structural steel tonnage - e.g., "W12x26 beams: 8.5 tons"
   - Drywall/sheathing areas (SF) - e.g., "Gypsum board: 4,800 SF"
   - Roofing/waterproofing (SF, squares) - e.g., "TPO roofing: 45 squares"
   - Paving (SY, tons) - e.g., "Asphalt paving: 240 tons"
   - Paint/coating areas - e.g., "Interior paint: 12,000 SF"
   - Excavation/fill volumes (CY) - e.g., "Cut: 350 CY, Fill: 280 CY"
   
   **IMPORTANT Rules**:
   - Extract ONLY quantities that are explicitly labeled on the document
   - DO NOT calculate quantities from dimensions or scales
   - Separate quantities by zone when labeled (e.g., "Building: 120 CY" vs "Parking: 40 CY")
   - Include material specifications if shown (e.g., "4000 PSI concrete")
   - Note the location/zone for each quantity
   - If no quantities are labeled, return empty array

26. SUBMITTAL REQUIREMENTS (PHASE 1 - CRITICAL):
   **Purpose**: Track what materials/equipment need approval before installation to prevent construction delays.
   
   **Extract Submittal Actions**:
   - Shop drawings (fabrication drawings)
   - Product data (manufacturer specs)
   - Samples (physical material samples)
   - Mockups (full-scale installations)
   - Test reports (material testing certifications)
   - Certifications (installer qualifications)
   
   **Extract for Each Submittal**:
   - Item description (what needs approval)
   - Action type (shop drawings, product data, etc.)
   - CSI division/section if specified
   - Due date or lead time (e.g., "30 days before fabrication")
   - Who approves (architect, engineer, owner)
   - Number of copies required
   - Delivery method (electronic, paper, portal)
   
   **Look for**:
   - "Submit..." or "Submittal:" phrases
   - Approval requirements in specs
   - Product data requirements
   - Shop drawing notes on plans

27. INSPECTION & TESTING REQUIREMENTS (PHASE 1 - CRITICAL):
   **Purpose**: Ensure quality control and code compliance by tracking required inspections and testing.
   
   **Extract Inspection Types**:
   - Special inspections (continuous or periodic observation)
   - Material testing (concrete, steel, soil, etc.)
   - Third-party testing (independent verification)
   - Building official inspections (code compliance)
   
   **Extract for Each Inspection/Test**:
   - Type of inspection (special, material test, etc.)
   - Item being inspected (concrete, welds, compaction)
   - Standard/specification (ASTM, ACI, AWS)
   - Frequency (continuous, daily, per 50 CY)
   - Inspector qualifications (CWI, special inspector, engineer)
   - Documentation requirements (reports, certifications)
   - Testing requirements (compressive strength, air content)
   - Who receives results (engineer, building official)
   
   **Look for**:
   - "Special inspection required"
   - "Testing requirements"
   - ASTM, ACI, AWS standard references
   - "Inspect before covering"
   - Cylinder testing notes
   - Weld inspection requirements

28. EQUIPMENT SPECIFICATIONS (PHASE 1 - CRITICAL):
   **Purpose**: Detailed equipment specs for procurement, installation, and operations.
   
   **Extract for Each Equipment Item**:
   - Equipment tag/ID (e.g., "AHU-1", "Panel A-1")
   - Equipment type (air handler, panel, pump, etc.)
   - Manufacturer (if specified)
   - Model number (if specified)
   - Capacity/size (CFM, BTU, GPM, HP, tonnage)
   - Electrical requirements (voltage, phase, amperage)
   - Mechanical specifications (BTU, CFM, GPM)
   - Mounting/installation requirements
   - Clearance requirements (service access)
   - Weight (for structural coordination)
   - Warranty period
   - Location (room, grid line)
   
   **Look for**:
   - Equipment schedules (major source)
   - Equipment tags on plans (AHU-1, RTU-2, Panel A)
   - Capacity callouts (15,000 CFM, 20 HP, 5 ton)
   - Electrical callouts (480V 3Ø, 60A)
   - "See equipment schedule" references


Provide your analysis in this exact JSON format:
{
  "sheetNumber": "sheet number or null",
  "scale": "scale notation or null",
  "labeledDimensions": ["dimension 1: value", "dimension 2: value"],
  "derivedDimensions": ["element 1: ~value (via scale)", "element 2: ~value (via scale)"],
  "spatialElements": ["element 1 description", "element 2 description"],
  "legend": ["pattern/symbol 1: meaning", "pattern/symbol 2: meaning"],
  "titleBlock": {
    "projectName": "name or null",
    "projectNumber": "number or null",
    "architect": "firm name or null",
    "engineer": "firm name or null",
    "contractor": "firm name or null",
    "issueDate": "date or null",
    "revisions": ["rev description with date"],
    "sheetTitle": "title or null"
  },
  "notes": ["note 1", "note 2", "note 3..."],
  "hatchPatterns": ["pattern description and location: meaning"],
  "zones": [
    {
