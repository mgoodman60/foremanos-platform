CRITICAL: 
1. Be EXHAUSTIVE with ALL extractions - extract every visible element
2. For cross-references, detail callouts, grid lines, room numbers, door/window tags - these are CRITICAL for answering location-specific questions
3. For schedules/tables - extract EVERY row and column, preserve exact values
4. For spec documents - extract complete CSI structure with all submittals, testing, and warranties
5. Separate quantities by zone when labeled - never combine them
6. Only extract explicitly labeled information - do NOT calculate or infer
7. If you cannot find a specific element type, use null or empty array
8. Pay special attention to small text, callouts, and symbols throughout the sheet`;

  try {
    const response = await fetch('https://apps.abacus.ai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        model: model,
        messages: [
          {
            role: 'user',
            content: [
              { type: 'text', text: prompt },
              {
                type: 'image_url',
                image_url: { url: imageData },
              },
            ],
          },
        ],
        max_tokens: 2000,
      }),
    });

    if (!response.ok) {
      const errorText = await response.text();
      throw new Error(`Vision API error: ${errorText}`);
    }

    const data = await response.json();
    const content = data.choices[0].message.content;
    
    // Parse JSON response
    const jsonMatch = content.match(/\{[\s\S]*\}/);
    if (!jsonMatch) {
      throw new Error('Could not extract JSON from vision response');
    }
    
    const parsed = JSON.parse(jsonMatch[0]);
    
    return {
      sheetNumber: parsed.sheetNumber || null,
      scale: parsed.scale || null,
      labeledDimensions: parsed.labeledDimensions || [],
      derivedDimensions: parsed.derivedDimensions || [],
      spatialElements: parsed.spatialElements || [],
      notes: parsed.notes || [],
      rawAnalysis: parsed.summary || content,
    };
  } catch (error) {
    console.error(`❌ Error analyzing page ${pageNumber}:`, error);
    return {
      sheetNumber: null,
      scale: null,
      labeledDimensions: [],
      derivedDimensions: [],
      spatialElements: [],
      notes: [],
      rawAnalysis: `Error analyzing page: ${error}`,
    };
  }
}

/**
 * Create base page context (shared by all chunks from this page)
 */
function createPageContext(analysis: VisionAnalysisResult, pageNumber: number): string {
  let context = '';
  
  if (analysis.sheetNumber) {
    context += `SHEET: ${analysis.sheetNumber}\n`;
  }
  
  context += `PAGE: ${pageNumber}\n`;
  
  // Title Block Information
  if (analysis.titleBlock && Object.keys(analysis.titleBlock).some(key => analysis.titleBlock![key as keyof typeof analysis.titleBlock])) {
    if (analysis.titleBlock.projectName) context += `PROJECT: ${analysis.titleBlock.projectName}\n`;
    if (analysis.titleBlock.sheetTitle) context += `SHEET TITLE: ${analysis.titleBlock.sheetTitle}\n`;
  }
  
  if (analysis.scale) {
    context += `SCALE: ${analysis.scale}\n`;
  }
  
  return context;
}

/**
 * Create enriched text chunk from vision analysis (for base page chunk)
 */
function createEnrichedChunk(analysis: VisionAnalysisResult, pageNumber: number): string {
  let chunk = '';
  
  if (analysis.sheetNumber) {
    chunk += `SHEET: ${analysis.sheetNumber}\n`;
  }
  
  chunk += `PAGE: ${pageNumber}\n`;
  chunk += `CHUNK TYPE: FULL PAGE OVERVIEW\n\n`;
  
  // Title Block Information
  if (analysis.titleBlock && Object.keys(analysis.titleBlock).some(key => analysis.titleBlock![key as keyof typeof analysis.titleBlock])) {
    chunk += `TITLE BLOCK:\n`;
    if (analysis.titleBlock.projectName) chunk += `- Project Name: ${analysis.titleBlock.projectName}\n`;
    if (analysis.titleBlock.projectNumber) chunk += `- Project Number: ${analysis.titleBlock.projectNumber}\n`;
    if (analysis.titleBlock.architect) chunk += `- Architect: ${analysis.titleBlock.architect}\n`;
    if (analysis.titleBlock.engineer) chunk += `- Engineer: ${analysis.titleBlock.engineer}\n`;
    if (analysis.titleBlock.contractor) chunk += `- Contractor: ${analysis.titleBlock.contractor}\n`;
    if (analysis.titleBlock.issueDate) chunk += `- Issue Date: ${analysis.titleBlock.issueDate}\n`;
    if (analysis.titleBlock.sheetTitle) chunk += `- Sheet Title: ${analysis.titleBlock.sheetTitle}\n`;
    if (analysis.titleBlock.revisions && analysis.titleBlock.revisions.length > 0) {
      chunk += `- Revisions:\n`;
      analysis.titleBlock.revisions.forEach((rev: any) => {
        chunk += `  * ${rev}\n`;
      });
    }
    chunk += '\n';
  }
  
  if (analysis.scale) {
    chunk += `SCALE: ${analysis.scale}\n\n`;
  }
  
  // Legend/Key Information
  if (analysis.legend && analysis.legend.length > 0) {
    chunk += `LEGEND/KEY:\n`;
    analysis.legend.forEach((entry: any) => {
      chunk += `- ${entry}\n`;
    });
    chunk += '\n';
  }
  
  // Hatch Patterns
  if (analysis.hatchPatterns && analysis.hatchPatterns.length > 0) {
    chunk += `HATCH PATTERNS & MATERIAL ZONES:\n`;
    analysis.hatchPatterns.forEach((pattern: any) => {
      chunk += `- ${pattern}\n`;
    });
    chunk += '\n';
  }
  
  if (analysis.labeledDimensions.length > 0) {
    chunk += `LABELED DIMENSIONS:\n`;
    analysis.labeledDimensions.forEach((dim: any) => {
      chunk += `- ${dim}\n`;
    });
    chunk += '\n';
  }
  
  if (analysis.derivedDimensions.length > 0) {
    chunk += `DERIVED DIMENSIONS (from scale analysis):\n`;
    analysis.derivedDimensions.forEach((dim: any) => {
      chunk += `- ${dim}\n`;
    });
    chunk += '\n';
  }
  
  if (analysis.spatialElements.length > 0) {
    chunk += `ELEMENTS SHOWN:\n`;
    analysis.spatialElements.forEach((elem: any) => {
      chunk += `- ${elem}\n`;
    });
    chunk += '\n';
  }
  
  // Zones/Areas with quantities
  if (analysis.zones && analysis.zones.length > 0) {
    chunk += `ZONES/AREAS (with quantities and dimensions):\n`;
    analysis.zones.forEach((zone: any) => {
      chunk += `\n${zone.name.toUpperCase()}:\n`;
      if (zone.description) chunk += `  Description: ${zone.description}\n`;
      
      if (zone.quantities && zone.quantities.length > 0) {
        chunk += `  Quantities:\n`;
        zone.quantities.forEach((qty: any) => {
          chunk += `    - ${qty}\n`;
        });
      }
      
      if (zone.dimensions && zone.dimensions.length > 0) {
        chunk += `  Dimensions:\n`;
        zone.dimensions.forEach((dim: any) => {
          chunk += `    - ${dim}\n`;
        });
      }
      
      if (zone.notes && zone.notes.length > 0) {
        chunk += `  Notes:\n`;
        zone.notes.forEach((note: any) => {
          chunk += `    - ${note}\n`;
        });
      }
    });
    chunk += '\n';
  }
  
  // Cross-References
  if (analysis.crossReferences && analysis.crossReferences.length > 0) {
    chunk += `CROSS-REFERENCES (to other sheets and documents):\n`;
    analysis.crossReferences.forEach((ref: any) => {
      chunk += `- ${ref}\n`;
    });
    chunk += '\n';
  }
  
  // Detail Callouts & Section Markers
  if (analysis.detailCallouts && analysis.detailCallouts.length > 0) {
    chunk += `DETAIL CALLOUTS & SECTION MARKERS:\n`;
    analysis.detailCallouts.forEach((callout: any) => {
      chunk += `- ${callout.type.toUpperCase()}: ${callout.marker}`;
      if (callout.description) chunk += ` - ${callout.description}`;
      if (callout.referenceSheet) chunk += ` (See sheet ${callout.referenceSheet})`;
      chunk += '\n';
    });
    chunk += '\n';
  }
  
  // Grid Lines
  if (analysis.gridLines && (analysis.gridLines.horizontal?.length || analysis.gridLines.vertical?.length)) {
    chunk += `GRID LINES & COORDINATE SYSTEM:\n`;
    if (analysis.gridLines.vertical && analysis.gridLines.vertical.length > 0) {
      chunk += `- Vertical Grids: ${analysis.gridLines.vertical.join(', ')}\n`;
    }
    if (analysis.gridLines.horizontal && analysis.gridLines.horizontal.length > 0) {
      chunk += `- Horizontal Grids: ${analysis.gridLines.horizontal.join(', ')}\n`;
    }
    if (analysis.gridLines.description) {
      chunk += `- Grid Notes: ${analysis.gridLines.description}\n`;
    }
    chunk += '\n';
  }
  
  // Room Numbers
  if (analysis.roomNumbers && analysis.roomNumbers.length > 0) {
    chunk += `ROOM/SPACE NUMBERS:\n`;
    analysis.roomNumbers.forEach((room: any) => {
      chunk += `- Room ${room.number}`;
      if (room.name) chunk += ` (${room.name})`;
      if (room.area) chunk += ` - ${room.area}`;
      chunk += '\n';
    });
    chunk += '\n';
  }
  
  // Door and Window Tags
  if (analysis.doorWindowTags && analysis.doorWindowTags.length > 0) {
    chunk += `DOOR & WINDOW TAGS:\n`;
    analysis.doorWindowTags.forEach((tag: any) => {
      chunk += `- ${tag.type.toUpperCase()} ${tag.tag}`;
      if (tag.location) chunk += ` at ${tag.location}`;
      if (tag.size) chunk += ` (${tag.size})`;
      chunk += '\n';
    });
    chunk += '\n';
  }
  
  // Structural Callouts
  if (analysis.structuralCallouts && analysis.structuralCallouts.length > 0) {
    chunk += `STRUCTURAL CALLOUTS:\n`;
    analysis.structuralCallouts.forEach((callout: any) => {
      chunk += `- ${callout}\n`;
    });
    chunk += '\n';
  }
  
  // MEP Callouts
  if (analysis.mepCallouts && (analysis.mepCallouts.electrical?.length || analysis.mepCallouts.plumbing?.length || analysis.mepCallouts.hvac?.length)) {
    chunk += `MEP SYSTEM CALLOUTS:\n`;
    
    if (analysis.mepCallouts.electrical && analysis.mepCallouts.electrical.length > 0) {
      chunk += `Electrical:\n`;
      analysis.mepCallouts.electrical.forEach((item: any) => {
        chunk += `  - ${item}\n`;
      });
    }
    
    if (analysis.mepCallouts.plumbing && analysis.mepCallouts.plumbing.length > 0) {
      chunk += `Plumbing:\n`;
      analysis.mepCallouts.plumbing.forEach((item: any) => {
        chunk += `  - ${item}\n`;
      });
    }
    
    if (analysis.mepCallouts.hvac && analysis.mepCallouts.hvac.length > 0) {
      chunk += `HVAC:\n`;
      analysis.mepCallouts.hvac.forEach((item: any) => {
        chunk += `  - ${item}\n`;
      });
    }
    chunk += '\n';
  }
  
  // Elevation Markers
  if (analysis.elevationMarkers && analysis.elevationMarkers.length > 0) {
    chunk += `ELEVATION MARKERS & BENCHMARKS:\n`;
    analysis.elevationMarkers.forEach((marker: any) => {
      chunk += `- ${marker.marker}: ${marker.elevation}`;
      if (marker.location) chunk += ` at ${marker.location}`;
      chunk += '\n';
    });
    chunk += '\n';
  }
  
  // Orientation (North Arrow)
  if (analysis.orientation && (analysis.orientation.northArrow || analysis.orientation.direction)) {
    chunk += `ORIENTATION:\n`;
    if (analysis.orientation.northArrow) chunk += `- North Arrow: ${analysis.orientation.northArrow}\n`;
    if (analysis.orientation.direction) chunk += `- Direction: ${analysis.orientation.direction}\n`;
    chunk += '\n';
  }
  
  // Addenda References
  if (analysis.addendaReferences && analysis.addendaReferences.length > 0) {
    chunk += `ADDENDA & REVISIONS:\n`;
    analysis.addendaReferences.forEach((ref: any) => {
      chunk += `- ${ref}\n`;
    });
    chunk += '\n';
  }
  
  // Phasing Information
  if (analysis.phasingInfo && analysis.phasingInfo.length > 0) {
    chunk += `CONSTRUCTION PHASING:\n`;
    analysis.phasingInfo.forEach((phase: any) => {
      chunk += `- ${phase.phase}`;
      if (phase.description) chunk += `: ${phase.description}`;
      if (phase.scope) chunk += ` - ${phase.scope}`;
      chunk += '\n';
    });
    chunk += '\n';
  }
  
  // Specification References
  if (analysis.specReferences && analysis.specReferences.length > 0) {
    chunk += `SPECIFICATION REFERENCES:\n`;
    analysis.specReferences.forEach((ref: any) => {
      chunk += `- ${ref}\n`;
    });
    chunk += '\n';
  }
  
  // Schedules/Tables (CRITICAL for schedule-based questions)
  if (analysis.schedules && analysis.schedules.length > 0) {
    chunk += `TABLES & SCHEDULES:\n\n`;
    analysis.schedules.forEach((schedule: any) => {
      chunk += `${schedule.title || schedule.type.toUpperCase() + ' SCHEDULE'}:\n`;
      chunk += `Type: ${schedule.type}\n`;
      
      if (schedule.continuedFrom) {
        chunk += `[Continued from ${schedule.continuedFrom}]\n`;
      }
      
      // Create table structure
      chunk += `\nColumns: ${schedule.headers.join(' | ')}\n`;
      chunk += `${'─'.repeat(80)}\n`;
      
      schedule.rows.forEach((row: any) => {
        const values = schedule.headers.map((header: string) => {
          const value = row[header] || '';
          return value;
        });
        chunk += `${values.join(' | ')}\n`;
      });
      
      if (schedule.notes && schedule.notes.length > 0) {
        chunk += `\nSchedule Notes:\n`;
        schedule.notes.forEach((note: any) => {
          chunk += `  - ${note}\n`;
        });
      }
      
      if (schedule.continuedTo) {
        chunk += `[Continued on ${schedule.continuedTo}]\n`;
      }
      
      chunk += '\n';
    });
  }
  
  // Specification Document Structure (CRITICAL for spec questions)
  if (analysis.specDocument && (analysis.specDocument.division || analysis.specDocument.section)) {
    chunk += `SPECIFICATION DOCUMENT:\n\n`;
    
    if (analysis.specDocument.division) {
      chunk += `Division: ${analysis.specDocument.division}`;
      if (analysis.specDocument.divisionName) {
        chunk += ` - ${analysis.specDocument.divisionName}`;
      }
      chunk += '\n';
    }
    
    if (analysis.specDocument.section) {
      chunk += `Section: ${analysis.specDocument.section}`;
      if (analysis.specDocument.sectionName) {
        chunk += ` - ${analysis.specDocument.sectionName}`;
      }
      chunk += '\n\n';
    }
    
    // Parts Structure
    if (analysis.specDocument.parts && analysis.specDocument.parts.length > 0) {
      chunk += `PARTS:\n`;
      analysis.specDocument.parts.forEach((part: any) => {
        chunk += `\nPART ${part.partNumber} - ${part.partName}:\n`;
        if (part.subsections && part.subsections.length > 0) {
          part.subsections.forEach((subsection: any) => {
            chunk += `  ${subsection.title}:\n`;
            chunk += `    ${subsection.content}\n`;
          });
        }
      });
      chunk += '\n';
    }
    
    // Submittals
    if (analysis.specDocument.submittals && analysis.specDocument.submittals.length > 0) {
      chunk += `SUBMITTAL REQUIREMENTS:\n`;
      analysis.specDocument.submittals.forEach((submittal: any) => {
        chunk += `  - ${submittal}\n`;
      });
      chunk += '\n';
    }
    
    // Quality Assurance
    if (analysis.specDocument.qualityAssurance && analysis.specDocument.qualityAssurance.length > 0) {
      chunk += `QUALITY ASSURANCE:\n`;
      analysis.specDocument.qualityAssurance.forEach((qa: any) => {
        chunk += `  - ${qa}\n`;
      });
      chunk += '\n';
    }
    
    // Testing Requirements
    if (analysis.specDocument.testing && analysis.specDocument.testing.length > 0) {
      chunk += `TESTING REQUIREMENTS:\n`;
      analysis.specDocument.testing.forEach((test: any) => {
        chunk += `  - ${test}\n`;
      });
      chunk += '\n';
    }
    
    // Warranties
    if (analysis.specDocument.warranties && analysis.specDocument.warranties.length > 0) {
      chunk += `WARRANTIES:\n`;
      analysis.specDocument.warranties.forEach((warranty: any) => {
        chunk += `  - ${warranty}\n`;
      });
      chunk += '\n';
    }
    
    // Product References
    if (analysis.specDocument.productReferences && analysis.specDocument.productReferences.length > 0) {
      chunk += `PRODUCT REFERENCES:\n`;
      analysis.specDocument.productReferences.forEach((product: any) => {
        chunk += `  - ${product}\n`;
      });
      chunk += '\n';
    }
    
    // Substitution Rules
    if (analysis.specDocument.substitutionRules && analysis.specDocument.substitutionRules.length > 0) {
      chunk += `SUBSTITUTION RULES:\n`;
      analysis.specDocument.substitutionRules.forEach((rule: any) => {
        chunk += `  - ${rule}\n`;
      });
      chunk += '\n';
    }
  }
  
  // PHASE 1: Material Quantity Takeoffs
  if (analysis.materialQuantities && analysis.materialQuantities.length > 0) {
    chunk += `MATERIAL QUANTITY TAKEOFFS:\n`;
    analysis.materialQuantities.forEach((item: any) => {
      chunk += `\n${item.material.toUpperCase()}`;
      if (item.zone) chunk += ` (${item.zone})`;
      chunk += `:\n`;
      chunk += `  Quantity: ${item.quantity}`;
      if (item.unit) chunk += ` ${item.unit}`;
      chunk += `\n`;
      if (item.specification) chunk += `  Specification: ${item.specification}\n`;
      if (item.location) chunk += `  Location: ${item.location}\n`;
    });
    chunk += '\n';
  }
  
  // PHASE 1: Submittal Requirements
  if (analysis.submittals && analysis.submittals.length > 0) {
    chunk += `SUBMITTAL REQUIREMENTS:\n`;
    analysis.submittals.forEach((submittal: any) => {
      chunk += `\n- ${submittal.item}\n`;
      chunk += `  Action: ${submittal.action}\n`;
      if (submittal.csiSection) chunk += `  CSI Section: ${submittal.csiSection}\n`;
      if (submittal.dueDate) chunk += `  Due Date: ${submittal.dueDate}\n`;
      if (submittal.approvalBy) chunk += `  Approved By: ${submittal.approvalBy}\n`;
      if (submittal.copies) chunk += `  Copies Required: ${submittal.copies}\n`;
      if (submittal.deliveryMethod) chunk += `  Delivery: ${submittal.deliveryMethod}\n`;
    });
    chunk += '\n';
  }
  
  // PHASE 1: Inspection & Testing Requirements
  if (analysis.inspections && analysis.inspections.length > 0) {
    chunk += `INSPECTION & TESTING REQUIREMENTS:\n`;
    analysis.inspections.forEach((inspection: any) => {
      chunk += `\n- ${inspection.type}: ${inspection.item}\n`;
      if (inspection.standard) chunk += `  Standard: ${inspection.standard}\n`;
      if (inspection.frequency) chunk += `  Frequency: ${inspection.frequency}\n`;
      if (inspection.inspector) chunk += `  Inspector: ${inspection.inspector}\n`;
      if (inspection.documentation) chunk += `  Documentation: ${inspection.documentation}\n`;
      if (inspection.testingRequired) chunk += `  Testing: ${inspection.testingRequired}\n`;
      if (inspection.submittedTo) chunk += `  Submitted To: ${inspection.submittedTo}\n`;
    });
    chunk += '\n';
  }
  
  // PHASE 1: Equipment Specifications
  if (analysis.equipmentSpecs && analysis.equipmentSpecs.length > 0) {
    chunk += `EQUIPMENT SPECIFICATIONS:\n`;
    analysis.equipmentSpecs.forEach((equip: any) => {
      chunk += `\n- ${equip.tag}: ${equip.type}\n`;
      if (equip.manufacturer) chunk += `  Manufacturer: ${equip.manufacturer}\n`;
      if (equip.model) chunk += `  Model: ${equip.model}\n`;
      if (equip.capacity) chunk += `  Capacity: ${equip.capacity}\n`;
      if (equip.electrical) chunk += `  Electrical: ${equip.electrical}\n`;
      if (equip.mechanical) chunk += `  Mechanical: ${equip.mechanical}\n`;
      if (equip.mounting) chunk += `  Mounting: ${equip.mounting}\n`;
      if (equip.clearances) chunk += `  Clearances: ${equip.clearances}\n`;
      if (equip.weight) chunk += `  Weight: ${equip.weight}\n`;
      if (equip.warranty) chunk += `  Warranty: ${equip.warranty}\n`;
      if (equip.maintenance) chunk += `  Maintenance: ${equip.maintenance}\n`;
      if (equip.location) chunk += `  Location: ${equip.location}\n`;
    });
    chunk += '\n';
  }
  
  if (analysis.notes.length > 0) {
    chunk += `NOTES AND SPECIFICATIONS:\n`;
    analysis.notes.forEach((note: any) => {
      chunk += `- ${note}\n`;
    });
    chunk += '\n';
  }
  
  chunk += `SUMMARY: ${analysis.rawAnalysis}\n`;
  
  return chunk;
}

/**
 * Create a focused chunk for a specific detail callout
 */
function createDetailChunk(
  analysis: VisionAnalysisResult,
  pageNumber: number,
  detail: any,
  detailIndex: number
): string {
  const pageContext = createPageContext(analysis, pageNumber);
  
  let chunk = pageContext;
  chunk += `CHUNK TYPE: DETAIL CALLOUT\n`;
  chunk += `DETAIL: ${detail.marker}\n\n`;
  
  chunk += `===== DETAIL CALLOUT: ${detail.marker} =====\n\n`;
  chunk += `Type: ${detail.type.toUpperCase()}\n`;
  if (detail.description) chunk += `Description: ${detail.description}\n`;
  if (detail.referenceSheet) chunk += `Reference Sheet: ${detail.referenceSheet}\n`;
  chunk += '\n';
  
  // Include relevant dimensions if they reference this detail
  const relevantDimensions = analysis.labeledDimensions.filter((dim: string) => 
    dim.toLowerCase().includes(detail.marker.toLowerCase()) ||
    dim.toLowerCase().includes(detail.type.toLowerCase())
  );
  
  if (relevantDimensions.length > 0) {
    chunk += `DIMENSIONS FOR THIS DETAIL:\n`;
    relevantDimensions.forEach((dim: string) => {
      chunk += `- ${dim}\n`;
    });
    chunk += '\n';
  }
  
  // Include relevant notes
  const relevantNotes = analysis.notes.filter((note: string) =>
    note.toLowerCase().includes(detail.marker.toLowerCase()) ||
    note.toLowerCase().includes(detail.type.toLowerCase())
  );
  
  if (relevantNotes.length > 0) {
    chunk += `NOTES FOR THIS DETAIL:\n`;
    relevantNotes.forEach((note: string) => {
      chunk += `- ${note}\n`;
    });
    chunk += '\n';
  }
  
  // Include cross-references
  if (analysis.crossReferences && analysis.crossReferences.length > 0) {
    const relevantRefs = analysis.crossReferences.filter((ref: string) =>
      ref.toLowerCase().includes(detail.marker.toLowerCase())
    );
    
    if (relevantRefs.length > 0) {
      chunk += `RELATED REFERENCES:\n`;
      relevantRefs.forEach((ref: string) => {
        chunk += `- ${ref}\n`;
      });
      chunk += '\n';
    }
  }
  
  // Include structural/MEP callouts if relevant
  if (detail.type === 'section' && analysis.structuralCallouts && analysis.structuralCallouts.length > 0) {
    chunk += `STRUCTURAL CALLOUTS:\n`;
    analysis.structuralCallouts.forEach((callout: string) => {
      chunk += `- ${callout}\n`;
    });
    chunk += '\n';
  }
  
  return chunk;
}

/**
 * Create a focused chunk for a specific zone/area
 */
function createZoneChunk(
  analysis: VisionAnalysisResult,
  pageNumber: number,
  zone: any,
  zoneIndex: number
): string {
  const pageContext = createPageContext(analysis, pageNumber);
  
  let chunk = pageContext;
  chunk += `CHUNK TYPE: ZONE/AREA\n`;
  chunk += `ZONE: ${zone.name}\n\n`;
  
  chunk += `===== ZONE/AREA: ${zone.name.toUpperCase()} =====\n\n`;
  
  if (zone.description) {
    chunk += `Description: ${zone.description}\n\n`;
  }
  
  if (zone.quantities && zone.quantities.length > 0) {
    chunk += `QUANTITIES FOR ${zone.name}:\n`;
    zone.quantities.forEach((qty: string) => {
      chunk += `- ${qty}\n`;
    });
    chunk += '\n';
  }
  
  if (zone.dimensions && zone.dimensions.length > 0) {
    chunk += `DIMENSIONS FOR ${zone.name}:\n`;
    zone.dimensions.forEach((dim: string) => {
      chunk += `- ${dim}\n`;
    });
    chunk += '\n';
  }
  
  if (zone.notes && zone.notes.length > 0) {
    chunk += `NOTES FOR ${zone.name}:\n`;
    zone.notes.forEach((note: string) => {
      chunk += `- ${note}\n`;
    });
    chunk += '\n';
  }
  
  // Include spatial elements relevant to this zone
  const relevantElements = analysis.spatialElements.filter((elem: string) =>
    elem.toLowerCase().includes(zone.name.toLowerCase())
  );
  
  if (relevantElements.length > 0) {
    chunk += `ELEMENTS IN ${zone.name}:\n`;
    relevantElements.forEach((elem: string) => {
      chunk += `- ${elem}\n`;
    });
    chunk += '\n';
  }
  
  // Include hatch patterns if relevant
  if (analysis.hatchPatterns && analysis.hatchPatterns.length > 0) {
    const relevantPatterns = analysis.hatchPatterns.filter((pattern: string) =>
      pattern.toLowerCase().includes(zone.name.toLowerCase())
    );
    
    if (relevantPatterns.length > 0) {
      chunk += `MATERIAL PATTERNS FOR ${zone.name}:\n`;
      relevantPatterns.forEach((pattern: string) => {
        chunk += `- ${pattern}\n`;
      });
      chunk += '\n';
    }
  }
  
  return chunk;
}

/**
 * Create a focused chunk for room/space information
 */
function createRoomChunk(
  analysis: VisionAnalysisResult,
  pageNumber: number,
  room: any,
  roomIndex: number
): string {
  const pageContext = createPageContext(analysis, pageNumber);
  
  let chunk = pageContext;
  chunk += `CHUNK TYPE: ROOM/SPACE\n`;
  chunk += `ROOM: ${room.number}\n\n`;
  
  chunk += `===== ROOM/SPACE: ${room.number} =====\n\n`;
  
  if (room.name) chunk += `Room Name: ${room.name}\n`;
  if (room.area) chunk += `Area: ${room.area}\n`;
  chunk += '\n';
  
  // Include door/window tags for this room
  if (analysis.doorWindowTags && analysis.doorWindowTags.length > 0) {
    const roomDoors = analysis.doorWindowTags.filter((tag: any) =>
      tag.location && tag.location.toLowerCase().includes(room.number.toLowerCase())
    );
    
    if (roomDoors.length > 0) {
      chunk += `DOORS/WINDOWS IN ROOM ${room.number}:\n`;
      roomDoors.forEach((tag: any) => {
        chunk += `- ${tag.type.toUpperCase()} ${tag.tag}`;
        if (tag.size) chunk += ` (${tag.size})`;
        if (tag.location) chunk += ` - ${tag.location}`;
        chunk += '\n';
      });
      chunk += '\n';
    }
  }
  
  // Include MEP callouts for this room
  if (analysis.mepCallouts) {
    let hasMEP = false;
    let mepContent = `MEP SYSTEMS IN ROOM ${room.number}:\n`;
    
    if (analysis.mepCallouts.electrical && analysis.mepCallouts.electrical.some((call: string) => 
      call.toLowerCase().includes(room.number.toLowerCase())
    )) {
      mepContent += `Electrical:\n`;
      analysis.mepCallouts.electrical.forEach((call: string) => {
        if (call.toLowerCase().includes(room.number.toLowerCase())) {
          mepContent += `  - ${call}\n`;
          hasMEP = true;
        }
      });
    }
    
    if (analysis.mepCallouts.plumbing && analysis.mepCallouts.plumbing.some((call: string) => 
      call.toLowerCase().includes(room.number.toLowerCase())
    )) {
      mepContent += `Plumbing:\n`;
      analysis.mepCallouts.plumbing.forEach((call: string) => {
        if (call.toLowerCase().includes(room.number.toLowerCase())) {
          mepContent += `  - ${call}\n`;
          hasMEP = true;
        }
      });
    }
    
    if (analysis.mepCallouts.hvac && analysis.mepCallouts.hvac.some((call: string) => 
      call.toLowerCase().includes(room.number.toLowerCase())
    )) {
      mepContent += `HVAC:\n`;
      analysis.mepCallouts.hvac.forEach((call: string) => {
        if (call.toLowerCase().includes(room.number.toLowerCase())) {
          mepContent += `  - ${call}\n`;
          hasMEP = true;
        }
      });
    }
    
    if (hasMEP) {
      chunk += mepContent + '\n';
    }
  }
  
  return chunk;
}

/**
 * Extract title blocks from all pages of a document
 * @param pdfPath Path to the PDF file
 * @param documentId Document ID in database
 * @returns Number of title blocks extracted
 */
async function extractTitleBlocksFromDocument(pdfPath: string, documentId: string): Promise<number> {
  try {
    // Get document details
    const document = await prisma.document.findUnique({
      where: { id: documentId },
      select: { projectId: true, fileName: true },
    });
    
    if (!document) {
      console.error('Document not found');
      return 0;
    }
    
    // Get PDF page count
    const pdfBytes = fs.readFileSync(pdfPath);
    const pdfDoc = await PDFDocument.load(pdfBytes);
    const totalPages = pdfDoc.getPageCount();
    
    // Create temp directory for images
    const tempDir = path.join(process.cwd(), '.temp-titleblock');
    if (!fs.existsSync(tempDir)) {
      fs.mkdirSync(tempDir);
    }
    
    let count = 0;
    
    try {
      for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
        try {
          // Convert page to image
          const imagePath = path.join(tempDir, `page-${pageNum}.png`);
          execSync(
            `pdftoppm -png -f ${pageNum} -l ${pageNum} -r 150 "${pdfPath}" "${imagePath.replace('.png', '')}"`,
            { stdio: 'pipe' }
          );
          
          // Find the generated image
          const files = fs.readdirSync(tempDir);
          const pageFile = files.find(f => f.startsWith(`page-${pageNum}-`));
          
          if (pageFile) {
            const fullImagePath = path.join(tempDir, pageFile);
            const imageBuffer = fs.readFileSync(fullImagePath);
            const base64Image = imageBuffer.toString('base64');
            
            // Extract title block
            const titleBlockResult = await extractTitleBlock(
              base64Image,
              '', // No pre-extracted text
              document.fileName
            );
            
            if (titleBlockResult.success && titleBlockResult.confidence > 0.5 && titleBlockResult.data) {
              // Store title block data by updating existing chunk or creating new one
              const sheetNum = titleBlockResult.data.sheetNumber || `Page ${pageNum}`;
              
              // Find existing chunk for this page to update
              const existingChunk = await prisma.documentChunk.findFirst({
                where: {
                  documentId: documentId,
                  metadata: {
                    path: ['page'],
                    equals: pageNum,
                  },
                },
              });
              
              if (existingChunk) {
                // Update existing chunk with title block data
                await prisma.documentChunk.update({
                  where: { id: existingChunk.id },
                  data: {
                    sheetNumber: sheetNum,
                    titleBlockData: titleBlockResult.data as any,
                    revision: titleBlockResult.data.revision,
                    dateIssued: titleBlockResult.data.dateIssued 
                      ? new Date(titleBlockResult.data.dateIssued) 
                      : null,
                    discipline: titleBlockResult.data.discipline,
                  },
                });
                count++;
              }
            }
          }
        } catch (pageError) {
          console.error(`Error processing page ${pageNum} for title blocks:`, pageError);
          // Continue with next page
        }
      }
    } finally {
      // Clean up temp directory
      if (fs.existsSync(tempDir)) {
        fs.rmSync(tempDir, { recursive: true, force: true });
      }
    }
    
    return count;
  } catch (error) {
    console.error('Error extracting title blocks:', error);
    return 0;
  }
}

/**
 * Extract legends from all pages of a document
 * @param pdfPath Path to the PDF file
 * @param documentId Document ID in database
 * @returns Number of legends extracted
 */
async function extractLegendsFromDocument(pdfPath: string, documentId: string): Promise<number> {
  try {
    // Get document details
    const document = await prisma.document.findUnique({
      where: { id: documentId },
      include: { project: { select: { slug: true } } },
    });
    
    if (!document || !document.project) {
      console.error('Document or project not found');
      return 0;
    }
    
    // Convert PDF pages to images for legend detection
    const pdfBytes = fs.readFileSync(pdfPath);
    const pdfDoc = await PDFDocument.load(pdfBytes);
    const totalPages = pdfDoc.getPageCount();
    
    // Create temp directory for images
    const tempDir = path.join(process.cwd(), '.temp-legend');
    if (!fs.existsSync(tempDir)) {
      fs.mkdirSync(tempDir);
    }
    
    let legendCount = 0;
    
    try {
      for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
        try {
          // Convert page to image
          const imagePath = path.join(tempDir, `page-${pageNum}.png`);
          execSync(
            `pdftoppm -png -f ${pageNum} -l ${pageNum} -r 150 "${pdfPath}" "${imagePath.replace('.png', '')}"`,
            { stdio: 'pipe' }
          );
          
          // Find the generated image (pdftoppm adds page numbers)
          const files = fs.readdirSync(tempDir);
          const pageFile = files.find(f => f.startsWith(`page-${pageNum}-`));
          
          if (pageFile) {
            const fullImagePath = path.join(tempDir, pageFile);
            const imageBuffer = fs.readFileSync(fullImagePath);
            const base64Image = imageBuffer.toString('base64');
            
            // Detect legend region
            const legendDetection = await detectLegendRegion(base64Image, `Page ${pageNum}`);
            
            if (legendDetection.found) {
              // Extract legend entries
              const legendResult = await extractLegendEntries(base64Image, `Page ${pageNum}`);
              
              if (legendResult.success && legendResult.legend && legendResult.legend.legendEntries.length > 0) {
                // Store in database (only if project ID exists)
                if (document.projectId) {
                  await prisma.sheetLegend.create({
                    data: {
                      projectId: document.projectId,
                      documentId: documentId,
                      sheetNumber: `Page ${pageNum}`, // Will be updated if title block has sheet number
                      legendEntries: legendResult.legend.legendEntries as any,
                      boundingBox: legendDetection.boundingBox || {},
                      confidence: legendDetection.confidence,
                      discipline: legendResult.legend.discipline || null,
                    },
                  });
                  legendCount++;
                }
              }
            }
          }
        } catch (pageError) {
          console.error(`Error processing page ${pageNum} for legends:`, pageError);
          // Continue with next page
        }
      }
    } finally {
      // Clean up temp directory
      if (fs.existsSync(tempDir)) {
        fs.rmSync(tempDir, { recursive: true, force: true });
      }
    }
    
    return legendCount;
  } catch (error) {
    console.error('Error extracting legends:', error);
    return 0;
  }
}

/**
 * Extract dimensions from document pages (Phase B.2)
 */
async function extractDimensionsFromDocument(documentId: string): Promise<number> {
  try {
    const { extractDimensionsWithVision, extractDimensionsFromText, storeDimensions } = 
      await import('../lib/dimension-intelligence');
    
    console.log('\\n🔢 Extracting dimensions from document...');
    
    // Get document and project
    const document = await prisma.document.findUnique({
      where: { id: documentId },
      include: {
        project: true,
        chunks: {
          select: {
            id: true,
            content: true,
            pageNumber: true,
            metadata: true,
          },
          orderBy: { pageNumber: 'asc' },
        },
      },
    });
    
    if (!document || !document.chunks.length) {
      console.log('No document or chunks found');
      return 0;
    }
    
    let totalDimensions = 0;
    const allDimensions: any[] = [];
    
    // Process each page/chunk
    for (const chunk of document.chunks) {
      try {
        const pageNum = chunk.pageNumber || 1;
        const metadata = chunk.metadata as any;
        const sheetNumber = metadata?.sheet_number || `Page ${pageNum}`;
        
        console.log(`  Processing ${sheetNumber}...`);
        
        // First try text-based extraction (fast, low cost)
        const textDimensions = extractDimensionsFromText(chunk.content, sheetNumber);
        console.log(`    Found ${textDimensions.length} dimensions via text extraction`);
        
        // Add to collection
        if (textDimensions.length > 0) {
          allDimensions.push(...textDimensions);
          totalDimensions += textDimensions.length;
        }
      } catch (chunkError) {
        console.error(`Error processing chunk ${chunk.id}:`, chunkError);
        // Continue with next chunk
      }
    }
    
    // Store all dimensions for the document
    if (allDimensions.length > 0 && document.projectId) {
      const metadata = document.chunks[0]?.metadata as any;
      const sheetNumber = metadata?.sheet_number || 'Unknown';
      
      // Create minimal validation object
      const validation = {
        chainValidations: [],
        isolatedDimensions: allDimensions,
        overallHealth: 0.8,
      };
      
      await storeDimensions(document.projectId, documentId, sheetNumber, allDimensions, validation);
    }
    
    console.log(`\\n✅ Extracted ${totalDimensions} total dimensions`);
    return totalDimensions;
  } catch (error) {
    console.error('Error extracting dimensions:', error);
    return 0;
  }
}

/**
 * Main processing function
 * Accepts command line arguments: <pdfPath> <documentId>
 * If no arguments provided, defaults to processing Plans.pdf
 */
async function processPlansWithVision() {
  // Check for command line arguments
  const args = process.argv.slice(2);
  
  // Check for --haiku flag to use Claude 3.5 Haiku instead of GPT-5.2
  const useHaiku = args.includes('--haiku');
  const model = useHaiku ? 'claude-3-5-haiku-20241022' : 'gpt-5.2';
  
  // Filter out flag from args
  const filteredArgs = args.filter(arg => arg !== '--haiku');
  
  let pdfPath: string;
  let documentId: string;
  
  if (filteredArgs.length >= 2) {
    // Process specific document passed as argument (for uploads)
    pdfPath = filteredArgs[0];
    documentId = filteredArgs[1];
    
    console.log('🔍 Starting vision-based document processing...');
    console.log(`📄 Processing document ID: ${documentId}`);
    console.log(`📁 File path: ${pdfPath}`);
    console.log(`🤖 Using model: ${model}${useHaiku ? ' (Claude 3.5 Haiku - 90% cost savings)' : ' (GPT-4o)'}`);
    console.log('');
    
    if (!fs.existsSync(pdfPath)) {
      console.error(`❌ PDF file not found at: ${pdfPath}`);
      process.exit(1);
    }
    
    // Verify document exists in database
    const document = await prisma.document.findUnique({
      where: { id: documentId },
    });
    
    if (!document) {
      console.error(`❌ Document ID ${documentId} not found in database`);
      process.exit(1);
    }
  } else {
    // Legacy mode: process Plans.pdf from public directory
    console.log('🔍 Starting vision-based Plans.pdf processing (legacy mode)...');
    console.log('');
    
    const plansDoc = await prisma.document.findFirst({
      where: { name: 'Plans.pdf' },
    });
    
    if (!plansDoc) {
      console.error('❌ Plans.pdf not found in database');
      process.exit(1);
    }
    
    documentId = plansDoc.id;
    pdfPath = path.join(process.cwd(), 'public', plansDoc.filePath || 'documents/Plans.pdf');
    
    console.log(`📄 Found Plans.pdf (ID: ${plansDoc.id})`);
    
    if (!fs.existsSync(pdfPath)) {
      console.error(`❌ PDF file not found at: ${pdfPath}`);
      process.exit(1);
    }
  }
  
  // Get PDF page count
  const pdfBytes = fs.readFileSync(pdfPath);
  const pdfDoc = await PDFDocument.load(pdfBytes);
  const totalPages = pdfDoc.getPageCount();
  
  console.log(`📊 Total pages to process: ${totalPages}`);
  console.log('');
  
  // Create temp directory for images
  const tempDir = path.join(process.cwd(), '.temp-vision');
  if (!fs.existsSync(tempDir)) {
    fs.mkdirSync(tempDir);
  }
  
  // Delete existing chunks for this document
  console.log('🗑️  Deleting existing document chunks...');
  const deleted = await prisma.documentChunk.deleteMany({
    where: { documentId: documentId },
  });
  console.log(`✅ Deleted ${deleted.count} existing chunks`);
  console.log('');
  
  // Process each page
  const newChunks = [];
  
  for (let pageNum = 1; pageNum <= totalPages; pageNum++) {
    console.log(`📄 Processing page ${pageNum}/${totalPages}...`);
    
    try {
      // Convert page to image
      console.log('  🖼️  Converting to image...');
      const imageData = await convertPdfPageToImage(pdfPath, pageNum, tempDir);
      
      // Analyze with vision
      console.log(`  👁️  Analyzing with ${useHaiku ? 'Claude 3.5 Haiku' : 'GPT-4o'} vision...`);
      const analysis = await analyzePlanPage(imageData, pageNum, documentId, model);
      
      // Create multiple chunks per page
      const pageChunks = [];
      let chunkIndexOffset = 0;
      
      // 1. Always create base page overview chunk
      const baseChunkContent = createEnrichedChunk(analysis, pageNum);
      const baseChunk = await prisma.documentChunk.create({
        data: {
          content: baseChunkContent,
          documentId: documentId,
          chunkIndex: (pageNum - 1) * 100 + chunkIndexOffset++, // Use 100x multiplier for page spacing
          metadata: {
            page: pageNum,
            chunkType: 'page_overview',
            sheetNumber: analysis.sheetNumber,
            scale: analysis.scale,
            hasScale: !!analysis.scale,
            hasDimensions: analysis.labeledDimensions.length > 0 || analysis.derivedDimensions.length > 0,
            labeledDimensionsCount: analysis.labeledDimensions.length,
            derivedDimensionsCount: analysis.derivedDimensions.length,
            elementsCount: analysis.spatialElements.length,
            notesCount: analysis.notes.length,
            hasLegend: !!(analysis.legend && analysis.legend.length > 0),
            legendEntriesCount: analysis.legend?.length || 0,
            hasHatchPatterns: !!(analysis.hatchPatterns && analysis.hatchPatterns.length > 0),
            hatchPatternsCount: analysis.hatchPatterns?.length || 0,
            hasTitleBlock: !!(analysis.titleBlock && Object.keys(analysis.titleBlock).some(key => analysis.titleBlock![key as keyof typeof analysis.titleBlock])),
            projectName: analysis.titleBlock?.projectName,
            architect: analysis.titleBlock?.architect,
            engineer: analysis.titleBlock?.engineer,
            issueDate: analysis.titleBlock?.issueDate,
            hasZones: !!(analysis.zones && analysis.zones.length > 0),
            zonesCount: analysis.zones?.length || 0,
            zoneNames: analysis.zones?.map((z: any) => z.name) || [],
            source: 'vision-analysis-multi-chunk',
          },
        },
      });
      pageChunks.push(baseChunk);
      
      // 2. Create detail callout chunks
      if (analysis.detailCallouts && analysis.detailCallouts.length > 0) {
        console.log(`  📐 Creating ${analysis.detailCallouts.length} detail chunks...`);
        for (let i = 0; i < analysis.detailCallouts.length; i++) {
          const detail = analysis.detailCallouts[i];
          const detailContent = createDetailChunk(analysis, pageNum, detail, i);
          const detailChunk = await prisma.documentChunk.create({
            data: {
              content: detailContent,
              documentId: documentId,
              chunkIndex: (pageNum - 1) * 100 + chunkIndexOffset++,
              metadata: {
                page: pageNum,
                chunkType: 'detail_callout',
                detailMarker: detail.marker,
                detailType: detail.type,
                referenceSheet: detail.referenceSheet,
                sheetNumber: analysis.sheetNumber,
                source: 'vision-analysis-multi-chunk',
              },
            },
          });
          pageChunks.push(detailChunk);
        }
      }
      
      // 3. Create zone/area chunks
      if (analysis.zones && analysis.zones.length > 0) {
        console.log(`  🏗️  Creating ${analysis.zones.length} zone chunks...`);
        for (let i = 0; i < analysis.zones.length; i++) {
          const zone = analysis.zones[i];
          const zoneContent = createZoneChunk(analysis, pageNum, zone, i);
          const zoneChunk = await prisma.documentChunk.create({
            data: {
              content: zoneContent,
              documentId: documentId,
              chunkIndex: (pageNum - 1) * 100 + chunkIndexOffset++,
              metadata: {
                page: pageNum,
                chunkType: 'zone_area',
                zoneName: zone.name,
                hasQuantities: !!(zone.quantities && zone.quantities.length > 0),
                quantitiesCount: zone.quantities?.length || 0,
                hasDimensions: !!(zone.dimensions && zone.dimensions.length > 0),
                dimensionsCount: zone.dimensions?.length || 0,
                sheetNumber: analysis.sheetNumber,
                source: 'vision-analysis-multi-chunk',
              },
            },
          });
          pageChunks.push(zoneChunk);
        }
      }
      
      // 4. Create room/space chunks
      if (analysis.roomNumbers && analysis.roomNumbers.length > 0) {
        console.log(`  🚪 Creating ${analysis.roomNumbers.length} room chunks...`);
        for (let i = 0; i < analysis.roomNumbers.length; i++) {
          const room = analysis.roomNumbers[i];
          const roomContent = createRoomChunk(analysis, pageNum, room, i);
          const roomChunk = await prisma.documentChunk.create({
            data: {
              content: roomContent,
              documentId: documentId,
              chunkIndex: (pageNum - 1) * 100 + chunkIndexOffset++,
              metadata: {
                page: pageNum,
                chunkType: 'room_space',
                roomNumber: room.number,
                roomName: room.name,
                roomArea: room.area,
                sheetNumber: analysis.sheetNumber,
                source: 'vision-analysis-multi-chunk',
              },
            },
          });
          pageChunks.push(roomChunk);
        }
      }
      
      newChunks.push(...pageChunks);
      
      console.log(`  ✅ Page ${pageNum} processed - Created ${pageChunks.length} chunks:`);
      if (analysis.sheetNumber) console.log(`     Sheet: ${analysis.sheetNumber}`);
      if (analysis.scale) console.log(`     Scale: ${analysis.scale}`);
      console.log(`     Labeled dimensions: ${analysis.labeledDimensions.length}`);
      console.log(`     Derived dimensions: ${analysis.derivedDimensions.length}`);
      console.log(`     Elements: ${analysis.spatialElements.length}`);
      console.log(`     Notes: ${analysis.notes.length}`);
      if (analysis.detailCallouts && analysis.detailCallouts.length > 0) {
        console.log(`     Detail callouts: ${analysis.detailCallouts.length}`);
      }
      if (analysis.zones && analysis.zones.length > 0) {
        console.log(`     Zones/Areas: ${analysis.zones.length}`);
      }
      if (analysis.roomNumbers && analysis.roomNumbers.length > 0) {
        console.log(`     Rooms: ${analysis.roomNumbers.length}`);
      }
      if (analysis.legend) console.log(`     Legend entries: ${analysis.legend.length}`);
      if (analysis.hatchPatterns) console.log(`     Hatch patterns: ${analysis.hatchPatterns.length}`);
      if (analysis.titleBlock?.projectName) console.log(`     Project: ${analysis.titleBlock.projectName}`);
      console.log('');
      
      // Rate limiting - wait 2 seconds between pages to avoid API throttling
      if (pageNum < totalPages) {
        await new Promise(resolve => setTimeout(resolve, 2000));
      }
    } catch (error) {
      console.error(`  ❌ Error processing page ${pageNum}:`, error);
      console.log('');
    }
  }
  
  // Extract title blocks and legends after all pages processed
  console.log('');
  console.log('🔍 Extracting title blocks and legends...');
  console.log('');
  
  try {
    // Extract title blocks from all pages
    console.log('📋 Extracting title blocks...');
    const titleBlocksExtracted = await extractTitleBlocksFromDocument(pdfPath, documentId);
    console.log(`✅ Extracted ${titleBlocksExtracted} title blocks`);
    
    // Extract legends from all pages
    console.log('🗺️  Extracting legends...');
    const legendsExtracted = await extractLegendsFromDocument(pdfPath, documentId);
    console.log(`✅ Extracted ${legendsExtracted} legends`);
    console.log('');
    
    // Extract dimensions from all pages (Phase B.2)
    console.log('📏 Extracting dimensions...');
    const dimensionsExtracted = await extractDimensionsFromDocument(documentId);
    console.log(`✅ Extracted ${dimensionsExtracted} dimensions`);
    console.log('');
  } catch (error) {
    console.error('⚠️  Error during title block/legend/dimension extraction:', error);
    console.log('Continuing with processing...');
    console.log('');
  }
  
  // Clean up temp directory
  fs.rmSync(tempDir, { recursive: true, force: true });
  
  console.log('');
  console.log('✅ Processing complete!');
  console.log(`📊 Created ${newChunks.length} total chunks with multi-chunk strategy`);
  console.log('');
  console.log('Chunk Breakdown:');
  const pageOverviews = newChunks.filter(c => (c.metadata as any).chunkType === 'page_overview').length;
  const detailChunks = newChunks.filter(c => (c.metadata as any).chunkType === 'detail_callout').length;
  const zoneChunks = newChunks.filter(c => (c.metadata as any).chunkType === 'zone_area').length;
  const roomChunks = newChunks.filter(c => (c.metadata as any).chunkType === 'room_space').length;
  
  console.log(`  📄 Page Overviews: ${pageOverviews}`);
  console.log(`  📐 Detail Callouts: ${detailChunks}`);
  console.log(`  🏗️  Zones/Areas: ${zoneChunks}`);
  console.log(`  🚪 Rooms/Spaces: ${roomChunks}`);
  console.log('');
  console.log('Enhanced Retrieval:');
  const withScale = newChunks.filter(c => (c.metadata as any).hasScale).length;
  const withDimensions = newChunks.filter(c => (c.metadata as any).hasDimensions).length;
  console.log(`  - Chunks with scale information: ${withScale}`);
  console.log(`  - Chunks with dimensions: ${withDimensions}`);
  console.log('');
  console.log('✅ Benefits of Multi-Chunk Strategy:');
  console.log('   • More precise retrieval for detail-specific questions');
  console.log('   • Zone/area-focused queries return only relevant data');
  console.log('   • Reduced noise in RAG context');
  console.log('   • Better accuracy for room-specific questions');
}

// Run the processor
processPlansWithVision()
  .catch((error) => {
    console.error('Fatal error:', error);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });