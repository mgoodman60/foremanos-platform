          {"title": "Submittals", "content": "content text"}
        ]
      }
    ],
    "submittals": ["Submit product data for...", "Submit shop drawings for..."],
    "qualityAssurance": ["ACI 301 compliance", "UL listed"],
    "testing": ["Slump test: 1 per 100 CY", "Compressive strength tests"],
    "warranties": ["5-year manufacturer warranty", "2-year installation"],
    "productReferences": ["ABC Corp Model 123 or equal", "XYZ Product per ASTM C150"],
    "substitutionRules": ["Submit 30 days prior", "Equal or better performance required"]
  "materialQuantities": [
