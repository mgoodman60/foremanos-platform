import { PrismaClient } from '@prisma/client';
import * as dotenv from 'dotenv';

dotenv.config();

const prisma = new PrismaClient();

async function main() {
  console.log('Starting access level migration...');

  // Migrate "internal" to "client"
  const internalDocs = await prisma.document.updateMany({
    where: { accessLevel: 'internal' },
    data: { accessLevel: 'client' },
  });
  console.log(`Migrated ${internalDocs.count} documents from "internal" to "client"`);

  // Migrate "external" to "guest"
  const externalDocs = await prisma.document.updateMany({
    where: { accessLevel: 'external' },
    data: { accessLevel: 'guest' },
  });
  console.log(`Migrated ${externalDocs.count} documents from "external" to "guest"`);

  // Migrate "both" to "guest" (accessible to everyone)
  const bothDocs = await prisma.document.updateMany({
    where: { accessLevel: 'both' },
    data: { accessLevel: 'guest' },
  });
  console.log(`Migrated ${bothDocs.count} documents from "both" to "guest"`);

  // Count remaining documents
  const adminDocs = await prisma.document.count({
    where: { accessLevel: 'admin' },
  });
  const clientDocs = await prisma.document.count({
    where: { accessLevel: 'client' },
  });
  const guestDocs = await prisma.document.count({
    where: { accessLevel: 'guest' },
  });

  console.log('\nFinal document counts:');
  console.log(`- Admin only: ${adminDocs}`);
  console.log(`- Client accessible: ${clientDocs}`);
  console.log(`- Guest accessible: ${guestDocs}`);
  console.log('\nMigration complete!');
}

main()
  .catch((e) => {
    console.error('Migration failed:', e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });
