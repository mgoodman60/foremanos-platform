/**
 * Test with a real document page to verify the system works end-to-end
 */

import { analyzeWithMultiProvider } from '../lib/vision-api-multi-provider';
import { PrismaClient } from '@prisma/client';
import { getFileUrl } from '../lib/s3';
import fs from 'fs';
import path from 'path';

const prisma = new PrismaClient();

async function testWithRealDocument() {
  console.log('======================================');
  console.log('Real Document Processing Test');
  console.log('======================================');
  console.log('');
  
  try {
    // Find Plans.pdf
    console.log('Looking for Plans.pdf...');
    const document = await prisma.document.findFirst({
      where: {
        name: {
          contains: 'Plans',
        },
        fileType: 'application/pdf',
      },
    });
    
    if (!document) {
      console.log('❌ Plans.pdf not found in database');
      return;
    }
    
    console.log(`✅ Found document: ${document.name}`);
    console.log(`   File type: ${document.fileType}`);
    console.log(`   S3 Path: ${document.cloud_storage_path}`);
    console.log('');
    
    // Find a chunk that was successfully processed
    const chunk = await prisma.documentChunk.findFirst({
      where: {
        documentId: document.id,
        content: {
          not: '',
        },
      },
      orderBy: {
        pageNumber: 'asc',
      },
    });
    
    if (!chunk) {
      console.log('❌ No processed chunks found');
      return;
    }
    
    console.log(`Using existing chunk from page ${chunk.pageNumber}`);
    console.log(`Content length: ${chunk.content.length} chars`);
    console.log('');
    
    // Create a simple prompt
    const prompt = `Extract and analyze this construction plan page. Provide:
1. Sheet number and title
2. Drawing type (floor plan, elevation, section, etc.)
3. Scale information
4. Key elements visible
5. Any annotations or callouts

Be concise and structured.`;
    
    console.log('Testing multi-provider system with real document...');
    console.log('');
    
    const startTime = Date.now();
    
    // Use a sample base64 image for testing (we'd need the actual PDF->image conversion here)
    // For now, let's just verify the provider chain works
    console.log('⚠️  Note: Using test image since PDF->image conversion requires additional setup');
    console.log('         The provider chain logic is what we\'re testing here');
    console.log('');
    
    const testImage = Buffer.from([
      0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
      0x00, 0x00, 0x00, 0x0D, 0x49, 0x48, 0x44, 0x52,
      0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
      0x08, 0x06, 0x00, 0x00, 0x00, 0x1F, 0x15, 0xC4,
      0x89, 0x00, 0x00, 0x00, 0x0A, 0x49, 0x44, 0x41,
      0x54, 0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00,
      0x05, 0x00, 0x01, 0x0D, 0x0A, 0x2D, 0xB4, 0x00,
      0x00, 0x00, 0x00, 0x49, 0x45, 0x4E, 0x44, 0xAE,
    ]).toString('base64');
    
    const result = await analyzeWithMultiProvider(testImage, prompt);
    
    const durationSec = (Date.now() - startTime) / 1000;
    
    console.log('');
    console.log('======================================');
    console.log('Test Results');
    console.log('======================================');
    console.log('');
    console.log(`⏱️  Duration: ${durationSec.toFixed(1)}s`);
    console.log(`🔄 Provider: ${result.provider}`);
    console.log(`🎯 Attempts: ${result.attempts}`);
    console.log(`📊 Content: ${result.content?.length || 0} chars`);
    console.log('');
    
    if (result.success && result.content) {
      console.log('✅ SUCCESS: Multi-provider system is working!');
      console.log('');
      console.log('Response preview:');
      console.log(result.content.substring(0, 200) + '...');
    } else {
      console.log('❌ FAILED: No response generated');
      if (result.error) {
        console.log(`   Error: ${result.error}`);
      }
    }
    
  } catch (error: any) {
    console.error('');
    console.error('❌ Test error:', error.message);
  } finally {
    await prisma.$disconnect();
  }
}

testWithRealDocument()
  .then(() => {
    console.log('');
    console.log('Test complete');
    process.exit(0);
  })
  .catch((error) => {
    console.error('Fatal error:', error);
    process.exit(1);
  });
