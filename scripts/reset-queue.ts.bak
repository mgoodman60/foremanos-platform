import { prisma } from '../lib/db';

async function resetQueue() {
  const documentId = 'cmk633er50001n508fpe1licm';
  
  console.log('Resetting queue for document:', documentId);
  
  // Delete queue entries
  const deleted = await prisma.processingQueue.deleteMany({
    where: { documentId },
  });
  
  console.log(`Deleted ${deleted.count} queue entries`);
  
  // Delete existing chunks
  const deletedChunks = await prisma.documentChunk.deleteMany({
    where: { documentId },
  });
  
  console.log(`Deleted ${deletedChunks.count} chunks`);
  
  // Reset document
  await prisma.document.update({
    where: { id: documentId },
    data: {
      processed: false,
      pagesProcessed: 0,
    },
  });
  
  console.log('✅ Queue reset complete');
}

resetQueue()
  .then(() => process.exit(0))
  .catch(console.error)
  .finally(() => prisma.$disconnect());
