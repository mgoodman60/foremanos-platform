/**
 * Test Provider Connectivity
 * 
 * Verifies that all configured vision API providers are accessible
 */

import fs from 'fs';

function getApiSecrets(): {
  anthropic: string | null;
  gemini: string | null;
  openai: string | null;
  abacus: string | undefined;
} {
  try {
    const secretsPath = '/home/ubuntu/.config/abacusai_auth_secrets.json';
    if (!fs.existsSync(secretsPath)) {
      console.error('❌ API secrets file not found');
      return {
        anthropic: null,
        gemini: null,
        openai: null,
        abacus: process.env.ABACUSAI_API_KEY,
      };
    }
    const secretsData = JSON.parse(fs.readFileSync(secretsPath, 'utf-8'));
    
    // Handle API key mapping (check both slots for each provider)
    const anthropicKey = secretsData?.anthropic?.secrets?.api_key?.value;
    const geminiKeySlot1 = secretsData?.['google gemini']?.secrets?.api_key?.value;
    const geminiKeySlot2 = secretsData?.['Google Gemini']?.secrets?.api_key?.value;
    const openaiKey = secretsData?.openai?.secrets?.api_key?.value;
    
    // Detect which key is which based on prefix
    let anthropicActual: string | null = null;
    let geminiActual: string | null = null;
    
    // Check if anthropic slot has actual Anthropic key (sk-ant-) or Gemini key (AIzaSy)
    if (anthropicKey) {
      if (anthropicKey.startsWith('sk-ant-')) {
        anthropicActual = anthropicKey;
      } else if (anthropicKey.startsWith('AIzaSy')) {
        geminiActual = anthropicKey; // Gemini key was stored in Anthropic slot
        console.log('  ℹ️  Note: Found Gemini key in Anthropic slot');
      }
    }
    
    // Check Gemini slots
    if (!geminiActual) {
      geminiActual = geminiKeySlot1 || geminiKeySlot2 || null;
    }
    
    return {
      anthropic: anthropicActual,
      gemini: geminiActual,
      openai: openaiKey || null,
      abacus: process.env.ABACUSAI_API_KEY,
    };
  } catch (error) {
    console.error('❌ Error loading API secrets:', error);
    return {
      anthropic: null,
      gemini: null,
      openai: null,
      abacus: process.env.ABACUSAI_API_KEY,
    };
  }
}

async function testProvider(name: string, testFn: () => Promise<boolean>): Promise<boolean> {
  try {
    console.log(`\nTesting ${name}...`);
    const result = await testFn();
    if (result) {
      console.log(`✅ ${name} - Connected successfully`);
    } else {
      console.log(`❌ ${name} - Connection failed`);
    }
    return result;
  } catch (error: any) {
    console.log(`❌ ${name} - Error: ${error.message}`);
    return false;
  }
}

async function testAbacusAI(apiKey: string): Promise<boolean> {
  if (!apiKey) {
    console.log('  ⚠️  API key not configured');
    return false;
  }

  const response = await fetch('https://apis.abacus.ai/v1/models', {
    method: 'GET',
    headers: {
      Authorization: `Bearer ${apiKey}`,
    },
  });

  console.log(`  Status: ${response.status}`);
  return response.ok;
}

async function testAnthropic(apiKey: string): Promise<boolean> {
  if (!apiKey) {
    console.log('  ⚠️  API key not configured');
    return false;
  }

  // Just test with a simple messages endpoint
  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': apiKey,
      'anthropic-version': '2023-06-01',
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514', // Claude Sonnet 4.5
      max_tokens: 10,
      messages: [{ role: 'user', content: 'Hi' }],
    }),
  });

  console.log(`  Status: ${response.status}`);
  
  // 200 = success, 401 = auth error, 400 = valid request but may need adjustment
  return response.ok || response.status === 400;
}

async function testGemini(apiKey: string): Promise<boolean> {
  if (!apiKey) {
    console.log('  ⚠️  API key not configured');
    return false;
  }

  const response = await fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent?key=${apiKey}`,
    {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        contents: [{ parts: [{ text: 'Hi' }] }],
      }),
    }
  );

  console.log(`  Status: ${response.status}`);
  return response.ok;
}

async function testOpenAI(apiKey: string): Promise<boolean> {
  if (!apiKey) {
    console.log('  ⚠️  API key not configured');
    return false;
  }

  const response = await fetch('https://api.openai.com/v1/models', {
    method: 'GET',
    headers: {
      Authorization: `Bearer ${apiKey}`,
    },
  });

  console.log(`  Status: ${response.status}`);
  return response.ok;
}

async function main() {
  console.log('\n======================================');
  console.log('Vision API Provider Connectivity Test');
  console.log('======================================');

  const secrets = getApiSecrets();
  const results: Record<string, boolean> = {};

  results['Abacus AI (GPT-5.2)'] = await testProvider(
    'Abacus AI (GPT-5.2)',
    () => testAbacusAI(secrets.abacus || '')
  );

  results['Anthropic (Claude Sonnet 4.5)'] = await testProvider(
    'Anthropic (Claude Sonnet 4.5)',
    () => testAnthropic(secrets.anthropic || '')
  );

  results['Google (Gemini Vision Pro)'] = await testProvider(
    'Google (Gemini Vision Pro)',
    () => testGemini(secrets.gemini || '')
  );

  results['OpenAI (GPT-4 Vision)'] = await testProvider(
    'OpenAI (GPT-4 Vision)',
    () => testOpenAI(secrets.openai || '')
  );

  console.log('\n======================================');
  console.log('Summary');
  console.log('======================================\n');

  const successCount = Object.values(results).filter(r => r).length;
  const totalCount = Object.keys(results).length;

  Object.entries(results).forEach(([name, success]) => {
    console.log(`${success ? '✅' : '❌'} ${name}`);
  });

  console.log(`\n${successCount}/${totalCount} providers connected successfully\n`);

  if (successCount === 0) {
    console.error('⚠️  No providers are accessible! Check API keys.');
    process.exit(1);
  } else if (successCount < totalCount) {
    console.warn(`⚠️  ${totalCount - successCount} provider(s) failed connectivity test`);
  } else {
    console.log('🎉 All providers connected successfully!');
  }

  console.log('\n✅ Connectivity test complete\n');
}

main();
