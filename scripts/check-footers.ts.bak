import { PrismaClient } from '@prisma/client';
import dotenv from 'dotenv';

dotenv.config();

const prisma = new PrismaClient();

async function checkFooters() {
  try {
    // Find chunks related to footers/footings
    const chunks = await prisma.documentChunk.findMany({
      where: {
        OR: [
          { content: { contains: 'footer', mode: 'insensitive' } },
          { content: { contains: 'footing', mode: 'insensitive' } },
          { content: { contains: 'foundation', mode: 'insensitive' } }
        ]
      },
      include: {
        Document: {
          select: {
            name: true
          }
        }
      },
      take: 20  // Limit to first 20 results
    });

    console.log(`Found ${chunks.length} chunks related to footers/footings/foundations:\n`);

    for (const chunk of chunks) {
      // Parse metadata if it exists
      const metadata = chunk.metadata as any;
      const sheetNumber = metadata?.sheet_number || 'N/A';
      
      // Only show chunks that might be from foundation plans
      if (sheetNumber.includes('S-') || sheetNumber.includes('S0') || 
          chunk.content.toLowerCase().includes('perimeter') ||
          chunk.content.toLowerCase().includes('interior')) {
        console.log('='.repeat(80));
        console.log(`Document: ${chunk.document?.name}`);
        console.log(`Page: ${chunk.pageNumber || 'N/A'}`);
        console.log(`Sheet: ${sheetNumber}`);
        
        if (metadata) {
          console.log(`Scale: ${metadata.scale || 'N/A'}`);
          if (metadata.labeled_dimensions) {
            console.log(`\nLabeled Dimensions:`);
            console.log(JSON.stringify(metadata.labeled_dimensions, null, 2));
          }
          if (metadata.elements) {
            console.log(`\nElements:`);
            console.log(JSON.stringify(metadata.elements, null, 2));
          }
          if (metadata.notes) {
            console.log(`\nNotes:`);
            console.log(JSON.stringify(metadata.notes, null, 2));
          }
        }
        
        console.log(`\nContent preview (first 600 chars):`);
        console.log(chunk.content.substring(0, 600));
        console.log('\n');
      }
    }

  } catch (error) {
    console.error('Error checking footers:', error);
  } finally {
    await prisma.$disconnect();
  }
}

checkFooters();
