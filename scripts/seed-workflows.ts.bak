/**
 * Seed Unified Daily Report Workflow
 * Creates one comprehensive daily report covering all trades
 */

import { prisma } from '../lib/db';
import { ProjectType, TradeType } from '@prisma/client';
import { createWorkflowTemplate, WorkflowTemplateData } from '../lib/workflow-service';

// Unified Daily Report Workflow (covers all trades)
const unifiedDailyReport: WorkflowTemplateData = {
  name: 'Daily Construction Report',
  description: 'Comprehensive daily report covering all site activities and trades',
  projectType: ProjectType.new_construction,
  tradeType: TradeType.general_contractor,
  steps: [
    {
      question: 'Which subcontractors were on site today?',
      helpText: 'Select all companies that worked on site (add subcontractors in Project Settings if not listed)',
      order: 1,
      stepType: 'multiselect',
      options: [], // Will be populated dynamically from project's subcontractors
      isRequired: true
    },
    {
      question: 'Total crew count on site today?',
      helpText: 'Include all workers from all trades',
      order: 2,
      stepType: 'number',
      isRequired: true
    },
    {
      question: 'Describe work completed by each trade today',
      helpText: 'Provide details about what was accomplished',
      order: 3,
      stepType: 'text',
      isRequired: true
    },
    {
      question: 'Upload photos from today',
      helpText: 'Select photos to include in the daily report (optional)',
      order: 4,
      stepType: 'photo',
      isRequired: false
    },
    {
      question: 'Were there any delays or issues today?',
      helpText: '',
      order: 5,
      stepType: 'yes_no',
      isRequired: true
    },
    {
      question: 'What caused the delay/issue?',
      helpText: 'Describe the cause and impact',
      order: 6,
      stepType: 'text',
      isRequired: true,
      conditionalOn: undefined, // Will be set after step creation
      conditionalValue: 'Yes'
    },
    {
      question: 'Were any inspections conducted today?',
      helpText: '',
      order: 7,
      stepType: 'yes_no',
      isRequired: true
    },
    {
      question: 'Inspection results',
      helpText: 'What was inspected and what were the results?',
      order: 8,
      stepType: 'select',
      options: ['Passed', 'Failed - Corrections needed', 'Pending'],
      isRequired: true,
      conditionalOn: undefined,
      conditionalValue: 'Yes'
    },
    {
      question: 'What corrections are needed?',
      helpText: 'List any deficiencies that need to be addressed',
      order: 9,
      stepType: 'text',
      isRequired: false,
      conditionalOn: undefined,
      conditionalValue: 'Failed - Corrections needed'
    },
    {
      question: 'Materials delivered today',
      helpText: 'List major materials received (optional)',
      order: 10,
      stepType: 'text',
      isRequired: false
    },
    {
      question: 'Materials used/installed today',
      helpText: 'Describe key materials installed or consumed (optional)',
      order: 11,
      stepType: 'text',
      isRequired: false
    },
    {
      question: 'Equipment on site today',
      helpText: 'List major equipment in use (optional)',
      order: 12,
      stepType: 'text',
      isRequired: false
    }
  ]
};

async function seedWorkflows() {
  console.log('[SEED] Starting workflow template seeding...');

  try {
    // Delete existing workflows (for clean re-seed)
    await prisma.workflowResponse.deleteMany({});
    await prisma.workflowStep.deleteMany({});
    await prisma.workflowTemplate.deleteMany({});
    console.log('[SEED] Cleared existing workflow data');

    // Create the unified workflow
    console.log('[SEED] Creating Unified Daily Report workflow...');
    const workflow = await createWorkflowTemplate(unifiedDailyReport);
    
    if (!workflow) {
      throw new Error('Failed to create workflow template');
    }

    console.log('[SEED] ✓ Successfully seeded unified daily report workflow!');
    console.log('[SEED] - Daily Construction Report (12 questions including photo intake)');
  } catch (error) {
    console.error('[SEED] Error seeding workflows:', error);
    throw error;
  } finally {
    await prisma.$disconnect();
  }
}

seedWorkflows();
