#!/usr/bin/env node
/**
 * OneDrive Sync and Document Processing Script
 * Syncs documents from OneDrive and processes them for RAG
 */

import 'dotenv/config';
import { PrismaClient } from '@prisma/client';
// import { getOneDriveService } from '../lib/onedrive-service'; // Deprecated: Use API endpoints instead
import * as fs from 'fs';
import * as path from 'path';
const { PDFParse: pdfParse } = require('pdf-parse');

const prisma = new PrismaClient();

// Document summaries for new files
const DOCUMENT_SUMMARIES: Record<string, string> = {
  'Budget.pdf': `Project Budget Document

Contains:
- Overall project cost breakdown and line items
- Material and labor cost estimates  
- Budget allocations by construction phase
- Contingency funds and allowances
- Payment schedule and financial milestones

For specific budget questions, users can upload screenshots of relevant sections for detailed analysis.`,

  'Critical Path Plan.docx': `Critical Path Method (CPM) Schedule

Includes:
- Critical path activities that drive project timeline
- Task dependencies and sequencing
- Activity durations and float times
- Resource allocation requirements
- Milestone dates and deadlines

Refer to this document for detailed schedule analysis.`,

  'Project Overview.docx': `Comprehensive Project Overview

Covers:
- Project scope, objectives, and deliverables
- Site location and description
- Key stakeholders and contacts
- Overall timeline and phases
- Success criteria and requirements

Review for high-level project information.`,

  'Geotech.pdf': `Geotechnical Engineering Report

Provides:
- Soil composition and bearing capacity
- Groundwater conditions and drainage
- Foundation design recommendations
- Seismic and geological considerations
- Test boring locations and results
- Site preparation requirements

Upload specific pages for detailed geotechnical questions.`,

  'Plans.pdf': `Construction Plans and Drawings

Includes:
- Architectural floor plans and elevations
- Structural details and specifications
- Site plans and grading
- MEP (Mechanical, Electrical, Plumbing) layouts
- Detail sheets and sections
- Material specifications

Upload specific plan sheets for installation guidance or verification.`,

  'Schedule.pdf': `Project Construction Schedule

Details:
- Phase-by-phase timeline
- Key milestones and completion dates
- Activity durations and sequences
- Critical deadlines
- Resource scheduling
- Weather and delay contingencies

Consult for project timing and sequencing questions.`,

  'Site Survey.pdf': `Topographic Site Survey

Contains:
- Survey control points and benchmarks
- Topographic elevations and contours
- Property boundaries and easements
- Existing utilities and infrastructure
- Site features and constraints
- Drainage patterns

Upload survey pages for specific site condition analysis.`,
};

interface TextChunk {
  content: string;
  pageNumber?: number;
}

function chunkText(text: string, chunkSize: number = 1000): string[] {
  const chunks: string[] = [];
  const sentences = text.split(/(?<=[.!?])\s+/);
  let currentChunk = '';

  for (const sentence of sentences) {
    if ((currentChunk + sentence).length > chunkSize && currentChunk.length > 0) {
      chunks.push(currentChunk.trim());
      currentChunk = sentence;
    } else {
      currentChunk += (currentChunk ? ' ' : '') + sentence;
    }
  }

  if (currentChunk.trim()) {
    chunks.push(currentChunk.trim());
  }

  return chunks;
}

/**
 * Extract text from PDF with page tracking
 */
async function extractPdfTextWithPages(filePath: string): Promise<TextChunk[]> {
  try {
    const dataBuffer = fs.readFileSync(filePath);
    const parser = new pdfParse({ data: dataBuffer });
    const result = await parser.getText();
    
    const chunks: TextChunk[] = [];
    const fullText = result.text;
    const totalPages = result.total || result.pages.length;
    
    if (!fullText || fullText.trim().length === 0) {
      console.log(`  No extractable text found in PDF`);
      return [];
    }
    
    // Estimate text per page (rough approximation)
    const avgTextPerPage = fullText.length / totalPages;
    
    // Create chunks with page estimates
    const textChunks = chunkText(fullText, 1500); // Larger chunks for PDF content
    
    let currentPosition = 0;
    textChunks.forEach((chunk) => {
      // Estimate page number based on current position in text
      const estimatedPage = Math.max(1, Math.min(
        totalPages,
        Math.ceil((currentPosition + 1) / avgTextPerPage)
      ));
      
      chunks.push({
        content: chunk,
        pageNumber: estimatedPage,
      });
      
      // Update position by actual chunk length
      currentPosition += chunk.length;
    });

    return chunks;
  } catch (error) {
    console.error('Error extracting PDF text:', error);
    return [];
  }
}

/**
 * Check if file is a PDF
 */
function isPdfFile(fileName: string): boolean {
  return fileName.toLowerCase().endsWith('.pdf');
}

async function processDocument(document: any) {
  try {
    console.log(`  Processing document for RAG: ${document.name}`);

    // Delete existing chunks
    await prisma.documentChunk.deleteMany({
      where: { documentId: document.id },
    });

    let chunks: TextChunk[] = [];

    // Check if PDF file exists and extract text with page numbers
    if (isPdfFile(document.fileName) && document.filePath) {
      const fullPath = path.join(process.cwd(), 'public', document.filePath.replace(/^\//, ''));
      
      if (fs.existsSync(fullPath)) {
        console.log(`  📄 Extracting text from PDF with page tracking...`);
        chunks = await extractPdfTextWithPages(fullPath);
        
        if (chunks.length > 0) {
          console.log(`  ✓ Extracted ${chunks.length} chunks from PDF`);
        } else {
          console.log(`  ⚠️  PDF extraction failed, using summary fallback`);
        }
      }
    }

    // Fallback to summary if no PDF content extracted
    if (chunks.length === 0) {
      console.log(`  Using document summary for chunking`);
      const summary = DOCUMENT_SUMMARIES[document.fileName] || 
        `Document: ${document.name}\n\nThis document contains project information. Upload specific pages or sections for detailed analysis.`;
      
      const textChunks = chunkText(summary);
      chunks = textChunks.map(content => ({ content }));
    }

    console.log(`  Creating ${chunks.length} searchable chunks in database`);

    // Create chunks in database with page numbers
    for (let i = 0; i < chunks.length; i++) {
      await prisma.documentChunk.create({
        data: {
          documentId: document.id,
          content: chunks[i].content,
          chunkIndex: i,
          pageNumber: chunks[i].pageNumber !== undefined ? chunks[i].pageNumber : null,
          metadata: {
            fileName: document.fileName,
            documentName: document.name,
            accessLevel: document.accessLevel,
            chunkCount: chunks.length,
            hasPageNumbers: chunks[i].pageNumber !== undefined,
          },
        },
      });
    }

    // Mark as processed
    await prisma.document.update({
      where: { id: document.id },
      data: { processed: true },
    });

    console.log(`  ✅ Successfully processed ${document.name}`);
  } catch (error) {
    console.error(`  ❌ Error processing ${document.name}:`, error);
    throw error;
  }
}

async function syncAndProcess() {
  console.log(`\n${'='.repeat(60)}`);
  console.log(`[${new Date().toISOString()}] Starting OneDrive sync and processing...`);
  console.log('='.repeat(60));

  // Create sync log
  const syncLog = await prisma.syncLog.create({
    data: {
      status: 'started',
      message: 'OneDrive sync and document processing initiated',
    },
  });

  let documentsProcessed = 0;

  try {
    // Enable maintenance mode
    await prisma.maintenanceMode.upsert({
      where: { id: 'singleton' },
      update: {
        isActive: true,
        activatedAt: new Date(),
        message: 'Syncing new documents from OneDrive...',
      },
      create: {
        id: 'singleton',
        isActive: true,
        activatedAt: new Date(),
        message: 'Syncing new documents from OneDrive...',
      },
    });
    console.log('\n🔒 Maintenance mode enabled\n');

    // Deprecated: OneDrive sync now handled via API endpoints
    // Initialize OneDrive service
    // const oneDriveService = getOneDriveService();

    // Sync documents from OneDrive
    console.log('📥 Skipping OneDrive sync (use API endpoints instead)...');
    const result = { found: 0, updated: 0, errors: [] };

    console.log(`\n📊 Sync Results:`);
    console.log(`   - Files found in OneDrive: ${result.found}`);
    console.log(`   - Documents updated: ${result.updated}`);
    
    if (result.errors.length > 0) {
      console.error('\n⚠️  Sync errors:', result.errors);
    }

    // Process unprocessed documents
    console.log('\n🔄 Processing new/updated documents for RAG...');
    const unprocessedDocs = await prisma.document.findMany({
      where: { processed: false },
    });

    if (unprocessedDocs.length === 0) {
      console.log('   No new documents to process');
    } else {
      console.log(`   Found ${unprocessedDocs.length} documents to process:\n`);
      
      for (const doc of unprocessedDocs) {
        await processDocument(doc);
        documentsProcessed++;
      }
    }

    // Update sync log
    await prisma.syncLog.update({
      where: { id: syncLog.id },
      data: {
        status: result.errors.length > 0 ? 'completed' : 'completed',
        message: `Synced ${result.updated} documents, processed ${documentsProcessed} for RAG`,
        documentsFound: result.found,
        documentsUpdated: result.updated,
        errorDetails: result.errors.length > 0 ? result.errors.join('\n') : null,
        completedAt: new Date(),
      },
    });

    // Disable maintenance mode
    await prisma.maintenanceMode.update({
      where: { id: 'singleton' },
      data: {
        isActive: false,
      },
    });
    console.log('\n🔓 Maintenance mode disabled');

    // Summary
    const totalChunks = await prisma.documentChunk.count();
    const totalDocs = await prisma.document.count({ where: { processed: true } });

    console.log('\n' + '='.repeat(60));
    console.log('✅ SYNC COMPLETE');
    console.log('='.repeat(60));
    console.log(`📚 Total documents in database: ${totalDocs}`);
    console.log(`🔍 Total searchable chunks: ${totalChunks}`);
    console.log(`📝 Documents processed this sync: ${documentsProcessed}`);
    console.log(`[${new Date().toISOString()}] Process completed successfully`);
    console.log('='.repeat(60) + '\n');

  } catch (error) {
    console.error('\n❌ Sync and process failed:', error);

    // Update sync log with error
    await prisma.syncLog.update({
      where: { id: syncLog.id },
      data: {
        status: 'failed',
        errorDetails: error instanceof Error ? error.message : 'Unknown error',
        completedAt: new Date(),
      },
    });

    // Disable maintenance mode even on error
    try {
      await prisma.maintenanceMode.update({
        where: { id: 'singleton' },
        data: {
          isActive: false,
        },
      });
      console.log('🔓 Maintenance mode disabled (after error)');
    } catch (e) {
      console.error('Failed to disable maintenance mode:', e);
    }

    process.exit(1);
  } finally {
    await prisma.$disconnect();
  }
}

// Run sync and process
syncAndProcess();
