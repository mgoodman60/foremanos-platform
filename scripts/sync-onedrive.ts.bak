#!/usr/bin/env node
/**
 * OneDrive Sync Script
 * Runs daily at midnight EST to sync documents from OneDrive
 */

import { PrismaClient } from '@prisma/client';
// import { getOneDriveService } from '../lib/onedrive-service'; // Deprecated: Use API endpoints instead

const prisma = new PrismaClient();

async function syncOneDrive() {
  console.log(`[${new Date().toISOString()}] Starting OneDrive sync...`);

  // Create sync log
  const syncLog = await prisma.syncLog.create({
    data: {
      status: 'started',
      message: 'OneDrive sync initiated',
    },
  });

  try {
    // Enable maintenance mode
    await prisma.maintenanceMode.upsert({
      where: { id: 'singleton' },
      update: {
        isActive: true,
        activatedAt: new Date(),
      },
      create: {
        id: 'singleton',
        isActive: true,
        activatedAt: new Date(),
      },
    });
    console.log('Maintenance mode enabled');

    // Deprecated: OneDrive sync now handled via API endpoints per-project
    // Initialize OneDrive service
    // const oneDriveService = getOneDriveService();

    // Sync documents
    // const result = await oneDriveService.syncDocuments();
    const result = { found: 0, updated: 0, errors: [] };

    console.log('OneDrive sync is now handled via per-project API endpoints');
    console.log(`Legacy sync skipped. Use POST /api/projects/[slug]/onedrive/sync instead`);
    if (result.errors.length > 0) {
      console.error('Sync errors:', result.errors);
    }

    // Update sync log
    await prisma.syncLog.update({
      where: { id: syncLog.id },
      data: {
        status: result.errors.length > 0 ? 'completed' : 'completed',
        message: `Synced ${result.updated} documents`,
        documentsFound: result.found,
        documentsUpdated: result.updated,
        errorDetails: result.errors.length > 0 ? result.errors.join('\n') : null,
        completedAt: new Date(),
      },
    });

    // Disable maintenance mode
    await prisma.maintenanceMode.update({
      where: { id: 'singleton' },
      data: {
        isActive: false,
      },
    });
    console.log('Maintenance mode disabled');

    console.log(`[${new Date().toISOString()}] OneDrive sync completed successfully`);
  } catch (error) {
    console.error('OneDrive sync failed:', error);

    // Update sync log with error
    await prisma.syncLog.update({
      where: { id: syncLog.id },
      data: {
        status: 'failed',
        errorDetails: error instanceof Error ? error.message : 'Unknown error',
        completedAt: new Date(),
      },
    });

    // Disable maintenance mode even on error
    await prisma.maintenanceMode.update({
      where: { id: 'singleton' },
      data: {
        isActive: false,
      },
    });

    process.exit(1);
  } finally {
    await prisma.$disconnect();
  }
}

// Run sync
syncOneDrive();
