/**
 * Test Claude 4.x model access
 */

async function testClaude4Models() {
  console.log('='.repeat(70));
  console.log('Claude 4.x Model Access Test');
  console.log('='.repeat(70));
  console.log('');
  
  // Get API key
  const fs = await import('fs');
  const secrets = JSON.parse(fs.readFileSync('/home/ubuntu/.config/abacusai_auth_secrets.json', 'utf8'));
  const apiKey = secrets?.anthropic?.secrets?.api_key?.value;
  
  if (!apiKey) {
    console.log('❌ No API key found');
    return;
  }
  
  console.log('✅ API Key loaded:', apiKey.substring(0, 15) + '...');
  console.log('');
  
  // Models to test based on Tier 1 rate limits screenshot
  const modelsToTest = [
    { name: 'Claude Opus 4.5', id: 'claude-opus-4-20250514' },
    { name: 'Claude Sonnet 4.5', id: 'claude-sonnet-4-20250514' },
    { name: 'Claude Haiku 4.x', id: 'claude-haiku-4-20250514' },
    { name: 'Claude 3.5 Sonnet (Oct)', id: 'claude-3-5-sonnet-20241022' },
    { name: 'Claude 3.5 Sonnet (June)', id: 'claude-3-5-sonnet-20240620' },
    { name: 'Claude 3 Opus', id: 'claude-3-opus-20240229' },
    { name: 'Claude 3 Sonnet', id: 'claude-3-sonnet-20240229' },
    { name: 'Claude 3 Haiku', id: 'claude-3-haiku-20240307' }, // We know this works
  ];
  
  console.log(`Testing ${modelsToTest.length} Claude models...`);
  console.log('');
  
  const workingModels: any[] = [];
  
  for (const model of modelsToTest) {
    process.stdout.write(`Testing ${model.name.padEnd(30)} (${model.id})... `);
    
    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'content-type': 'application/json',
          'x-api-key': apiKey,
          'anthropic-version': '2023-06-01',
        },
        body: JSON.stringify({
          model: model.id,
          max_tokens: 10,
          messages: [{ role: 'user', content: 'Hi' }],
        }),
      });
      
      if (response.ok) {
        const data = await response.json();
        console.log('✅ WORKS!');
        workingModels.push(model);
      } else {
        const errorData = await response.json();
        if (response.status === 404) {
          console.log('❌ Not Found');
        } else if (response.status === 400) {
          console.log(`❌ Bad Request: ${errorData?.error?.message || 'Unknown'}`);
        } else {
          console.log(`❌ ${response.status}: ${errorData?.error?.type || 'Unknown'}`);
        }
      }
    } catch (error: any) {
      console.log(`❌ Error: ${error.message}`);
    }
  }
  
  console.log('');
  console.log('='.repeat(70));
  console.log('RESULTS');
  console.log('='.repeat(70));
  console.log('');
  
  if (workingModels.length === 0) {
    console.log('❌ No models are accessible with your API key');
  } else {
    console.log(`✅ ${workingModels.length} model(s) accessible:`);
    console.log('');
    
    // Group by tier
    const claude4Models = workingModels.filter(m => m.id.startsWith('claude-4') || m.id.includes('-4-'));
    const claude35Models = workingModels.filter(m => m.id.includes('3-5') || m.id.includes('3.5'));
    const claude3Models = workingModels.filter(m => m.id.startsWith('claude-3') && !m.id.includes('3-5'));
    
    if (claude4Models.length > 0) {
      console.log('🚀 Claude 4.x Models:');
      claude4Models.forEach(m => console.log(`   ✅ ${m.name} (${m.id})`));
      console.log('');
    }
    
    if (claude35Models.length > 0) {
      console.log('⭐ Claude 3.5 Models:');
      claude35Models.forEach(m => console.log(`   ✅ ${m.name} (${m.id})`));
      console.log('');
    }
    
    if (claude3Models.length > 0) {
      console.log('📌 Claude 3 Models:');
      claude3Models.forEach(m => console.log(`   ✅ ${m.name} (${m.id})`));
      console.log('');
    }
    
    // Recommend best model
    console.log('='.repeat(70));
    console.log('RECOMMENDATION');
    console.log('='.repeat(70));
    console.log('');
    
    let recommended;
    if (claude4Models.find(m => m.id.includes('sonnet'))) {
      recommended = claude4Models.find(m => m.id.includes('sonnet'));
      console.log('🎯 Best Choice: ' + recommended.name);
      console.log('   Model ID: ' + recommended.id);
      console.log('   Why: Latest Claude 4 Sonnet - best quality for construction docs');
    } else if (claude35Models.length > 0) {
      recommended = claude35Models[0];
      console.log('🎯 Best Choice: ' + recommended.name);
      console.log('   Model ID: ' + recommended.id);
      console.log('   Why: Claude 3.5 Sonnet - excellent quality, proven performance');
    } else if (claude3Models.find(m => m.id.includes('opus'))) {
      recommended = claude3Models.find(m => m.id.includes('opus'));
      console.log('🎯 Best Choice: ' + recommended.name);
      console.log('   Model ID: ' + recommended.id);
      console.log('   Why: Claude 3 Opus - most capable Claude 3 model');
    } else {
      recommended = workingModels[0];
      console.log('🎯 Best Available: ' + recommended.name);
      console.log('   Model ID: ' + recommended.id);
    }
  }
  
  console.log('');
}

testClaude4Models()
  .then(() => {
    console.log('Test complete');
    process.exit(0);
  })
  .catch((error) => {
    console.error('Fatal error:', error);
    process.exit(1);
  });
