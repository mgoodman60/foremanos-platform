/**
 * Check Plans.pdf processing status
 */
import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

async function checkPlansStatus() {
  console.log('='.repeat(70));
  console.log('Plans.pdf Processing Status Check');
  console.log('='.repeat(70));
  console.log('');
  
  // Find Plans.pdf document
  const plansDoc = await prisma.document.findFirst({
    where: {
      name: {
        equals: 'Plans',
        mode: 'insensitive',
      },
      fileType: 'pdf',
    },
    include: {
      chunks: {
        select: {
          id: true,
          pageNumber: true,
          content: true,
        },
        orderBy: {
          pageNumber: 'asc',
        },
      },
    },
  });
  
  if (!plansDoc) {
    console.log('❌ Plans.pdf not found in database');
    console.log('');
    console.log('Available documents:');
    const docs = await prisma.document.findMany({
      where: { fileType: 'application/pdf' },
      select: { name: true, fileType: true },
    });
    docs.forEach(doc => console.log(`  - ${doc.name}`));
    return;
  }
  
  console.log('✅ Found Plans.pdf');
  console.log(`   Document ID: ${plansDoc.id}`);
  console.log(`   Name: ${plansDoc.name}`);
  console.log('');
  
  // Analyze chunks
  const totalChunks = plansDoc.chunks.length;
  const chunksWithText = plansDoc.chunks.filter(c => c.content && c.content.length > 50);
  const pages = [...new Set(plansDoc.chunks.map(c => c.pageNumber).filter((p): p is number => p !== null))].sort((a, b) => a - b);
  
  console.log('📊 Processing Statistics:');
  console.log(`   Total chunks: ${totalChunks}`);
  console.log(`   Chunks with text: ${chunksWithText.length}`);
  console.log(`   Pages represented: ${pages.length}`);
  console.log('');
  
  console.log('📄 Page Coverage:');
  const EXPECTED_TOTAL_PAGES = 45;
  const missingPages: number[] = [];
  
  for (let i = 1; i <= EXPECTED_TOTAL_PAGES; i++) {
    if (!pages.includes(i)) {
      missingPages.push(i);
    }
  }
  
  console.log(`   Processed: ${pages.length}/${EXPECTED_TOTAL_PAGES} pages (${Math.round(pages.length / EXPECTED_TOTAL_PAGES * 100)}%)`);
  console.log(`   Missing: ${missingPages.length} pages`);
  
  if (missingPages.length > 0 && missingPages.length <= 20) {
    console.log(`   Missing pages: ${missingPages.join(', ')}`);
  } else if (missingPages.length > 20) {
    console.log(`   Missing pages: ${missingPages.slice(0, 10).join(', ')}... and ${missingPages.length - 10} more`);
  }
  
  console.log('');
  console.log('🔍 Sample Data Quality:');
  const sampleChunk = chunksWithText[0];
  if (sampleChunk) {
    console.log(`   Page ${sampleChunk.pageNumber}: ${sampleChunk.content.substring(0, 100)}...`);
  }
  
  console.log('');
  console.log('='.repeat(70));
  
  if (missingPages.length > 0) {
    console.log('✅ Ready to reprocess');
    console.log(`   Will process ${missingPages.length} missing pages with Claude Sonnet 4.5`);
  } else {
    console.log('✅ All pages already processed');
  }
  
  console.log('='.repeat(70));
  console.log('');
}

checkPlansStatus()
  .then(() => {
    process.exit(0);
  })
  .catch((error) => {
    console.error('Error:', error);
    process.exit(1);
  })
  .finally(() => {
    prisma.$disconnect();
  });
