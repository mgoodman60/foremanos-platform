/**
 * Enhanced Vision Processing for All Documents
 * 
 * This script uses GPT-4o vision with improved OCR and spatial analysis
 * to extract accurate measurements, boundaries, and text from all PDFs.
 */

import { PrismaClient } from '@prisma/client';
import { execSync } from 'child_process';
import fs from 'fs';
import path from 'path';
import dotenv from 'dotenv';

// Load environment variables
dotenv.config();

const prisma = new PrismaClient();

if (!process.env.ABACUSAI_API_KEY) {
  console.error('❌ ABACUSAI_API_KEY not found in environment');
  process.exit(1);
}

interface EnhancedVisionResult {
  sheetNumber: string | null;
  scale: string | null;
  labeledDimensions: string[];
  derivedDimensions: string[];
  perimeterMeasurements: string[];
  spatialElements: string[];
  boundaries: string[];
  legendInfo: string[];
  notes: string[];
  textContent: string[];
  rawAnalysis: string;
}

/**
 * Convert PDF page to high-quality PNG
 */
async function convertPdfPageToImage(pdfPath: string, pageNumber: number, outputDir: string): Promise<string> {
  const outputPrefix = path.join(outputDir, `page-${pageNumber}`);
  
  try {
    // Use high DPI for better OCR
    execSync(`pdftoppm -png -r 300 -f ${pageNumber} -l ${pageNumber} -singlefile "${pdfPath}" "${outputPrefix}"`, {
      stdio: 'pipe'
    });
    
    const imagePath = `${outputPrefix}.png`;
    
    if (!fs.existsSync(imagePath)) {
      throw new Error(`Image not created at ${imagePath}`);
    }
    
    const imageBuffer = fs.readFileSync(imagePath);
    const base64 = imageBuffer.toString('base64');
    fs.unlinkSync(imagePath);
    
    return `data:image/png;base64,${base64}`;
  } catch (error) {
    console.error(`Error converting page ${pageNumber}:`, error);
    throw error;
  }
}

/**
 * Enhanced vision analysis with comprehensive OCR and boundary detection
 */
async function analyzePageEnhanced(
  imageData: string,
  pageNumber: number,
  documentName: string
): Promise<EnhancedVisionResult> {
  const apiKey = process.env.ABACUSAI_API_KEY!;
  
  const prompt = `You are analyzing a construction document page with MAXIMUM ACCURACY. Your goal is to extract ALL information visible on this page with NO HALLUCINATIONS.

**CRITICAL RULES:**
1. ONLY report what you can SEE in the image
2. DO NOT invent, assume, or extrapolate any information
3. If you cannot read something clearly, mark it as "unclear" or "partially visible"
4. For measurements, TRACE THE ACTUAL BOUNDARY shown, not just one dimension

**STEP 1: TEXT EXTRACTION (OCR)**
Extract ALL readable text from this page:
- Sheet titles and numbers
- All dimension callouts (even if small)
- Notes, specifications, labels
- Schedule/table contents
- Legend/key information
- Any text in title blocks

**STEP 2: LEGEND ANALYSIS**
If a legend or key is visible:
- Identify what different line types represent (property line, building edge, pavement edge, fence, etc.)
- Note symbols and their meanings (tree, light pole, utility marker, etc.)
- Record hatch patterns and what they represent (concrete, grass, water, etc.)

**STEP 3: BOUNDARY IDENTIFICATION**
For site plans or floor plans, identify COMPLETE BOUNDARIES:
- Property lines: Trace the ENTIRE perimeter, measuring each side
- Building footprint: Measure all edges of the building outline
- Parking lot boundaries: Identify pavement edges and measure the COMPLETE perimeter
- Room boundaries: For floor plans, measure individual room perimeters

**STEP 4: SCALE IDENTIFICATION**
Look for scale information:
- Graphic scale bars (measure the bar segments)
- Text scale notations ("SCALE: 1\" = 20'-0\"")
- Multiple scales if shown
- Note if "NTS" (Not To Scale)

**STEP 5: LABELED DIMENSIONS**
Extract ALL dimension callouts visible:
- Building dimensions
- Parking space sizes
- Setbacks and clearances
- Room dimensions
- Structural member sizes
- Include units (feet, inches, meters)

**STEP 6: DERIVED MEASUREMENTS**
USING THE SCALE, measure unlabeled elements:
- For parking lots: Measure length AND width, calculate perimeter
- For buildings: Measure all sides if not labeled
- For site features: Measure areas, distances
- SHOW YOUR CALCULATION: "Visual measurement: 3.5 scale inches × 20 ft/inch = 70 feet"

**STEP 7: PERIMETER CALCULATIONS**
For any enclosed area (parking lot, building, room):
- Measure EACH SIDE
- Calculate total perimeter: side1 + side2 + side3 + side4
- For irregular shapes, break into segments
- Example: "Parking lot perimeter = North: 120', East: 80', South: 120', West: 80' = 400 LF total"

**STEP 8: SPATIAL ELEMENTS**
List all major features shown:
- Buildings, parking lots, driveways, sidewalks
- Structural elements (columns, beams, walls)
- MEP elements (ductwork, piping, electrical)
- Include locations ("north side", "grid line A-3")

**STEP 9: NOTES AND SPECIFICATIONS**
Extract all notes:
- General notes
- Construction specifications
- Material requirements
- Code compliance notes
- Keyed notes with references

**OUTPUT FORMAT:**
Provide your analysis in this exact JSON format:
{
  "sheetNumber": "sheet identifier or null",
  "scale": "scale notation or null",
  "labeledDimensions": [
    "element description: dimension with units"
  ],
  "derivedDimensions": [
    "element: calculated dimension (calculation shown)"
  ],
  "perimeterMeasurements": [
    "feature name: side1 + side2 + ... = total perimeter"
  ],
  "spatialElements": [
    "element with location"
  ],
  "boundaries": [
    "boundary type: description"
  ],
  "legendInfo": [
    "symbol/line: meaning"
  ],
  "notes": [
    "note text"
  ],
  "textContent": [
    "all other visible text"
  ],
  "summary": "comprehensive description of page"
}

**QUALITY CHECKS:**
- Did you extract ALL visible text?
- Did you identify the legend/key?
- Did you measure COMPLETE perimeters, not just one side?
- Did you show calculations for derived measurements?
- Did you avoid inventing any information?

Be exhaustive and precise. This data will be used for quantity takeoffs and compliance verification.`;

  try {
    const response = await fetch('https://apps.abacus.ai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        model: 'gpt-4o',
        messages: [
          {
            role: 'user',
            content: [
              { type: 'text', text: prompt },
              {
                type: 'image_url',
                image_url: { url: imageData },
              },
            ],
          },
        ],
        max_tokens: 4000, // Increased for more detailed extraction
        temperature: 0, // Zero temperature for maximum consistency
      }),
    });

    if (!response.ok) {
      const errorText = await response.text();
      throw new Error(`Vision API error: ${errorText}`);
    }

    const data = await response.json();
    const content = data.choices[0].message.content;
    
    // Parse JSON response
    const jsonMatch = content.match(/\{[\s\S]*\}/);
    if (!jsonMatch) {
      console.error('Could not extract JSON from response:', content);
      throw new Error('Could not extract JSON from vision response');
    }
    
    const parsed = JSON.parse(jsonMatch[0]);
    
    return {
      sheetNumber: parsed.sheetNumber || null,
      scale: parsed.scale || null,
      labeledDimensions: parsed.labeledDimensions || [],
      derivedDimensions: parsed.derivedDimensions || [],
      perimeterMeasurements: parsed.perimeterMeasurements || [],
      spatialElements: parsed.spatialElements || [],
      boundaries: parsed.boundaries || [],
      legendInfo: parsed.legendInfo || [],
      notes: parsed.notes || [],
      textContent: parsed.textContent || [],
      rawAnalysis: parsed.summary || content,
    };
  } catch (error) {
    console.error(`❌ Error analyzing page ${pageNumber}:`, error);
    return {
      sheetNumber: null,
      scale: null,
      labeledDimensions: [],
      derivedDimensions: [],
      perimeterMeasurements: [],
      spatialElements: [],
      boundaries: [],
      legendInfo: [],
      notes: [],
      textContent: [],
      rawAnalysis: `Error analyzing page: ${error}`,
    };
  }
}

/**
 * Create enriched text chunk from enhanced analysis
 */
function createEnrichedChunk(analysis: EnhancedVisionResult, pageNumber: number): string {
  let chunk = '';
  
  if (analysis.sheetNumber) {
    chunk += `SHEET: ${analysis.sheetNumber}\n`;
  }
  
  chunk += `PAGE: ${pageNumber}\n\n`;
  
  if (analysis.scale) {
    chunk += `SCALE: ${analysis.scale}\n\n`;
  }
  
  if (analysis.legendInfo.length > 0) {
    chunk += `LEGEND/KEY:\n`;
    analysis.legendInfo.forEach((info: any) => {
      chunk += `- ${info}\n`;
    });
    chunk += `\n`;
  }
  
  if (analysis.boundaries.length > 0) {
    chunk += `BOUNDARIES:\n`;
    analysis.boundaries.forEach((boundary: any) => {
      chunk += `- ${boundary}\n`;
    });
    chunk += `\n`;
  }
  
  if (analysis.labeledDimensions.length > 0) {
    chunk += `LABELED DIMENSIONS:\n`;
    analysis.labeledDimensions.forEach((dim: any) => {
      chunk += `- ${dim}\n`;
    });
    chunk += `\n`;
  }
  
  if (analysis.derivedDimensions.length > 0) {
    chunk += `DERIVED DIMENSIONS (from scale analysis):\n`;
    analysis.derivedDimensions.forEach((dim: any) => {
      chunk += `- ${dim}\n`;
    });
    chunk += `\n`;
  }
  
  if (analysis.perimeterMeasurements.length > 0) {
    chunk += `PERIMETER MEASUREMENTS:\n`;
    analysis.perimeterMeasurements.forEach((perim: any) => {
      chunk += `- ${perim}\n`;
    });
    chunk += `\n`;
  }
  
  if (analysis.spatialElements.length > 0) {
    chunk += `ELEMENTS SHOWN:\n`;
    analysis.spatialElements.forEach((elem: any) => {
      chunk += `- ${elem}\n`;
    });
    chunk += `\n`;
  }
  
  if (analysis.notes.length > 0) {
    chunk += `NOTES AND SPECIFICATIONS:\n`;
    analysis.notes.forEach((note: any) => {
      chunk += `- ${note}\n`;
    });
    chunk += `\n`;
  }
  
  if (analysis.textContent.length > 0) {
    chunk += `OTHER TEXT CONTENT:\n`;
    analysis.textContent.forEach((text: any) => {
      chunk += `- ${text}\n`;
    });
    chunk += `\n`;
  }
  
  chunk += `SUMMARY: ${analysis.rawAnalysis}`;
  
  return chunk;
}

/**
 * Process a single document with enhanced vision
 */
async function processDocument(documentId: string, documentName: string, filePath: string) {
  console.log(`\n${'='.repeat(80)}`);
  console.log(`Processing: ${documentName}`);
  console.log(`${'='.repeat(80)}\n`);
  
  // Get page count
  const pageCountCmd = `pdfinfo "${filePath}" | grep "Pages:" | awk '{print $2}'`;
  const pageCount = parseInt(execSync(pageCountCmd).toString().trim());
  
  console.log(`📄 Total pages: ${pageCount}`);
  
  // Create temp directory for images
  const tempDir = path.join('/tmp', `vision-${Date.now()}`);
  fs.mkdirSync(tempDir, { recursive: true });
  
  // Delete existing chunks for this document
  const deleteResult = await prisma.documentChunk.deleteMany({
    where: { documentId }
  });
  console.log(`🗑️  Deleted ${deleteResult.count} existing chunks\n`);
  
  let successCount = 0;
  let failCount = 0;
  
  // Process each page
  for (let page = 1; page <= pageCount; page++) {
    try {
      console.log(`\n[${page}/${pageCount}] Analyzing page ${page}...`);
      
      // Convert to image
      const imageData = await convertPdfPageToImage(filePath, page, tempDir);
      
      // Analyze with enhanced vision
      const analysis = await analyzePageEnhanced(imageData, page, documentName);
      
      // Create enriched chunk
      const content = createEnrichedChunk(analysis, page);
      
      // Store in database
      await prisma.documentChunk.create({
        data: {
          documentId,
          content,
          chunkIndex: page - 1,
          pageNumber: page,
          metadata: {
            page,
            source: 'enhanced-vision-analysis',
            sheetNumber: analysis.sheetNumber,
            scale: analysis.scale,
            hasScale: !!analysis.scale,
            labeledDimensionsCount: analysis.labeledDimensions.length,
            derivedDimensionsCount: analysis.derivedDimensions.length,
            perimeterMeasurementsCount: analysis.perimeterMeasurements.length,
            elementsCount: analysis.spatialElements.length,
            hasDimensions: analysis.labeledDimensions.length > 0 || analysis.derivedDimensions.length > 0,
            labeled_dimensions: analysis.labeledDimensions,
            derived_dimensions: analysis.derivedDimensions,
            perimeter_measurements: analysis.perimeterMeasurements,
            elements: analysis.spatialElements,
            boundaries: analysis.boundaries,
            legend_info: analysis.legendInfo,
            notes: analysis.notes,
            text_content: analysis.textContent,
          },
        },
      });
      
      console.log(`  ✅ Sheet: ${analysis.sheetNumber || 'N/A'}`);
      console.log(`  📏 Scale: ${analysis.scale || 'N/A'}`);
      console.log(`  📐 Labeled dims: ${analysis.labeledDimensions.length}`);
      console.log(`  📊 Derived dims: ${analysis.derivedDimensions.length}`);
      console.log(`  🔄 Perimeter measurements: ${analysis.perimeterMeasurements.length}`);
      console.log(`  🏗️  Elements: ${analysis.spatialElements.length}`);
      console.log(`  📝 Notes: ${analysis.notes.length}`);
      
      successCount++;
      
      // Small delay to avoid rate limits
      await new Promise(resolve => setTimeout(resolve, 1000));
      
    } catch (error) {
      console.error(`  ❌ Error processing page ${page}:`, error);
      failCount++;
    }
  }
  
  // Cleanup temp directory
  try {
    fs.rmSync(tempDir, { recursive: true, force: true });
  } catch (error) {
    console.error('Error cleaning up temp directory:', error);
  }
  
  console.log(`\n${'='.repeat(80)}`);
  console.log(`✅ Successfully processed: ${successCount} pages`);
  console.log(`❌ Failed: ${failCount} pages`);
  console.log(`${'='.repeat(80)}\n`);
}

/**
 * Main execution
 */
async function main() {
  try {
    console.log('🚀 Starting Enhanced Vision Processing for ALL Documents\n');
    
    // Get all documents
    const documents = await prisma.document.findMany({
      where: {
        fileType: 'pdf',
        processed: true // Only process documents that have been synced
      },
      orderBy: {
        name: 'asc'
      }
    });
    
    console.log(`📚 Found ${documents.length} PDF documents to process\n`);
    
    for (const doc of documents) {
      if (!doc.filePath || !fs.existsSync(doc.filePath)) {
        console.log(`⚠️  Skipping ${doc.name}: File not found at ${doc.filePath}`);
        continue;
      }
      
      await processDocument(doc.id, doc.name, doc.filePath);
    }
    
    console.log('\n🎉 Enhanced vision processing complete for all documents!');
    
  } catch (error) {
    console.error('❌ Fatal error:', error);
    process.exit(1);
  } finally {
    await prisma.$disconnect();
  }
}

main();
