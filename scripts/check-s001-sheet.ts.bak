import { PrismaClient } from '@prisma/client';
import dotenv from 'dotenv';

dotenv.config();

const prisma = new PrismaClient();

async function checkS001() {
  try {
    // Get all chunks from Plans.pdf
    const doc = await prisma.document.findFirst({
      where: {
        name: 'Plans.pdf'
      }
    });

    if (!doc) {
      console.log('Plans.pdf not found');
      return;
    }

    const chunks = await prisma.documentChunk.findMany({
      where: {
        documentId: doc.id
      },
      orderBy: {
        pageNumber: 'asc'
      }
    });

    console.log(`Total chunks in Plans.pdf: ${chunks.length}\n`);

    // Look for S-001 or foundation-related chunks
    for (const chunk of chunks) {
      const metadata = chunk.metadata as any;
      const sheetNumber = metadata?.sheet_number || '';
      
      // Show S-001 sheet or anything with "footer" or "footing" in content
      if (sheetNumber.includes('S-001') || sheetNumber.includes('S001') ||
          chunk.content.toLowerCase().includes('perimeter footer') ||
          chunk.content.toLowerCase().includes('interior footer') ||
          (chunk.content.toLowerCase().includes('linear feet') && chunk.content.toLowerCase().includes('footer'))) {
        
        console.log('='.repeat(80));
        console.log(`Page: ${chunk.pageNumber}`);
        console.log(`Sheet: ${sheetNumber}`);
        console.log(`Scale: ${metadata?.scale || 'N/A'}`);
        
        if (metadata?.labeled_dimensions && metadata.labeled_dimensions.length > 0) {
          console.log(`\nLabeled Dimensions:`);
          console.log(JSON.stringify(metadata.labeled_dimensions, null, 2));
        }
        
        if (metadata?.notes && metadata.notes.length > 0) {
          console.log(`\nNotes:`);
          console.log(JSON.stringify(metadata.notes, null, 2));
        }
        
        console.log(`\nFull Content:`);
        console.log(chunk.content);
        console.log('\n');
      }
    }

  } catch (error) {
    console.error('Error checking S-001:', error);
  } finally {
    await prisma.$disconnect();
  }
}

checkS001();
