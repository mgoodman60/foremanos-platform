import { prisma } from '../lib/db';

async function verify() {
  const chunks = await prisma.documentChunk.findMany({
    where: { documentId: 'cmj3irmmz0006mh4eae6qxjhm' },
    orderBy: { chunkIndex: 'asc' },
    take: 5
  });
  
  console.log('\n📊 Sample of enriched chunks:');
  chunks.forEach((chunk: any, i: number) => {
    const meta = chunk.metadata as Record<string, any>;
    console.log(`\n✅ Chunk ${i + 1}:`);
    console.log(`   Sheet: ${meta.sheet_number || 'N/A'}`);
    console.log(`   Scale: ${meta.scale || 'N/A'}`);
    console.log(`   Dimensions: ${meta.labeled_dimensions?.length || 0} labeled, ${meta.derived_dimensions?.length || 0} derived`);
    console.log(`   Elements: ${meta.spatial_elements?.length || 0}`);
    console.log(`   Content preview: ${chunk.content.substring(0, 100)}...`);
  });
  
  const total = await prisma.documentChunk.count({
    where: { documentId: 'cmj3irmmz0006mh4eae6qxjhm' }
  });
  console.log(`\n✨ Total chunks for Plans.pdf: ${total}`);
  
  // Show some parking lot specific chunks
  const parkingChunks = await prisma.documentChunk.findMany({
    where: {
      documentId: 'cmj3irmmz0006mh4eae6qxjhm',
      content: { contains: 'parking' }
    },
    take: 2
  });
  
  console.log('\n🅿️ Parking-related chunks:');
  parkingChunks.forEach((chunk: any, i: number) => {
    const meta = chunk.metadata as Record<string, any>;
    console.log(`\n   Chunk ${i + 1}:`);
    console.log(`   Sheet: ${meta.sheet_number || 'N/A'}`);
    console.log(`   Content: ${chunk.content.substring(0, 150)}...`);
  });
  
  await prisma.$disconnect();
}

verify().catch(console.error);
