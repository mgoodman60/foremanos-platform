import { PrismaClient } from '@prisma/client';
import * as dotenv from 'dotenv';
import * as fs from 'fs';
import * as path from 'path';
import { exec } from 'child_process';
import { promisify } from 'util';

dotenv.config();

const prisma = new PrismaClient();
const execPromise = promisify(exec);

async function reprocessLocalDocuments() {
  const startTime = Date.now();
  
  console.log('🔄 Starting document reprocessing (local files)...');
  console.log('');
  
  try {
    const project = await prisma.project.findUnique({
      where: { slug: 'one-senior-care' },
    });
    
    if (!project) {
      console.error('❌ Project "one-senior-care" not found');
      process.exit(1);
    }
    
    console.log(`📂 Project: ${project.name} (${project.slug})`);
    console.log('');
    
    // Get all PDF documents
    const documents = await prisma.document.findMany({
      where: {
        projectId: project.id,
        fileName: { endsWith: '.pdf' },
        deletedAt: null,
      },
      orderBy: { name: 'asc' },
    });
    
    if (documents.length === 0) {
      console.log('ℹ️  No PDF documents found to reprocess');
      await prisma.$disconnect();
      return;
    }
    
    console.log(`📄 Found ${documents.length} PDF documents:`);
    documents.forEach((doc: any, i: number) => {
      console.log(`   ${i + 1}. ${doc.name}`);
    });
    console.log('');
    
    console.log('⚠️  This will:');
    console.log('   1. Delete all existing chunks for these documents');
    console.log('   2. Re-run vision processing with enhanced prompts (including zone extraction)');
    console.log('');
    console.log('💰 Estimated cost: ~$0.50 (0.01/page × ~50 pages)');
    console.log('⏱️  Estimated time: 15-20 minutes');
    console.log('');
    
    let totalPages = 0;
    let totalCost = 0;
    let successCount = 0;
    let failCount = 0;
    
    for (const doc of documents) {
      try {
        console.log(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`);
        console.log(`🔧 Processing: ${doc.name}`);
        console.log('');
        
        // Check if file exists in public/documents
        const filePath = path.join(process.cwd(), 'public', 'documents', doc.fileName);
        
        if (!fs.existsSync(filePath)) {
          console.error(`   ❌ File not found: ${filePath}`);
          failCount++;
          continue;
        }
        
        console.log(`   ✅ Found file: ${filePath}`);
        
        // Delete existing chunks
        const deletedChunks = await prisma.documentChunk.deleteMany({
          where: { documentId: doc.id },
        });
        
        console.log(`   ✅ Deleted ${deletedChunks.count} existing chunks`);
        console.log(`   🔄 Starting vision processing...`);
        console.log('');
        
        // Run vision processing directly
        const { stdout, stderr } = await execPromise(
          `cd ${process.cwd()} && yarn tsx --require dotenv/config scripts/vision-process-plans.ts "${filePath}" "${doc.id}"`
        );
        
        if (stderr && !stderr.includes('ExperimentalWarning')) {
          console.error('   ⚠️  stderr:', stderr);
        }
        
        // Get updated stats
        const chunks = await prisma.documentChunk.count({
          where: { documentId: doc.id },
        });
        
        // Estimate cost (assuming $0.01 per page)
        const pageCount = chunks; // Rough estimate: 1 chunk ≈ 1 page
        const cost = pageCount * 0.01;
        
        // Update document
        await prisma.document.update({
          where: { id: doc.id },
          data: {
            processed: true,
            pagesProcessed: pageCount,
            processingCost: cost,
          },
        });
        
        totalPages += pageCount;
        totalCost += cost;
        
        console.log('');
        console.log(`   ✅ Completed: ${pageCount} pages, ${chunks} chunks, $${cost.toFixed(4)}`);
        successCount++;
        
      } catch (error) {
        console.error(`   ❌ Failed to reprocess ${doc.name}:`, error);
        failCount++;
      }
      
      console.log('');
    }
    
    // Summary
    const elapsedSeconds = Math.floor((Date.now() - startTime) / 1000);
    const elapsedMinutes = Math.floor(elapsedSeconds / 60);
    const remainingSeconds = elapsedSeconds % 60;
    
    console.log(`━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━`);
    console.log(`✅ REPROCESSING COMPLETE`);
    console.log('');
    console.log(`📊 Summary:`);
    console.log(`   ✅ Successful: ${successCount}`);
    console.log(`   ❌ Failed: ${failCount}`);
    console.log(`   📄 Total Pages: ${totalPages}`);
    console.log(`   💰 Total Cost: $${totalCost.toFixed(4)}`);
    console.log(`   ⏱️  Time: ${elapsedMinutes}m ${remainingSeconds}s`);
    console.log('');
    
    await prisma.$disconnect();
    
  } catch (error) {
    console.error('❌ Error during reprocessing:', error);
    await prisma.$disconnect();
    process.exit(1);
  }
}

reprocessLocalDocuments();
