// Subcontractor Contracts
model SubcontractorContract {
  id                String              @id @default(cuid())
  projectId         String
  subcontractorId   String
  
  // Contract identification
  contractNumber    String
  title             String
  contractType      ContractType        @default(SUBCONTRACT)
  
  // Financial terms
  originalValue     Float               // Original contract amount
  currentValue      Float               // Current value including approved COs
  retainagePercent  Float               @default(10)
  
  // Dates
  executionDate     DateTime?           // Date contract was signed
  effectiveDate     DateTime            // When work can begin
  completionDate    DateTime            // Scheduled completion
  actualCompletionDate DateTime?
  
  // Scope (AI-extracted or manual)
  scopeOfWork       String?             @db.Text
  inclusions        String[]
  exclusions        String[]
  
  // Payment terms
  paymentTerms      String?             // "Net 30", "Progress billing", etc.
  billingSchedule   BillingSchedule     @default(MONTHLY)
  
  // Insurance requirements
  glRequired        Float?              // General Liability minimum
  wcRequired        Boolean             @default(true)
  autoRequired      Float?              // Auto liability minimum
  umbrellaRequired  Float?              // Umbrella/excess minimum
  bondRequired      Boolean             @default(false)
  bondAmount        Float?
  
  // Key clauses (AI-extracted)
  liquidatedDamages Float?              // Per day amount
  warrantyPeriod    Int?                // Months
  changeOrderProcess String?
  disputeResolution String?
  terminationClauses String?            @db.Text
  
  // File storage
  originalFileName  String
  cloudStoragePath  String
  fileSize          Int?
  mimeType          String?
  
  // AI extraction
  aiExtracted       Boolean             @default(false)
  aiConfidence      Float?
  extractedAt       DateTime?
  
  // Status
  status            ContractStatus      @default(DRAFT)
  approvedBy        String?
  approvedAt        DateTime?
  
  // Tracking
  createdBy         String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subcontractor     Subcontractor       @relation(fields: [subcontractorId], references: [id])
  createdByUser     User                @relation("ContractCreatedBy", fields: [createdBy], references: [id])
  approvedByUser    User?               @relation("ContractApprovedBy", fields: [approvedBy], references: [id])
  insuranceCerts    InsuranceCertificate[]
  changeOrders      ContractChangeOrder[]
  payments          ContractPayment[]
  
  @@unique([projectId, contractNumber])
  @@index([projectId])
  @@index([subcontractorId])
  @@index([status])
  @@index([createdBy])
}

enum ContractType {
  SUBCONTRACT
  PURCHASE_ORDER
  SERVICE_AGREEMENT
  MASTER_AGREEMENT
  TASK_ORDER
}

enum ContractStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  COMPLETED
  TERMINATED
  EXPIRED
}

enum BillingSchedule {
  WEEKLY
  BIWEEKLY
  MONTHLY
  MILESTONE
  COMPLETION
  CUSTOM
}

