generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/construction_project_assistant/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  User       User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model AdminCorrection {
  id               String          @id @default(cuid())
  feedbackId       String          @unique
  projectId        String?
  originalQuestion String
  originalAnswer   String
  correctedAnswer  String
  adminNotes       String?
  keywords         String[]
  isActive         Boolean         @default(true)
  usageCount       Int             @default(0)
  createdBy        String
  createdAt        DateTime        @default(now())
  updatedAt DateTime @updatedAt
  User             User            @relation(fields: [createdBy], references: [id])
  MessageFeedback  MessageFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  Project          Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([keywords])
  @@index([projectId])
}

model AnnotationReply {
  id               String           @id @default(cuid())
  annotationId     String
  content          String
  createdBy        String
  createdAt        DateTime         @default(now())
  updatedAt DateTime @updatedAt
  VisualAnnotation VisualAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  User             User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([annotationId])
  @@index([createdBy])
}

model BudgetItem {
  id             String        @id @default(cuid())
  budgetId       String
  name           String
  description    String?
  costCode       String?
  tradeType      TradeType?
  
  // Walker Company Phase Structure (CSI Divisions)
  phaseCode      Int?          // 100, 200, 300, etc. (CSI Division)
  phaseName      String?       // "GENERAL REQUIREMENTS", "SITEWORK", etc.
  categoryNumber Int?          // Line item number within phase (1, 2, 3...)
  
  // Financial Tracking
  budgetedAmount Float         // Budget column
  revisedBudget  Float?        // After change orders
  contractAmount Float?        // Original contract amount for this line
  actualCost     Float         @default(0)
  committedCost  Float         @default(0)
  billedToDate   Float         @default(0)  // Amount billed for this line item
  
  // Hours Tracking
  budgetedHours  Float         @default(0)
  actualHours    Float         @default(0)
  
  linkedTaskIds  String[]
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ProjectBudget            ProjectBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  ChangeOrder              ChangeOrder[]
  Invoice                  Invoice[]
  LaborEntry               LaborEntry[]
  CostAlert                CostAlert[]
  PaymentApplicationItem   PaymentApplicationItem[]
  Procurement              Procurement[]

  @@index([budgetId])
  @@index([costCode])
  @@index([tradeType])
  @@index([phaseCode])
}

// Change Order Tracking
model ChangeOrder {
  id              String           @id @default(cuid())
  projectId       String
  budgetItemId    String?
  orderNumber     String
  title           String
  description     String?
  requestedBy     String?
  status          ChangeOrderStatus @default(PENDING)
  originalAmount  Float            @default(0)
  proposedAmount  Float
  approvedAmount  Float?
  scheduleImpactDays Int?
  submittedDate   DateTime         @default(now())
  reviewedDate    DateTime?
  approvedDate    DateTime?
  rejectedDate    DateTime?
  approvedBy      String?
  notes           String?
  attachmentIds   String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  Project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  BudgetItem      BudgetItem?      @relation(fields: [budgetItemId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([budgetItemId])
}

enum ChangeOrderStatus {
  DRAFT
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  VOIDED
}

// Subcontractor Invoice Tracking
model Invoice {
  id                String        @id @default(cuid())
  projectId         String
  budgetItemId      String?
  subcontractorId   String?
  invoiceNumber     String
  description       String?
  amount            Float
  laborAmount       Float         @default(0)
  materialsAmount   Float         @default(0)
  status            InvoiceStatus @default(PENDING)
  invoiceDate       DateTime
  dueDate           DateTime?
  paidDate          DateTime?
  submittedBy       String?
  approvedBy        String?
  notes             String?
  attachmentId      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  Project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  BudgetItem        BudgetItem?   @relation(fields: [budgetItemId], references: [id])
  Subcontractor     Subcontractor? @relation(fields: [subcontractorId], references: [id])

  @@index([projectId])
  @@index([budgetItemId])
  @@index([subcontractorId])
  @@index([status])
}

enum InvoiceStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  DISPUTED
}

// Labor Cost Tracking
model LaborEntry {
  id              String        @id @default(cuid())
  projectId       String
  budgetItemId    String?
  workerId        String?
  workerName      String
  tradeType       TradeType?
  date            DateTime
  hoursWorked     Float
  hourlyRate      Float
  overtimeHours   Float         @default(0)
  overtimeRate    Float?
  totalCost       Float
  description     String?
  approvedBy      String?
  status          LaborStatus   @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  Project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  BudgetItem      BudgetItem?   @relation(fields: [budgetItemId], references: [id])

  @@index([projectId])
  @@index([budgetItemId])
  @@index([date])
  @@index([tradeType])
}

enum LaborStatus {
  PENDING
  APPROVED
  REJECTED
}

// Cost Alerts
model CostAlert {
  id              String        @id @default(cuid())
  projectId       String
  budgetItemId    String?
  alertType       CostAlertType
  severity        AlertSeverity @default(WARNING)
  title           String
  message         String
  threshold       Float?
  currentValue    Float?
  isRead          Boolean       @default(false)
  isDismissed     Boolean       @default(false)
  triggeredAt     DateTime      @default(now())
  readAt          DateTime?
  dismissedAt     DateTime?
  createdAt       DateTime      @default(now())
  Project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  BudgetItem      BudgetItem?   @relation(fields: [budgetItemId], references: [id])

  @@index([projectId])
  @@index([alertType])
  @@index([isRead])
  @@index([isDismissed])
}

enum CostAlertType {
  CPI_LOW
  SPI_LOW
  BUDGET_EXCEEDED
  ITEM_OVER_BUDGET
  CONTINGENCY_LOW
  FORECAST_OVERRUN
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// Contingency Usage Tracking
model ContingencyUsage {
  id              String        @id @default(cuid())
  projectId       String
  changeOrderId   String?
  amount          Float
  reason          String
  description     String?
  approvedBy      String?
  usedDate        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  Project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([usedDate])
}

// Budget Snapshots for S-Curve
model BudgetSnapshot {
  id              String        @id @default(cuid())
  projectId       String
  snapshotDate    DateTime
  plannedValue    Float
  earnedValue     Float
  actualCost      Float
  cpi             Float?
  spi             Float?
  percentComplete Float
  createdAt       DateTime      @default(now())
  Project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([snapshotDate])
}

// Weekly Cost Reports
model WeeklyCostReport {
  id                String        @id @default(cuid())
  projectId         String
  weekStartDate     DateTime
  weekEndDate       DateTime
  totalBudget       Float
  actualCost        Float
  committedCost     Float
  cpi               Float?
  spi               Float?
  eac               Float?
  contingencyUsed   Float         @default(0)
  contingencyRemaining Float
  changeOrdersApproved Int        @default(0)
  changeOrdersValue Float         @default(0)
  laborCost         Float         @default(0)
  materialsCost     Float         @default(0)
  highlights        String?
  concerns          String?
  generatedAt       DateTime      @default(now())
  generatedBy       String?
  Project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([weekStartDate])
  @@unique([projectId, weekStartDate])
}


model ChatMessage {
  id              String           @id @default(cuid())
  userId          String?
  userRole        String           @default("external")
  message         String
  response        String
  documentsUsed   String[]
  createdAt       DateTime         @default(now())
  conversationId  String?
  hasImage        Boolean          @default(false)
  Conversation    Conversation?    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User            User?            @relation(fields: [userId], references: [id])
  MessageFeedback MessageFeedback?

  @@index([conversationId])
  @@index([createdAt])
  @@index([userId])
}

