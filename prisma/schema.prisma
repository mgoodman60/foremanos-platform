  conversationType      String             @default("regular")
  dailyReportDate       DateTime?
  isPinned              Boolean            @default(false)
  isReadOnly            Boolean            @default(false)
  isSystemManaged       Boolean            @default(false)
  introMessageSent      Boolean            @default(false)
  lastWorkflowStep      String?
  reportData            Json?
  weatherFetched        Boolean            @default(false)
  workflowState         String             @default("new")
  weatherImpactWarning  String?
  weatherSnapshots      Json?
  scheduleAskedUser     Boolean            @default(false)
  scheduleSuggestions   Json?
  scheduleUpdates       Json?
  scheduledActivities   Json?
  locationAskedUser     Boolean            @default(false)
  locationSuggestions   Json?
