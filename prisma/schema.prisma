model MaintenanceMode {
  id          String    @id @default("singleton")
  isActive    Boolean   @default(false)
  message     String    @default("Updating documents... Please check back in a few minutes")
  activatedAt DateTime?
  updatedAt DateTime @updatedAt
}

model MaterialTakeoff {
  id              String            @id @default(cuid())
  projectId       String
  name            String
  description     String?
  status          String            @default("draft")
  documentId      String?
  extractedBy     String?
  extractedAt     DateTime?
  totalCost       Float?
  costUnit        String            @default("USD")
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt DateTime @updatedAt
  User            User              @relation(fields: [createdBy], references: [id])
  Document        Document?         @relation(fields: [documentId], references: [id])
  Project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  TakeoffLineItem TakeoffLineItem[]

  @@index([createdBy])
  @@index([projectId])
  @@index([status])
}

model TakeoffAggregation {
  id              String                    @id @default(cuid())
  projectId       String
  name            String
  description     String?
  status          String                    @default("draft") // draft, finalized, approved
  sourceSheets    Json                      // Array of sheet numbers included
  sourceTakeoffs  Json?                     // Array of takeoff IDs included
  totalItems      Int                       @default(0)
  totalQuantity   Float                     @default(0)
  totalCost       Float?
  costUnit        String                    @default("USD")
  aggregatedData  Json?                     // Merged line items with source tracking
  categorySummary Json?                     // Summary by category
  tradeBreakdown  Json?                     // Summary by trade type
  duplicatesMerged Int                      @default(0) // Count of merged duplicate items
  createdBy       String
