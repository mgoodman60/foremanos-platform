generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  User       User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model AdminCorrection {
  id               String          @id @default(cuid())
  feedbackId       String          @unique
  projectId        String?
  originalQuestion String
  originalAnswer   String
  correctedAnswer  String
  adminNotes       String?
  keywords         String[]
  isActive         Boolean         @default(true)
  usageCount       Int             @default(0)
  createdBy        String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  User             User            @relation(fields: [createdBy], references: [id])
  MessageFeedback  MessageFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  Project          Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([keywords])
  @@index([projectId])
}

model AnnotationReply {
  id               String           @id @default(cuid())
  annotationId     String
  content          String
  createdBy        String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  VisualAnnotation VisualAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  User             User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([annotationId])
  @@index([createdBy])
}

model BudgetItem {
  id                     String                   @id @default(cuid())
  budgetId               String
  name                   String
  description            String?
  costCode               String?
  tradeType              TradeType?
  phaseCode              Int?
  phaseName              String?
  categoryNumber         Int?
  budgetedAmount         Float
  revisedBudget          Float?
  contractAmount         Float?
  actualCost             Float                    @default(0)
  committedCost          Float                    @default(0)
  billedToDate           Float                    @default(0)
  budgetedHours          Float                    @default(0)
  actualHours            Float                    @default(0)
  linkedTaskIds          String[]
  isActive               Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  ProjectBudget          ProjectBudget            @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  ChangeOrder            ChangeOrder[]
  CostAlert              CostAlert[]
  Invoice                Invoice[]
  LaborEntry             LaborEntry[]
  PaymentApplicationItem PaymentApplicationItem[]
  Procurement            Procurement[]

  @@index([budgetId])
  @@index([costCode])
  @@index([tradeType])
  @@index([phaseCode])
  @@index([budgetId, isActive])
}

model ChangeOrder {
  id                 String            @id @default(cuid())
  projectId          String
  budgetItemId       String?
  orderNumber        String
  title              String
  description        String?
  requestedBy        String?
  status             ChangeOrderStatus @default(PENDING)
  originalAmount     Float             @default(0)
  proposedAmount     Float
  approvedAmount     Float?
  scheduleImpactDays Int?
  submittedDate      DateTime          @default(now())
  reviewedDate       DateTime?
  approvedDate       DateTime?
  rejectedDate       DateTime?
  approvedBy         String?
  notes              String?
  attachmentIds      String[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  BudgetItem         BudgetItem?       @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)
  Project            Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([budgetItemId])
}

model Invoice {
  id              String         @id @default(cuid())
  projectId       String
  budgetItemId    String?
  subcontractorId String?
  invoiceNumber   String
  description     String?
  amount          Float
  laborAmount     Float          @default(0)
  materialsAmount Float          @default(0)
  status          InvoiceStatus  @default(PENDING)
  invoiceDate     DateTime
  dueDate         DateTime?
  paidDate        DateTime?
  submittedBy     String?
  approvedBy      String?
  notes           String?
  attachmentId    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  BudgetItem      BudgetItem?    @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)
  Project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Subcontractor   Subcontractor? @relation(fields: [subcontractorId], references: [id])

  @@index([projectId])
  @@index([budgetItemId])
  @@index([subcontractorId])
  @@index([status])
}

model LaborEntry {
  id            String      @id @default(cuid())
  projectId     String
  budgetItemId  String?
  workerId      String?
  workerName    String
  tradeType     TradeType?
  date          DateTime
  hoursWorked   Float
  hourlyRate    Float
  overtimeHours Float       @default(0)
  overtimeRate  Float?
  totalCost     Float
  description   String?
  approvedBy    String?
  status        LaborStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  BudgetItem    BudgetItem? @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)
  Project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([budgetItemId])
  @@index([date])
  @@index([tradeType])
}

model CostAlert {
  id           String        @id @default(cuid())
  projectId    String
  budgetItemId String?
  alertType    CostAlertType
  severity     AlertSeverity @default(WARNING)
  title        String
  message      String
  threshold    Float?
  currentValue Float?
  isRead       Boolean       @default(false)
  isDismissed  Boolean       @default(false)
  triggeredAt  DateTime      @default(now())
  readAt       DateTime?
  dismissedAt  DateTime?
  createdAt    DateTime      @default(now())
  BudgetItem   BudgetItem?   @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)
  Project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([alertType])
  @@index([isRead])
  @@index([isDismissed])
}

model ContingencyUsage {
  id            String   @id @default(cuid())
  projectId     String
  changeOrderId String?
  amount        Float
  reason        String
  description   String?
  approvedBy    String?
  usedDate      DateTime @default(now())
  createdAt     DateTime @default(now())
  Project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([usedDate])
}

model BudgetSnapshot {
  id              String   @id @default(cuid())
  projectId       String
  snapshotDate    DateTime
  plannedValue    Float
  earnedValue     Float
  actualCost      Float
  cpi             Float?
  spi             Float?
  percentComplete Float
  createdAt       DateTime @default(now())
  Project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, snapshotDate])
  @@index([projectId])
  @@index([snapshotDate])
}

model WeeklyCostReport {
  id                   String   @id @default(cuid())
  projectId            String
  weekStartDate        DateTime
  weekEndDate          DateTime
  totalBudget          Float
  actualCost           Float
  committedCost        Float
  cpi                  Float?
  spi                  Float?
  eac                  Float?
  contingencyUsed      Float    @default(0)
  contingencyRemaining Float
  changeOrdersApproved Int      @default(0)
  changeOrdersValue    Float    @default(0)
  laborCost            Float    @default(0)
  materialsCost        Float    @default(0)
  highlights           String?
  concerns             String?
  generatedAt          DateTime @default(now())
  generatedBy          String?
  Project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, weekStartDate])
  @@index([projectId])
  @@index([weekStartDate])
}

model ChatMessage {
  id              String           @id @default(cuid())
  userId          String?
  userRole        String           @default("external")
  message         String
  response        String
  documentsUsed   String[]
  createdAt       DateTime         @default(now())
  conversationId  String?
  hasImage        Boolean          @default(false)
  Conversation    Conversation?    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User            User?            @relation(fields: [userId], references: [id])
  MessageFeedback MessageFeedback?

  @@index([conversationId])
  @@index([createdAt])
  @@index([userId])
  @@index([conversationId, createdAt])
}

model Conversation {
  id                    String             @id @default(cuid())
  userId                String?
  title                 String             @default("New Conversation")
  userRole              String             @default("external")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  projectId             String?
  conversationType      String             @default("regular")
  dailyReportDate       DateTime?
  isPinned              Boolean            @default(false)
  isReadOnly            Boolean            @default(false)
  isSystemManaged       Boolean            @default(false)
  introMessageSent      Boolean            @default(false)
  lastWorkflowStep      String?
  reportData            Json?
  weatherFetched        Boolean            @default(false)
  workflowState         String             @default("new")
  weatherImpactWarning  String?
  weatherSnapshots      Json?
  scheduleAskedUser     Boolean            @default(false)
  scheduleSuggestions   Json?
  scheduleUpdates       Json?
  scheduledActivities   Json?
  locationAskedUser     Boolean            @default(false)
  locationSuggestions   Json?
  workLocations         Json?
  photoCount            Int                @default(0)
  photoSequence         Int                @default(0)
  photos                Json?
  calculationsAskedUser Boolean            @default(false)
  calculationsPending   Boolean            @default(false)
  quantityCalculations  Json?
  documentId            String?
  finalizationMethod    String?
  finalizationWarned    Boolean            @default(false)
  finalized             Boolean            @default(false)
  finalizedAt           DateTime?
  finalizedBy           String?
  lastActivityAt        DateTime?
  onedriveExportPath    String?
  onedriveExported      Boolean            @default(false)
  onedriveExportedAt    DateTime?
  ragIndexed            Boolean            @default(false)
  ragIndexedAt          DateTime?
  equipmentData         Json?
  materialDeliveries    Json?
  ChatMessage           ChatMessage[]
  Project               Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  User                  User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  WorkflowResponse      WorkflowResponse[]

  @@index([conversationType])
  @@index([createdAt])
  @@index([dailyReportDate])
  @@index([isPinned])
  @@index([projectId])
  @@index([userId])
  @@index([projectId, conversationType, dailyReportDate])
}

model Crew {
  id                String            @id @default(cuid())
  projectId         String
  name              String
  tradeType         TradeType
  subcontractorId   String?
  foremanName       String?
  foremanPhone      String?
  averageSize       Int               @default(4)
  isActive          Boolean           @default(true)
  productivityScore Float?
  safetyScore       Float?
  qualityScore      Float?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  Project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Subcontractor     Subcontractor?    @relation(fields: [subcontractorId], references: [id])
  CrewAssignment    CrewAssignment[]
  CrewPerformance   CrewPerformance[]

  @@unique([projectId, name])
  @@index([isActive])
  @@index([projectId])
  @@index([tradeType])
}

model CrewAssignment {
  id           String       @id @default(cuid())
  taskId       String
  crewId       String
  assignedDate DateTime     @default(now())
  startDate    DateTime?
  endDate      DateTime?
  crewSize     Int          @default(4)
  hoursWorked  Float        @default(0)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  Crew         Crew         @relation(fields: [crewId], references: [id], onDelete: Cascade)
  ScheduleTask ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, crewId])
  @@index([crewId])
  @@index([taskId])
}

model CrewPerformance {
  id               String   @id @default(cuid())
  crewId           String
  date             DateTime
  crewSize         Int
  hoursWorked      Float
  tasksCompleted   Int      @default(0)
  unitsProduced    Float?
  productivityRate Float?
  safetyIncidents  Int      @default(0)
  qualityIssues    Int      @default(0)
  reworkRequired   Boolean  @default(false)
  weatherDelay     Boolean  @default(false)
  weatherNotes     String?
  notes            String?
  recordedBy       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  Crew             Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@unique([crewId, date])
  @@index([crewId])
  @@index([date])
}

model CustomSymbol {
  id            String         @id @default(cuid())
  projectId     String
  name          String
  description   String
  category      SymbolCategory
  aliases       String[]       @default([])
  standardMatch String?
  confidence    Float          @default(0.0)
  usageCount    Int            @default(0)
  learnedFrom   String?
  contextInfo   Json?
  confirmedBy   String?
  rejectedCount Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  User          User?          @relation(fields: [confirmedBy], references: [id])
  Project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([category])
  @@index([confidence])
  @@index([projectId])
  @@index([category], map: "idx_symbols_category")
  @@index([projectId], map: "idx_symbols_project")
}

model DetailCallout {
  id             String   @id @default(cuid())
  projectId      String
  documentId     String
  extractedAt    DateTime @default(now())
  confidence     Float    @default(0.85)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  boundingBox    Json?
  description    String?
  number         String
  sheetReference String
  sourceLocation String?
  sourceSheet    String
  type           String
  Document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([projectId])
  @@index([projectId, sheetReference])
  @@index([projectId, sourceSheet])
  @@index([sheetReference])
  @@index([sourceSheet])
}

model DimensionAnnotation {
  id               String   @id @default(cuid())
  projectId        String
  documentId       String
  sheetNumber      String
  dimensions       Json     @default("[]")
  validationErrors Json?    @default("[]")
  extractedAt      DateTime @default(now())
  confidence       Float    @default(0.85)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  Document         Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, documentId, sheetNumber])
  @@index([documentId])
  @@index([projectId])
  @@index([sheetNumber])
}

model Document {
  id                      String                  @id @default(cuid())
  name                    String
  fileName                String
  fileType                String
  oneDriveId              String?                 @unique
  accessLevel             String                  @default("guest")
  filePath                String?
  fileUrl                 String?
  lastModified            DateTime?
  fileSize                Int?
  processed               Boolean                 @default(false)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  projectId               String
  description             String?
  tags                    String[]
  updatedBy               String?
  cloud_storage_path      String?
  isPublic                Boolean                 @default(false)
  deletedAt               DateTime?
  oneDriveHash            String?
  syncSource              String?
  pagesProcessed          Int?
  processingCost          Float?
  processorType           String?
  category                DocumentCategory        @default(other)
  fileHash                String?
  lastProcessedHash       String?
  processedAt             DateTime?
  queuePriority           Int                     @default(5)
  queueStatus             String                  @default("none")
  queuedAt                DateTime?
  lastProcessingError     String?
  processingRetries       Int                     @default(0)
  virusStatus             String? // "clean" | "infected" | "skipped" | "error"
  virusScanAt             DateTime?
  virusScanProvider       String? // "virustotal"
  sheetIndex              Json?
  DetailCallout           DetailCallout[]
  DimensionAnnotation     DimensionAnnotation[]
  Project                 Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  DocumentChunk           DocumentChunk[]
  DoorScheduleItem        DoorScheduleItem[]
  DrawingType             DrawingType[]
  EnhancedAnnotation      EnhancedAnnotation[]
  FinishScheduleSourceDoc FinishScheduleItem[]    @relation("FinishScheduleSourceDoc")
  FloorPlanSourceDoc      FloorPlan[]             @relation("FloorPlanSourceDoc")
  HardwareSetDefinition   HardwareSetDefinition[]
  MaterialTakeoff         MaterialTakeoff[]
  ProcessingQueue         ProcessingQueue[]
  ProjectDataSource       ProjectDataSource[]
  RoomFromSource          Room[]                  @relation("RoomSourceDoc")
  Schedule                Schedule[]
  SheetLegend             SheetLegend[]
  VisualAnnotation        VisualAnnotation[]
  WindowScheduleItem      WindowScheduleItem[]
  Markup                  Markup[]
  MarkupReply             MarkupReply[]          @relation("MarkupReplyDocument")
  MarkupLayer             MarkupLayer[]
  MarkupCalibration       MarkupCalibration[]
  MarkupSession           MarkupSession[]

  @@index([category])
  @@index([deletedAt])
  @@index([oneDriveId])
  @@index([projectId])
  @@index([syncSource])
  @@index([projectId, processed, category])
}

model DocumentChunk {
  id                    String              @id @default(cuid())
  documentId            String?
  content               String
  chunkIndex            Int
  pageNumber            Int?
  metadata              Json?
  createdAt             DateTime            @default(now())
  regulatoryDocumentId  String?
  dateIssued            DateTime?
  discipline            String?
  revision              String?
  sheetNumber           String?
  titleBlockData        Json?
  hasMultipleScales     Boolean?
  primaryScale          String?
  scaleData             Json?
  scaleRatio            Float?
  scaleType             String?
  drawingType           String?
  drawingTypeConfidence Float?
  isCompositeDrawing    Boolean?
  annotations           Json?
  callouts              Json?
  crossReferences       Json?
  drawingCategory       String?
  scale                 String?
  scaleValidation       Json?
  dimensionCount        Int?
  dimensionSummary      Json?
  dimensions            Json?
  Document              Document?           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  RegulatoryDocument    RegulatoryDocument? @relation(fields: [regulatoryDocumentId], references: [id], onDelete: Cascade)

  @@index([chunkIndex])
  @@index([discipline])
  @@index([documentId])
  @@index([drawingCategory])
  @@index([drawingType])
  @@index([regulatoryDocumentId])
  @@index([sheetNumber])
  @@index([documentId], map: "idx_document_chunks_document")
}

model DrawingType {
  id          String   @id @default(cuid())
  projectId   String
  documentId  String
  sheetNumber String
  type        String
  subtype     String
  confidence  Float
  features    Json
  reasoning   String
  patterns    Json
  extractedAt DateTime @default(now())
  Document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, documentId, sheetNumber])
  @@index([documentId])
  @@index([projectId])
  @@index([sheetNumber])
  @@index([subtype])
  @@index([type])
}

model EarnedValue {
  id                       String        @id @default(cuid())
  budgetId                 String
  periodDate               DateTime
  periodType               String        @default("daily")
  plannedValue             Float
  earnedValue              Float
  actualCost               Float
  costVariance             Float
  scheduleVariance         Float
  costPerformanceIndex     Float
  schedulePerformanceIndex Float
  estimateAtCompletion     Float?
  estimateToComplete       Float?
  varianceAtCompletion     Float?
  percentComplete          Float         @default(0)
  percentSpent             Float         @default(0)
  notes                    String?
  calculatedBy             String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  ProjectBudget            ProjectBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, periodDate, periodType])
  @@index([budgetId])
  @@index([periodDate])
}

model EnhancedAnnotation {
  id          String   @id @default(cuid())
  projectId   String
  documentId  String
  sheetNumber String
  annotations Json     @default("[]")
  extractedAt DateTime @default(now())
  confidence  Float    @default(0.85)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, documentId, sheetNumber])
  @@index([documentId])
  @@index([projectId])
  @@index([sheetNumber])
}

model FinishScheduleItem {
  id                String      @id @default(cuid())
  roomId            String
  category          String
  finishType        String?
  material          String?
  manufacturer      String?
  modelNumber       String?
  color             String?
  dimensions        String?
  notes             String?
  csiCode           String?
  csiDivision       Int?
  sourceDocumentId  String?
  sourceSheetNumber String?
  extractedAt       DateTime?
  isConfirmed       Boolean     @default(false)
  status            String      @default("proposed")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  Room              Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  SourceDocument    Document?   @relation("FinishScheduleSourceDoc", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  RoomPhoto         RoomPhoto[]

  @@index([category])
  @@index([csiDivision])
  @@index([roomId])
  @@index([sourceDocumentId])
  @@index([status])
}

model FloorPlan {
  id                 String    @id @default(cuid())
  projectId          String
  name               String
  floor              String?
  building           String?
  cloud_storage_path String
  isPublic           Boolean   @default(false)
  imageWidth         Int?
  imageHeight        Int?
  sourceDocumentId   String?
  sourceSheetNumber  String?
  scale              String?
  description        String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  Project            Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  SourceDocument     Document? @relation("FloorPlanSourceDoc", fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([floor])
  @@index([isActive])
  @@index([projectId])
  @@index([sourceDocumentId])
}

model MaintenanceMode {
  id          String    @id @default("singleton")
  isActive    Boolean   @default(false)
  message     String    @default("Updating documents... Please check back in a few minutes")
  activatedAt DateTime?
  updatedAt   DateTime  @updatedAt
}

model MaterialTakeoff {
  id              String                @id @default(cuid())
  projectId       String
  name            String
  description     String?
  status          MaterialTakeoffStatus @default(draft)
  documentId      String?
  extractedBy     String?
  extractedAt     DateTime?
  totalCost       Float?
  costUnit        String                @default("USD")
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  User            User                  @relation(fields: [createdBy], references: [id])
  Document        Document?             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  TakeoffLineItem TakeoffLineItem[]

  @@index([createdBy])
  @@index([projectId])
  @@index([status])
}

model TakeoffAggregation {
  id               String                @id @default(cuid())
  projectId        String
  name             String
  description      String?
  status           MaterialTakeoffStatus @default(draft)
  sourceSheets     Json
  sourceTakeoffs   Json?
  totalItems       Int                   @default(0)
  totalQuantity    Float                 @default(0)
  totalCost        Float?
  costUnit         String                @default("USD")
  aggregatedData   Json?
  categorySummary  Json?
  tradeBreakdown   Json?
  duplicatesMerged Int                   @default(0)
  createdBy        String
  approvedBy       String?
  approvedAt       DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
