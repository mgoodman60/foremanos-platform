  objectKey         String    // Autodesk OSS object key
  urn               String    // Base64 encoded URN for Model Derivative
  status            String    @default("processing") // processing, complete, failed
  fileSize          Int?
  thumbnailUrl      String?
  uploadedBy        String
  metadata          Json?     // Extracted model metadata (BIM)
  extractedMetadata Json?     // DWG-specific extracted data (layers, blocks, text)
  lastExtractedAt   DateTime? // When extraction was last run
  fileType          String?   // dwg, dxf, rvt, ifc, etc.
  is2D              Boolean   @default(false) // True for 2D drawings (DWG)
  markups           Json?     // Markup annotations (replaces data/markups/ filesystem)
  measurements      Json?     // Measurement data (replaces data/measurements/ filesystem)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([uploadedBy])
  @@index([fileType])
}

// ============================================
// PHASE 2: FIELD OPERATIONS
// ============================================

// Daily Reports with weather, crew, and photo tracking
model DailyReport {
  id                String   @id @default(cuid())
  projectId         String
  reportDate        DateTime
  reportNumber      Int      // Sequential number per project
  status            DailyReportStatus @default(DRAFT)
  
  // Weather data
  weatherCondition  String?  // sunny, cloudy, rainy, etc.
  temperatureHigh   Float?
  temperatureLow    Float?
  humidity          Int?     // Percentage
  precipitation     Float?   // inches
  windSpeed         Float?   // mph
  weatherNotes      String?
  
  // Work summary
  workPerformed     String?
  workPlanned       String?
  delaysEncountered String?
  delayHours        Float?
  delayReason       String?
  
  // Safety
  safetyIncidents   Int      @default(0)
  safetyNotes       String?
  
  // Visitors
  visitors          Json?    // Array of {name, company, timeIn, timeOut}
  
  // Equipment
  equipmentOnSite   Json?    // Array of {name, hours, status}
  
  // Materials delivered
  materialsReceived Json?    // Array of {description, quantity, supplier}
  
  // Photos (references to Document IDs)
  photoIds          String[]
  
  // Timestamps
  createdBy         String
  submittedAt       DateTime?
  submittedBy       String?
  approvedAt        DateTime?
  approvedBy        String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser     User     @relation("DailyReportCreatedBy", fields: [createdBy], references: [id])
  laborEntries      DailyReportLabor[]
  equipmentEntries  DailyReportEquipment[]
  progressEntries   DailyReportProgress[]
  
  @@unique([projectId, reportDate])
  @@index([projectId])
  @@index([status])
  @@index([reportDate])
  @@index([createdBy])
}

enum DailyReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// Labor tracking per daily report
model DailyReportLabor {
  id            String      @id @default(cuid())
  reportId      String
  crewId        String?     // Link to existing Crew model
  budgetItemId  String?     // Link to budget line item for cost tracking
  tradeName     String      // e.g., "Electricians", "Plumbers"
  workerCount   Int
  regularHours  Float
  overtimeHours Float       @default(0)
  hourlyRate    Float       @default(0)     // Hourly rate for cost calculation
  overtimeRate  Float       @default(0)     // OT rate (typically 1.5x)
  totalCost     Float       @default(0)     // Calculated: (regular * rate) + (OT * OT rate)
  description   String?     // Work performed by this crew
  isSyncedToBudget Boolean  @default(false) // Has this been synced to budget actuals?
  syncedAt      DateTime?
  createdAt     DateTime    @default(now())
  
  report        DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  @@index([reportId])
  @@index([crewId])
  @@index([budgetItemId])
}

// Equipment usage tracking per daily report
model DailyReportEquipment {
  id            String      @id @default(cuid())
  reportId      String
  budgetItemId  String?     // Link to budget line item for cost tracking
  equipmentName String
  equipmentType String?     // Crane, Excavator, Generator, etc.
  hours         Float
  dailyRate     Float       @default(0)     // Daily rental rate
  hourlyRate    Float       @default(0)     // Hourly rate if applicable
  fuelCost      Float       @default(0)
  operatorCost  Float       @default(0)
  totalCost     Float       @default(0)     // Calculated total
  status        String?     // Operating, Idle, Down
  notes         String?
  isSyncedToBudget Boolean  @default(false)
  syncedAt      DateTime?
  createdAt     DateTime    @default(now())
  
  report        DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  @@index([reportId])
  @@index([budgetItemId])
}

// Work progress tracking - links daily work to schedule tasks
model DailyReportProgress {
  id              String      @id @default(cuid())
  reportId        String
  scheduleTaskId  String?     // Link to ScheduleTask
  budgetItemId    String?     // Link to budget item
  activityName    String      // Description of work activity
  location        String?     // Where work was performed
  unitsCompleted  Float       @default(0)   // Quantity completed today
  unitOfMeasure   String?     // SF, LF, EA, etc.
  percentComplete Float       @default(0)   // Progress percentage for this task
  previousPercent Float       @default(0)   // Previous progress
  valueEarned     Float       @default(0)   // Earned value for today's work
  notes           String?
  isSyncedToSchedule Boolean  @default(false)
  syncedAt        DateTime?
  createdAt       DateTime    @default(now())
  
  report          DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  @@index([reportId])
  @@index([scheduleTaskId])
  @@index([budgetItemId])
}

// Request for Information (RFI) Tracking
model RFI {
  id              String    @id @default(cuid())
  projectId       String
  rfiNumber       Int       // Sequential number per project
  title           String
  question        String    // The actual question/request
  status          RFIStatus @default(OPEN)
  priority        RFIPriority @default(NORMAL)
  
  // Assignment
  assignedTo      String?   // User ID of assignee
  assignedToName  String?   // Name for display
  assignedToEmail String?   // Email for notifications
  
  // Related items
  specSection     String?   // Spec section reference
  drawingRef      String?   // Drawing reference
  documentIds     String[]  // Related document IDs
  
  // Response
  response        String?
  respondedBy     String?
  respondedAt     DateTime?
  
  // Impact assessment
  costImpact      Float?
  scheduleImpact  Int?      // Days
  impactNotes     String?
  
  // Ball in court - who needs to act
  ballInCourt     String?
  
  // Dates
  dueDate         DateTime?
  closedAt        DateTime?
  closedBy        String?
  
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser   User      @relation("RFICreatedBy", fields: [createdBy], references: [id])
  comments        RFIComment[]
  
  @@unique([projectId, rfiNumber])
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([createdBy])
}

enum RFIStatus {
  OPEN
  PENDING_RESPONSE
  RESPONDED
  CLOSED
  VOID
}

enum RFIPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model RFIComment {
  id        String   @id @default(cuid())
  rfiId     String
  content   String
  createdBy String
  createdAt DateTime @default(now())
  
  rfi       RFI      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [createdBy], references: [id])
  
  @@index([rfiId])
  @@index([createdBy])
}

// Punch List Items
model PunchListItem {
  id            String          @id @default(cuid())
  projectId     String
  itemNumber    Int             // Sequential per project
  title         String
  description   String?
  status        PunchListStatus @default(OPEN)
  priority      PunchListPriority @default(NORMAL)
  
  // Location
  location      String?         // Room/area description
  floor         String?
  room          String?
  
  // Assignment
  assignedTo    String?         // Subcontractor or user
  assignedToName String?
  trade         TradeType?
  
  // Category
  category      PunchListCategory @default(GENERAL)
  
  // Photos
  photoIds      String[]        // Before photos
  completionPhotoIds String[]   // After photos
  
  // Dates
  dueDate       DateTime?
  completedAt   DateTime?
  completedBy   String?
  verifiedAt    DateTime?
  verifiedBy    String?
  
  // Notes
  notes         String?
  completionNotes String?
  
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser User            @relation("PunchListCreatedBy", fields: [createdBy], references: [id])
  
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([category])
  @@index([dueDate])
}

enum PunchListStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  VERIFIED
  REJECTED
  VOID
}

enum PunchListPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum PunchListCategory {
  GENERAL
  SAFETY
  QUALITY
  INCOMPLETE_WORK
  DAMAGED
  DEFECTIVE
  CODE_VIOLATION
  DESIGN_CHANGE
}

// Project Health Snapshots - stored periodically for trends
model ProjectHealthSnapshot {
  id            String   @id @default(cuid())
  projectId     String
  
  // Overall score (0-100)
  overallScore  Float
  
  // Component scores
  scheduleScore Float    // On-time performance
  budgetScore   Float    // Budget adherence
  safetyScore   Float    // Safety incident rate
  qualityScore  Float    // Punch list / RFI resolution
  documentScore Float    // Documentation completeness
  
  // Raw metrics at time of snapshot
  metrics       Json     // Detailed breakdown
  
  // Trends
  trend         String?  // 'improving', 'stable', 'declining'
  changeFromPrevious Float? // Delta from last snapshot
  
  createdAt     DateTime @default(now())
  
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([createdAt])
}


// ============================================
// MEP TRACKING MODELS
// ============================================

// MEP System - Grouping of equipment by system
model MEPSystem {
  id            String          @id @default(cuid())
  projectId     String
  
  // System identification
  systemNumber  String          // SYS-001
  name          String          // "HVAC System - Zone 1"
  systemType    MEPSystemType
  
  // Description
  description   String?
  designCapacity String?        // "50 ton", "200 amp"
  
  // Location
  servingArea   String?         // "Building A - Floors 1-3"
  mainLocation  String?         // Equipment room location
  
  // Status
  status        MEPSystemStatus @default(DESIGN)
  
  // Design data (can be auto-populated from BIM)
  designData    Json?           // Load calculations, sizing
  bimModelUrn   String?         // Source BIM model
  
  // Dates
  plannedInstallStart DateTime?
  plannedInstallEnd   DateTime?
  actualInstallStart  DateTime?
  actualInstallEnd    DateTime?
  commissioningDate   DateTime?
  
  // Contractor
  installingContractor String?
  contractorContact    String?
  
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser User            @relation("MEPSystemCreatedBy", fields: [createdBy], references: [id])
  equipment     MEPEquipment[]
  submittals    MEPSubmittal[]
  maintenanceSchedules MEPMaintenanceSchedule[]
  loadCalculations MEPLoadCalculation[]
  
  @@unique([projectId, systemNumber])
  @@index([projectId])
  @@index([systemType])
  @@index([status])
}

enum MEPSystemType {
  HVAC
  ELECTRICAL
  PLUMBING
  FIRE_PROTECTION
  CONTROLS
  LOW_VOLTAGE
  SPECIALTY
}

enum MEPSystemStatus {
  DESIGN
  SUBMITTAL
  FABRICATION
  ROUGH_IN
  INSTALLATION
  TESTING
  COMMISSIONING
  OPERATIONAL
  DEFICIENT
}

// MEP Equipment - Individual pieces of equipment
model MEPEquipment {
  id            String          @id @default(cuid())
  projectId     String
  systemId      String?
  
  // Equipment identification
  equipmentTag  String          // "AHU-1", "MDP-A"
  name          String          // "Air Handling Unit 1"
  equipmentType MEPEquipmentType
  
  // Specifications
  manufacturer  String?
  model         String?
  serialNumber  String?
  capacity      String?         // "10 ton", "100 amp"
  specifications Json?          // Detailed specs
  
  // Location
  level         String?
  room          String?
  gridLocation  String?         // "A-3"
  
  // BIM Integration
  bimDbId       Int?            // Autodesk viewer element ID
  bimExternalId String?
  bimModelUrn   String?
  extractedFromBIM Boolean      @default(false)
  
  // Status
  status        MEPEquipmentStatus @default(SPECIFIED)
  
  // Dates
  submittalDue     DateTime?
  submittalApproved DateTime?
  deliveryDate     DateTime?
  installationDate DateTime?
  startupDate      DateTime?
  
  // Cost tracking
  estimatedCost    Float?
  actualCost       Float?
  
  // Warranty
  warrantyExpires  DateTime?
  warrantyNotes    String?
  
  // Installation contractor
  installedBy      String?
  
  // Notes
  notes         String?
  
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  system        MEPSystem?      @relation(fields: [systemId], references: [id])
  createdByUser User            @relation("MEPEquipmentCreatedBy", fields: [createdBy], references: [id])
  submittals    MEPSubmittal[]
  maintenanceSchedules MEPMaintenanceSchedule[]
  
  @@unique([projectId, equipmentTag])
  @@index([projectId])
  @@index([systemId])
  @@index([equipmentType])
  @@index([status])
  @@index([bimDbId])
}

enum MEPEquipmentType {
  // HVAC
  AHU
  RTU
  CHILLER
  BOILER
  PUMP_HVAC
  FAN
  VAV_BOX
  FCU
  EXHAUST_FAN
  DAMPER
  // Electrical
  TRANSFORMER
  SWITCHGEAR
  MDP
  PANEL
  DISCONNECT
  VFD
  GENERATOR
  UPS
  LIGHTING_FIXTURE
  // Plumbing
  WATER_HEATER
  PUMP_PLUMBING
  FIXTURE
  BACKFLOW
  PRV
  // Fire Protection
  FIRE_PUMP
  SPRINKLER_HEAD
  FIRE_ALARM_PANEL
  SMOKE_DETECTOR
  // Other
  CONTROLS
  SENSOR
  METER
  OTHER
}

enum MEPEquipmentStatus {
  SPECIFIED
  SUBMITTAL_PENDING
  SUBMITTAL_APPROVED
  ORDERED
  DELIVERED
  STAGED
  INSTALLED
  CONNECTED
  TESTED
  OPERATIONAL
  DEFICIENT
  REPLACED
}

// MEP Submittals - Equipment approval tracking
model MEPSubmittal {
  id            String          @id @default(cuid())
  projectId     String
  systemId      String?
  equipmentId   String?
  
  // Submittal identification
  submittalNumber String        // "SUB-MEP-001"
  title         String
  
  // Type
  submittalType MEPSubmittalType
  specSection   String?         // "23 05 00"
  
  // Status tracking
  status        MEPSubmittalStatus @default(PENDING)
  
  // Dates
  dueDate       DateTime?
  submittedDate DateTime?
  reviewedDate  DateTime?
  approvedDate  DateTime?
  resubmitDue   DateTime?
  
  // Review
  reviewer      String?
  reviewerName  String?
  reviewComments String?
  stampStatus   String?         // "Approved", "Approved as Noted", "Revise and Resubmit", "Rejected"
  
  // Documents
  documentIds   String[]        // Uploaded submittal docs
  responseDocIds String[]       // Reviewer response docs
  
  // Revision tracking
  revision      Int             @default(0)
  previousSubmittalId String?
  
  // Contractor
  submittedBy   String?         // Subcontractor name
  contactEmail  String?
  
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  system        MEPSystem?      @relation(fields: [systemId], references: [id])
  equipment     MEPEquipment?   @relation(fields: [equipmentId], references: [id])
  createdByUser User            @relation("MEPSubmittalCreatedBy", fields: [createdBy], references: [id])
  lineItems     SubmittalLineItem[]
  verificationLogs VerificationAuditLog[]
  approvalHistory SubmittalApprovalHistory[]
  
  @@unique([projectId, submittalNumber])
  @@index([projectId])
  @@index([systemId])
  @@index([equipmentId])
  @@index([status])
  @@index([dueDate])
}

enum MEPSubmittalType {
  PRODUCT_DATA
  SHOP_DRAWINGS
  SAMPLES
  CALCULATIONS
  TEST_REPORTS
  CERTIFICATIONS
  WARRANTIES
  O_AND_M_MANUALS
  AS_BUILTS
}

enum MEPSubmittalStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  APPROVED_AS_NOTED
  REVISE_RESUBMIT
  REJECTED
  VOID
}

// =============================================================================
// SUBMITTAL LINE ITEMS & QUANTITY VERIFICATION
// =============================================================================

// Individual products/materials within a submittal
model SubmittalLineItem {
  id                String              @id @default(cuid())
  submittalId       String
  
  // Product identification
  productName       String              // "Mortise Lockset Model 8200"
  manufacturer      String?             // "Schlage"
  modelNumber       String?             // "L9453P 06A 626"
  partNumber        String?             // Manufacturer part number
  
  // Quantities
  submittedQty      Float               // What contractor is submitting
  requiredQty       Float?              // What project requires (calculated)
  unit              String              // EA, SET, LF, SF, etc.
  unitPrice         Float?              // Optional cost tracking
  
  // Categorization
  csiDivision       String?             // "08 71 00"
  csiTitle          String?             // "Door Hardware"
  specSection       String?             // Spec section reference
  tradeCategory     String?             // "doors", "plumbing", "electrical", etc.
  
  // Cross-reference linkage
  linkedSourceType  String?             // "door_schedule", "takeoff", "mep_equipment", "window_schedule", "finish_schedule"
  linkedSourceIds   String[]            // IDs of linked items (doors, equipment, etc.)
  hardwareSetId     String?             // Link to HardwareSetDefinition if applicable
  
  // Compliance tracking
  complianceStatus  QuantityComplianceStatus @default(UNVERIFIED)
  varianceQty       Float?              // submittedQty - requiredQty
  variancePercent   Float?              // (variance / required) * 100
  
  // Verification
  verifiedAt        DateTime?
  verifiedBy        String?
  verificationNotes String?
  
  // Metadata
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  submittal         MEPSubmittal        @relation(fields: [submittalId], references: [id], onDelete: Cascade)
  hardwareSet       HardwareSetDefinition? @relation(fields: [hardwareSetId], references: [id])
  overrides         ManualOverride[]
  
  @@index([submittalId])
  @@index([complianceStatus])
  @@index([tradeCategory])
  @@index([linkedSourceType])
}

enum QuantityComplianceStatus {
  UNVERIFIED        // Not yet checked
  SUFFICIENT        // Submitted >= Required
  INSUFFICIENT      // Submitted < Required (SHORTAGE)
  EXCESS            // Submitted significantly > Required (may need review)
  PARTIAL_MATCH     // Some items match, some don't
  NO_REQUIREMENT    // No project data to compare against
}

// Hardware set definitions extracted from door/window schedules and specs
model HardwareSetDefinition {
  id                String              @id @default(cuid())
  projectId         String
  
  // Set identification
  setNumber         String              // "1", "HS-A", "HW-01"
  setName           String?             // "Entry Hardware - ADA Compliant"
  description       String?             // Full description
  
  // Components (JSON array)
  // [{ type: "HINGES", spec: "4-1/2 x 4-1/2 Ball Bearing", qtyPerDoor: 3, manufacturer: "Hager", model: "BB1279" }]
  components        Json                @default("[]")
  
  // Usage counts (calculated from schedules)
  doorCount         Int                 @default(0)  // How many doors use this set
  windowCount       Int                 @default(0)  // How many windows use this set (if applicable)
  
  // Source tracking
  sourceDocumentId  String?
  sourceType        String?             // "door_schedule", "spec_section", "manual"
  specSection       String?             // "08 71 00"
  
  // Fire/Rating requirements
  fireRated         Boolean             @default(false)
  fireRating        String?             // "20 MIN", "45 MIN", etc.
  adaCompliant      Boolean             @default(false)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceDocument    Document?           @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  lineItems         SubmittalLineItem[]
  
  @@unique([projectId, setNumber])
  @@index([projectId])
}

// Aggregated quantity requirements from all project sources
model QuantityRequirement {
  id                String              @id @default(cuid())
  projectId         String
  
  // Item identification
  itemName          String              // "Mortise Lockset", "3'-0\" x 7'-0\" HM Door"
  itemCategory      String              // "door_hardware", "doors", "windows", "plumbing_fixtures"
  csiDivision       String?             // "08 71 00"
  specSection       String?
  
  // Quantity
  requiredQty       Float
  unit              String              // EA, SET, LF, SF
  
  // Source tracking (where requirement came from)
  sourceType        String              // "door_schedule", "window_schedule", "takeoff", "mep_equipment", "manual"
  sourceIds         String[]            // IDs of source records
  sourceDescription String?             // Human-readable source, e.g., "15 doors with Hardware Set 1"
  
  // Submittal tracking
  submittedQty      Float               @default(0)  // Total submitted across all submittals
  approvedQty       Float               @default(0)  // Total approved
  
  // Status
  status            RequirementStatus   @default(PENDING)
  lastVerifiedAt    DateTime?
  
  // Metadata
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, itemName, itemCategory, sourceType])
  @@index([projectId])
  @@index([itemCategory])
  @@index([status])
}

enum RequirementStatus {
  PENDING           // Awaiting submittal
  PARTIALLY_SUBMITTED // Some qty submitted
  FULLY_SUBMITTED   // All qty submitted
  APPROVED          // Submittal approved
  INSUFFICIENT      // Not enough submitted
}

// =============================================================================
// VERIFICATION AUDIT TRAIL
// =============================================================================

// Tracks every verification run with results snapshot
// Submittal Approval History
model SubmittalApprovalHistory {
  id            String   @id @default(cuid())
  submittalId   String
  action        String   // SUBMITTED, REVIEWED, APPROVED, REJECTED, RESUBMITTED
  fromStatus    String?
  toStatus      String
  performedBy   String
  performerName String?
  comments      String?
  createdAt     DateTime @default(now())
  
  submittal     MEPSubmittal @relation(fields: [submittalId], references: [id], onDelete: Cascade)
  user          User         @relation("ApprovalHistoryUser", fields: [performedBy], references: [id])
  
  @@index([submittalId])
  @@index([performedBy])
  @@index([createdAt])
}

model VerificationAuditLog {
  id                String              @id @default(cuid())
  projectId         String
  submittalId       String?             // Null for bulk verifications
  
  // Verification details
  verificationType  VerificationType    // SINGLE_SUBMITTAL, BULK_PROJECT
  triggeredBy       String              // User ID who triggered
  triggeredByName   String?             // User name for display
  triggerReason     String?             // "manual", "auto_data_change", "scheduled"
  
  // Results snapshot (JSON)
  // { totalItems: 10, sufficient: 7, insufficient: 2, excess: 1, noRequirement: 0 }
  resultsSummary    Json                @default("{}")
  
  // Detailed results (JSON array of line item results)
  lineItemResults   Json                @default("[]")
  
  // Status
  overallStatus     VerificationOverallStatus
  
  // Timing
  startedAt         DateTime            @default(now())
  completedAt       DateTime?
  durationMs        Int?                // Processing time
  
  // Notes
  notes             String?
  
  createdAt         DateTime            @default(now())
  
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittal         MEPSubmittal?       @relation(fields: [submittalId], references: [id], onDelete: SetNull)
  overrides         ManualOverride[]
  
  @@index([projectId])
  @@index([submittalId])
  @@index([triggeredBy])
  @@index([createdAt])
}

enum VerificationType {
  SINGLE_SUBMITTAL    // Single submittal verification
  BULK_PROJECT        // Project-wide verification
  RE_VERIFICATION     // Auto-triggered re-verification
}

enum VerificationOverallStatus {
  PASS                // All items sufficient
  FAIL                // Has critical shortages
  REVIEW_NEEDED       // Has excess or partial matches
  INCOMPLETE          // Verification did not complete
}

// Manual override tracking for auditing
model ManualOverride {
  id                String              @id @default(cuid())
  projectId         String
  lineItemId        String?             // Which line item was overridden
  verificationLogId String?             // Which verification run
  
  // Override details
  overrideType      OverrideType
  previousStatus    QuantityComplianceStatus
  newStatus         QuantityComplianceStatus
  previousQty       Float?              // Original required qty
  newQty            Float?              // Overridden required qty
  
  // Who and why
  overriddenBy      String              // User ID
  overriddenByName  String?
  justification     String              // Required reason
  
  // Supporting docs
  documentIds       String[]            // Any attached docs
  
  // Approval
  approved          Boolean             @default(false)
  approvedBy        String?
  approvedByName    String?
  approvedAt        DateTime?
  approvalNotes     String?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItem          SubmittalLineItem?  @relation(fields: [lineItemId], references: [id], onDelete: SetNull)
  verificationLog   VerificationAuditLog? @relation(fields: [verificationLogId], references: [id], onDelete: SetNull)
  
  @@index([projectId])
  @@index([lineItemId])
  @@index([overriddenBy])
  @@index([createdAt])
}

enum OverrideType {
  STATUS_CHANGE       // Changed compliance status
  QUANTITY_ADJUSTMENT // Adjusted required quantity
  WAIVER              // Waived requirement entirely
  SUBSTITUTION        // Substituted different product
}

// Verification Tolerance Settings - per project configuration
model VerificationToleranceSettings {
  id                  String    @id @default(cuid())
  projectId           String    @unique
  
  // Shortage tolerance (items below requirement)
  shortagePercent     Float     @default(0)   // Allow X% under (e.g., 5 = 95% is OK)
  shortageAbsolute    Int       @default(0)   // Allow X units under
  
  // Excess tolerance (items above requirement)
  excessPercent       Float     @default(100) // Allow X% over (e.g., 100 = up to 200%)
  excessAbsolute      Int       @default(100) // Allow X units over
  
  // Auto-reverification settings
  autoReverifyEnabled Boolean   @default(true)
  reverifyOnRequirementChange Boolean @default(true)
  reverifyOnSubmittalChange   Boolean @default(true)
  
  // Trade-specific tolerances (JSON)
  // { "ELECTRICAL": { shortagePercent: 0 }, "PLUMBING": { shortagePercent: 5 } }
  tradeTolerances     Json      @default("{}")
  
  // Updated tracking
  updatedBy           String?
  updatedAt           DateTime  @updatedAt
  createdAt           DateTime  @default(now())
  
  // Relations
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
}

// MEP Maintenance Schedule - PM tracking
model MEPMaintenanceSchedule {
  id            String          @id @default(cuid())
  projectId     String
  systemId      String?
  equipmentId   String?
  
  // Schedule identification
  scheduleNumber String         // "PM-001"
  name          String          // "Quarterly Filter Change - AHU-1"
  
  // Frequency
  frequency     MaintenanceFrequency
  intervalDays  Int?            // For custom intervals
  
  // Task details
  taskDescription String?
  checklist     Json?           // Array of checklist items
  estimatedDuration Int?        // Minutes
  
  // Assignment
  assignedTo    String?
  assignedContractor String?
  
  // Schedule dates
  startDate     DateTime
  nextDueDate   DateTime
  lastCompletedDate DateTime?
  
  // Status
  isActive      Boolean         @default(true)
  
  // Compliance
  regulatoryRequired Boolean    @default(false)
  regulatoryCode     String?
  
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  system        MEPSystem?      @relation(fields: [systemId], references: [id])
  equipment     MEPEquipment?   @relation(fields: [equipmentId], references: [id])
  createdByUser User            @relation("MEPMaintenanceCreatedBy", fields: [createdBy], references: [id])
  logs          MEPMaintenanceLog[]
  
  @@index([projectId])
  @@index([systemId])
  @@index([equipmentId])
  @@index([nextDueDate])
  @@index([isActive])
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  CUSTOM
}

// Maintenance completion logs
model MEPMaintenanceLog {
  id            String          @id @default(cuid())
  scheduleId    String
  
  // Completion details
  completedDate DateTime
  completedBy   String
  completedByName String?
  
  // Results
  status        MaintenanceLogStatus @default(COMPLETED)
  notes         String?
  findings      String?
  deficienciesFound Boolean     @default(false)
  
  // Photos
  photoIds      String[]
  
  // Time tracking
  actualDuration Int?           // Minutes
  
  createdAt     DateTime        @default(now())
  
  schedule      MEPMaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  @@index([scheduleId])
  @@index([completedDate])
}

enum MaintenanceLogStatus {
  COMPLETED
  PARTIAL
  DEFERRED
  ISSUE_FOUND
}

// MEP Load Calculations
model MEPLoadCalculation {
  id            String          @id @default(cuid())
  projectId     String
  systemId      String?
  
  // Calculation identification
  calcNumber    String          // "CALC-E-001"
  name          String          // "Electrical Load Schedule - Panel A"
  calcType      LoadCalculationType
  
  // Results
  designLoad    Float?          // Primary result (kW, BTU, GPM, etc.)
  unit          String?         // "kW", "tons", "CFM", "GPM"
  
  // Diversity/demand factors
  connectedLoad Float?
  demandFactor  Float?          // 0.0 to 1.0
  diversityFactor Float?
  safetyFactor  Float?          @default(1.15)
  
  // Breakdown by category
  breakdown     Json?           // Array of load items
  
  // Assumptions
  assumptions   String?
  
  // BIM derived
  extractedFromBIM Boolean      @default(false)
  bimModelUrn   String?
  
  // Status
  status        CalcStatus      @default(DRAFT)
  
  // Review
  preparedBy    String?
  reviewedBy    String?
  approvedDate  DateTime?
  
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  system        MEPSystem?      @relation(fields: [systemId], references: [id])
  createdByUser User            @relation("MEPLoadCalcCreatedBy", fields: [createdBy], references: [id])
  
  @@unique([projectId, calcNumber])
  @@index([projectId])
  @@index([systemId])
  @@index([calcType])
}

enum LoadCalculationType {
  ELECTRICAL_DEMAND
  ELECTRICAL_PANEL_SCHEDULE
  HVAC_HEATING_LOAD
  HVAC_COOLING_LOAD
  PLUMBING_FIXTURE_UNITS
  PLUMBING_WATER_DEMAND
  FIRE_WATER_DEMAND
}

enum CalcStatus {
  DRAFT
  FOR_REVIEW
  APPROVED
  SUPERSEDED
}
// ============================================
// PHASE 4: SCHEDULE & BUDGET ENHANCEMENTS
// ============================================

// Milestones - Key project dates
model Milestone {
  id              String          @id @default(uuid())
  projectId       String
  
  name            String
  description     String?
  
  // Dates
  plannedDate     DateTime
  forecastDate    DateTime?
  actualDate      DateTime?
  baselineDate    DateTime?       // Original planned date
  
  // Status
  status          MilestoneStatus @default(UPCOMING)
  
  // Financial
  paymentLinked   Boolean         @default(false)
  paymentAmount   Float?
  
  // Classification
  category        MilestoneCategory @default(PROJECT)
  isCritical      Boolean         @default(false)
  
  // Dependencies
  linkedTaskIds   String[]
  predecessorIds  String[]
  
  // Notes
  notes           String?
  
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser   User            @relation("MilestoneCreatedBy", fields: [createdBy], references: [id])
  
  @@index([projectId])
  @@index([status])
  @@index([plannedDate])
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  AT_RISK
  DELAYED
  MISSED
}

enum MilestoneCategory {
  PROJECT          // Project-level milestones
  PHASE            // Phase completion
  PERMIT           // Permits/inspections
  SUBMITTAL        // Key submittals
  PROCUREMENT      // Procurement milestones
  PAYMENT          // Payment milestones
  REGULATORY       // Code/regulatory
  CLIENT           // Client reviews/approvals
  SUBSTANTIAL_COMPLETION
  FINAL_COMPLETION
}

// Payment Applications (Pay Apps)
model PaymentApplication {
  id                String              @id @default(uuid())
  projectId         String
  budgetId          String?
  
  // Identification
  applicationNumber Int
  periodStart       DateTime
  periodEnd         DateTime
  
  // Values
  scheduledValue    Float               // Total contract value
  previouslyApproved Float              @default(0)
  currentPeriod     Float               @default(0)
  totalCompleted    Float               @default(0)
  retainage         Float               @default(0)
  retainagePercent  Float               @default(10)
  netDue            Float               @default(0)
  
  // Status tracking
  status            PayAppStatus        @default(DRAFT)
  submittedAt       DateTime?
  reviewedAt        DateTime?
  approvedAt        DateTime?
  paidAt            DateTime?
  
  // Review
  reviewedBy        String?
  approvedBy        String?
  rejectionReason   String?
  
  // Supporting docs
  supportingDocs    String[]
  
  createdBy         String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budget            ProjectBudget?      @relation(fields: [budgetId], references: [id])
  createdByUser     User                @relation("PayAppCreatedBy", fields: [createdBy], references: [id])
  items             PaymentApplicationItem[]
  contractPayments  ContractPayment[]
  
  @@unique([projectId, applicationNumber])
  @@index([projectId])
  @@index([status])
}

enum PayAppStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUIRED
  APPROVED
  PARTIALLY_PAID
  PAID
  REJECTED
}

// Payment Application Line Items
model PaymentApplicationItem {
  id                String            @id @default(uuid())
  paymentAppId      String
  budgetItemId      String?
  
  // Cost code reference
  costCode          String?
  description       String
  
  // Values (AIA G702/G703 format)
  scheduledValue    Float
  fromPreviousApp   Float             @default(0)
  thisApplication   Float             @default(0)
  materialsStored   Float             @default(0)
  totalCompleted    Float             @default(0)
  percentComplete   Float             @default(0)
  balanceToFinish   Float
  retainage         Float             @default(0)
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  paymentApp        PaymentApplication @relation(fields: [paymentAppId], references: [id], onDelete: Cascade)
  budgetItem        BudgetItem?       @relation(fields: [budgetItemId], references: [id])
  
  @@index([paymentAppId])
  @@index([budgetItemId])
}

// Cash Flow Forecast
model CashFlowForecast {
  id              String          @id @default(uuid())
  projectId       String
  
  // Period
  periodDate      DateTime
  periodType      String          @default("MONTHLY") // WEEKLY, MONTHLY
  
  // Inflows (Income)
  plannedInflow   Float           @default(0)
  actualInflow    Float           @default(0)
  forecastInflow  Float           @default(0)
  
  // Outflows (Expenses)
  plannedOutflow  Float           @default(0)
  actualOutflow   Float           @default(0)
  forecastOutflow Float           @default(0)
  
  // Net Cash
  plannedNet      Float           @default(0)
  actualNet       Float           @default(0)
  forecastNet     Float           @default(0)
  
  // Cumulative
  cumulativePlanned Float         @default(0)
  cumulativeActual  Float         @default(0)
  cumulativeForecast Float        @default(0)
  
  // Notes
  notes           String?
  isLocked        Boolean         @default(false)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@unique([projectId, periodDate, periodType])
  @@index([projectId])
  @@index([periodDate])
}

// Procurement Tracking
model Procurement {
  id              String            @id @default(uuid())
  projectId       String
  budgetItemId    String?
  
  // Identification
  procurementNumber String
  description     String
  
  // Item details
  itemType        ProcurementType
  specifications  String?
  quantity        Float?
  unit            String?
  
  // Vendor
  vendorId        String?
  vendorName      String?
  vendorContact   String?
  
  // Dates
  requiredDate    DateTime?         // When needed on site
  leadTime        Int?              // Lead time in days
  orderDate       DateTime?
  expectedDelivery DateTime?
  actualDelivery  DateTime?
  
  // Financial
  budgetedCost    Float?
  quotedCost      Float?
  actualCost      Float?
  purchaseOrder   String?
  
  // Status
  status          ProcurementStatus @default(IDENTIFIED)
  
  // Tracking
  trackingNumber  String?
  warehouse       String?
  
  // Notes
  notes           String?
  
  createdBy       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetItem      BudgetItem?       @relation(fields: [budgetItemId], references: [id])
  vendor          Subcontractor?    @relation(fields: [vendorId], references: [id])
  createdByUser   User              @relation("ProcurementCreatedBy", fields: [createdBy], references: [id])
  
  @@unique([projectId, procurementNumber])
  @@index([projectId])
  @@index([status])
  @@index([requiredDate])
}

enum ProcurementType {
  EQUIPMENT
  MATERIAL
  LONG_LEAD_ITEM
  SPECIALTY_ITEM
  OWNER_FURNISHED
}

enum ProcurementStatus {
  IDENTIFIED
  SPEC_REVIEW
  BIDDING
  AWARDED
  ORDERED
  IN_TRANSIT
  RECEIVED
  INSTALLED
  CANCELLED
}

// Schedule Baseline
model ScheduleBaseline {
  id              String          @id @default(uuid())
  scheduleId      String
  
  // Baseline info
  baselineNumber  Int
  name            String
  description     String?
  
  // Snapshot date
  capturedAt      DateTime        @default(now())
  
  // Metrics at baseline
  totalDuration   Int             // Total project duration in days
  criticalPathDays Int            // Critical path length
  totalFloat      Int?            // Total float days
  
  // Task snapshot
  taskSnapshot    Json            // Array of task states at baseline
  
  // Summary
  totalTasks      Int
  milestonesCount Int
  
  isActive        Boolean         @default(true)
  
  createdBy       String
  createdAt       DateTime        @default(now())
  
  schedule        Schedule        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdByUser   User            @relation("BaselineCreatedBy", fields: [createdBy], references: [id])
  
  @@unique([scheduleId, baselineNumber])
  @@index([scheduleId])
}

// Resource Allocation
model ResourceAllocation {
  id              String          @id @default(uuid())
  projectId       String
  taskId          String?
  
  // Resource info
  resourceType    ResourceType
  resourceName    String
  
  // Allocation
  allocatedUnits  Float           @default(1)
  maxUnits        Float           @default(1)
  
  // Time
  startDate       DateTime
  endDate         DateTime
  hoursPerDay     Float           @default(8)
  
  // Cost
  costRate        Float?          // Cost per hour
  totalCost       Float?
  
  // Status
  isOverallocated Boolean         @default(false)
  utilizationPercent Float        @default(100)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            ScheduleTask?   @relation(fields: [taskId], references: [id])
  
  @@index([projectId])
  @@index([taskId])
  @@index([resourceType])
}

enum ResourceType {
  LABOR
  EQUIPMENT
  MATERIAL
  SUBCONTRACTOR
}

// Schedule Forecast
model ScheduleForecast {
  id                String        @id @default(uuid())
  projectId         String
  scheduleId        String?
  
  // Forecast date
  forecastDate      DateTime      @default(now())
  
  // Metrics
  projectedEndDate  DateTime
  originalEndDate   DateTime
  varianceDays      Int           // Positive = delay
  
  // Performance indices
  schedulePerformanceIndex Float  @default(1.0)  // SPI
  completionConfidence Float      @default(80)   // Confidence %
  
  // Risk assessment
  riskLevel         String        @default("MEDIUM") // LOW, MEDIUM, HIGH
  riskFactors       Json?         // Array of risk factors
  
  // Recovery
  recoveryActions   Json?         // Recommended actions
  
  // Method
  forecastMethod    String        @default("TRENDING") // TRENDING, SIMULATION, EXPERT
  
  notes             String?
  
  createdAt         DateTime      @default(now())
  
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  schedule          Schedule?     @relation(fields: [scheduleId], references: [id])
  
  @@index([projectId])
  @@index([scheduleId])
  @@index([forecastDate])
}

// Track data sources for project features with confidence levels
model ProjectDataSource {
  id            String   @id @default(cuid())
  projectId     String
  documentId    String?
  featureType   String   // scale, dimensions, rooms, doors, mep_electrical, etc.
  sourceType    String   // dwg, rvt, pdf_cad, pdf_scan, xlsx, manual
  confidence    Int      // 0-100 based on source type
  metadata      Json?    // Additional extraction data
  extractedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  Project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Document      Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  
  @@unique([projectId, featureType])
  @@index([projectId])
  @@index([featureType])
}

// Door schedule items extracted from door schedules in construction documents
model DoorScheduleItem {
  id              String   @id @default(cuid())
  projectId       String
  roomId          String?  // Optional link to room
  
  // Door identification
  doorNumber      String   // e.g., "001A", "101", "EXT-1"
  doorMark        String?  // Mark/type code from schedule, e.g., "A", "B", "C"
  doorType        String   // Full type description, e.g., "Hollow Metal", "Wood", "Aluminum Storefront"
  
  // Room association
  roomNumber      String?  // Room number the door serves
  fromRoom        String?  // Room on one side
  toRoom          String?  // Room on other side (for corridor doors)
  
  // Physical specs
  width           String?  // Width dimension, e.g., "3'-0\""
  height          String?  // Height dimension, e.g., "7'-0\""
  thickness       String?  // Door thickness
  
  // Materials
  frameMaterial   String?  // "HM" (Hollow Metal), "WD" (Wood), "AL" (Aluminum)
  frameType       String?  // Frame type code
  doorMaterial    String?  // Door leaf material
  glazing         String?  // Glass type if applicable
  
  // Hardware
  hardwareSet     String?  // Hardware set number/code
  hinges          String?  // Hinge type/count
  lockset         String?  // Lock type
  closer          String?  // Door closer
  
  // Fire rating
  fireRating      String?  // "20 MIN", "45 MIN", "60 MIN", "90 MIN"
  smokeRating     Boolean  @default(false)
  
  // Other
  louver          Boolean  @default(false)
  kickplate       Boolean  @default(false)
  weatherstrip    Boolean  @default(false)
  threshold       String?  // Threshold type
  
  // Source tracking
  sourceDocumentId String?
  sourceSheetNumber String?
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  Project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Room            Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  Document        Document? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  
  @@unique([projectId, doorNumber])
  @@index([projectId])
  @@index([roomId])
  @@index([roomNumber])
}


// Window Schedule Model
model WindowScheduleItem {
  id              String   @id @default(cuid())
  projectId       String
  roomId          String?  // Optional link to room
  
  // Window identification
  windowNumber    String   // e.g., "W-1", "W-2A", "SK-1"
  windowMark      String?  // Type/mark code from schedule
  windowType      String   // Full type description
  
  // Room association
  roomNumber      String?  // Room number the window serves
  elevation       String?  // N, S, E, W or specific elevation ref
  
  // Physical dimensions
  width           String?  // Width dimension, e.g., "3'-0\""
  height          String?  // Height dimension, e.g., "4'-0\""
  roughOpeningW   String?  // Rough opening width
  roughOpeningH   String?  // Rough opening height
  sillHeight      String?  // Height from floor to sill
  headHeight      String?  // Height to head
  
  // Materials and components
  frameMaterial   String?  // Aluminum, Vinyl, Wood, etc.
  frameFinish     String?  // Anodized, painted color, etc.
  glazingType     String?  // Single, Double, Triple pane
  glassType       String?  // Clear, Low-E, Tinted, etc.
  glassThickness  String?  // Glass thickness
  uValue          Float?   // Thermal performance
  shgc            Float?   // Solar Heat Gain Coefficient
  
  // Operation type
  operationType   String?  // Fixed, Casement, Double-hung, Sliding, Awning
  
  // Hardware
  hardwareFinish  String?  // Hardware finish/color
  screenType      String?  // Full, half, none
  
  // Fire and code
  fireRating      String?  // If applicable
  egressCompliant Boolean  @default(false)
  
  // Manufacturer
  manufacturer    String?
  modelNumber     String?
  
  // Source tracking
  sourceDocumentId String?
  sourceSheetNumber String?
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  Project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Room            Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  Document        Document? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  
  @@unique([projectId, windowNumber])
  @@index([projectId])
  @@index([roomId])
  @@index([roomNumber])
}

// Schedule Prediction for ML-based forecasting
model SchedulePrediction {
  id              String   @id @default(cuid())
  projectId       String
  
  // Prediction target
  taskId          String?  // Specific task being predicted
  milestoneId     String?  // Or milestone
  predictedDate   DateTime // Predicted completion date
  confidenceLevel Float    // 0-100% confidence
  
  // Factors considered
  weatherImpact   Float?   // Days of impact from weather
  laborImpact     Float?   // Days of impact from labor issues
  supplyImpact    Float?   // Days of impact from supply chain
  historicalVariance Float? // Historical variance for similar tasks
  
  // Prediction metadata
  modelVersion    String   // Version of prediction model used
  inputFeatures   Json?    // Features used for prediction
  riskFactors     Json?    // Identified risk factors
  
  // Outcome tracking
  actualDate      DateTime? // Actual completion date (for model training)
  accuracy        Float?    // How accurate was the prediction
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  Project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([predictedDate])
}

// Spec Compliance Check Results
model SpecComplianceCheck {
  id              String   @id @default(cuid())
  projectId       String
  
  // What was checked
  submittalId     String?  // Link to submittal if applicable
  documentId      String?  // Document being checked
  itemType        String   // submittal, material, equipment, etc.
  itemDescription String
  
  // Spec reference
  specSection     String?  // e.g., "09 91 23"
  specParagraph   String?  // e.g., "2.1.A"
  specRequirement String?  // The requirement text
  
  // Compliance result
  status          ComplianceStatus @default(PENDING)
  complianceScore Float?   // 0-100% compliance
  
  // Issues found
  issues          Json?    // Array of {field, required, submitted, severity}
  criticalIssues  Int      @default(0)
  warnings        Int      @default(0)
  
  // AI analysis
  aiAnalysis      String?  // LLM analysis summary
  recommendations String?  // Suggested corrections
  
  // Review
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  Project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([status])
  @@index([specSection])
}

enum ComplianceStatus {
  PENDING
  COMPLIANT
  NON_COMPLIANT
  PARTIAL
  REQUIRES_REVIEW
}

// Extraction lock to prevent race conditions during document processing
model ExtractionLock {
  id            String   @id @default(cuid())
  resourceType  String   // 'document', 'project'
  resourceId    String   // documentId or projectId
  extractionType String  // 'schedule', 'budget', 'takeoff', 'mep', etc.
  processId     String   // Unique process identifier
  acquiredAt    DateTime @default(now())
  expiresAt     DateTime // Auto-release time (prevents deadlocks)
  
  @@unique([resourceType, resourceId, extractionType])
  @@index([expiresAt])
  @@index([resourceId])
}