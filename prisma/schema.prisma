model DailyReportChunk {
  id            String      @id @default(cuid())
  dailyReportId String
  projectId     String
  content       String
  chunkIndex    Int
  section       String
  reportDate    DateTime
  metadata      Json?
  createdAt     DateTime    @default(now())
  dailyReport   DailyReport @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([dailyReportId])
  @@index([projectId])
  @@index([section])
  @@index([reportDate])
}

model CrewTemplate {
  id         String    @id @default(cuid())
  projectId  String
  name       String
  entries    Json
  createdBy  String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User      @relation("CrewTemplateCreatedBy", fields: [createdBy], references: [id])

  @@index([projectId])
  @@index([createdBy])
}

model SMSMapping {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  phoneNumber String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation("SMSMappingUser", fields: [userId], references: [id])

  @@unique([projectId, phoneNumber])
  @@index([phoneNumber])
  @@index([projectId])
}

model ProjectRender {
  id                 String   @id @default(cuid())
  projectId          String
  roomId             String?
  createdBy          String

  // Wizard inputs
  viewType           String   // "exterior" | "interior" | "aerial_site"
  style              String   // "photorealistic" | "conceptual" | "sketch" | etc.
  cameraAngle        String?  // "eye_level" | "elevated" | "corner" | "worms_eye" | "overhead"
  qualityTier        String   @default("high") // "draft" | "high" | "max"
  assembledPrompt    String   @db.Text
  promptHash         String?  // For dedup detection
  userNotes          String?  @db.Text
  dataSnapshot       Json?    // Full data used for prompt (reproducibility)
  referencePhotoKeys String[]

  // Site photo compositing
  compositeMode       String?      // "standalone" | "site_composite"
  sitePhotoKey        String?      // R2 key for uploaded site photo
  placementBounds     Json?        // {x, y, width, height} as % of site photo

  // Generation
  status             String   @default("pending") // pending | generating | completed | failed
  provider           String?  // "flux-2-pro" | "gpt-image-1.5" | "gpt-image-1-mini"
  imageKey           String?  // R2 key
  thumbnailKey       String?  // R2 key (400px wide)
  revisedPrompt      String?  @db.Text
  imageWidth         Int?
  imageHeight        Int?
  fileSizeBytes      Int?

  // Tracking
  generationTimeMs   Int?
  estimatedCostUsd   Float?
  errorMessage       String?
  retryCount         Int      @default(0)

  // Metadata
  isFavorite         Boolean  @default(false)
  title              String?
  tags               String[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  Project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Room               Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  User               User     @relation(fields: [createdBy], references: [id])

  @@index([projectId])
  @@index([createdBy])
  @@index([status])
  @@index([promptHash])
}

model PresentationBoard {
  id              String    @id @default(cuid())
  projectId       String
  createdBy       String
  title           String
  templateId      String

  projectName     String?
  companyName     String?
  tagline         String?   @db.Text
  contactInfo     String?
  dateText        String?

  primaryColor    String?   @default("#F97316")
  accentColor     String?   @default("#003B71")

  companyLogoKey  String?
  clientLogoKey   String?
  partnerLogo1Key String?
  partnerLogo2Key String?

  renderIds       String[]

  sitePhotoKey    String?

  lastExportedAt  DateTime?
  lastExportFormat String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  Project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User            User      @relation(fields: [createdBy], references: [id])

  @@index([projectId])
  @@index([createdBy])
}

// ---------------------------------------------------------------------------
// Markup & Annotation System (Bluebeam-grade)
// ---------------------------------------------------------------------------

model Markup {
  id               String             @id @default(cuid())
  documentId       String
  projectId        String
  pageNumber       Int
  sheetNumber      String?
  shapeType        String
  geometry         Json
  style            Json
  content          String?
  label            String?
  status           AnnotationStatus   @default(open)
  priority         AnnotationPriority @default(medium)
  tags             String[]           @default([])
  layerId          String?
  measurementValue Float?
  measurementUnit  String?
  calibrationId    String?
  symbolId         String?
  createdBy        String
  lockedBy         String?
  lockedAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  Document         Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Creator          User               @relation("MarkupCreatedBy", fields: [createdBy], references: [id])
  LockedByUser     User?              @relation("MarkupLockedBy", fields: [lockedBy], references: [id])
  Layer            MarkupLayer?       @relation(fields: [layerId], references: [id], onDelete: SetNull)
  Calibration      MarkupCalibration? @relation(fields: [calibrationId], references: [id], onDelete: SetNull)
  Replies          MarkupReply[]

  @@index([documentId, pageNumber, deletedAt])
  @@index([projectId, deletedAt])
  @@index([createdBy, deletedAt])
  @@index([layerId, deletedAt])
  @@index([deletedAt])
}

model MarkupReply {
  id         String    @id @default(cuid())
  markupId   String
  documentId String
  content    String
  createdBy  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  Markup     Markup    @relation(fields: [markupId], references: [id], onDelete: Cascade)
  Document   Document  @relation("MarkupReplyDocument", fields: [documentId], references: [id], onDelete: Cascade)
  Creator    User      @relation("MarkupReplyCreatedBy", fields: [createdBy], references: [id])

  @@index([markupId, deletedAt])
}

model MarkupLayer {
  id         String   @id @default(cuid())
  documentId String
  projectId  String
  name       String
  color      String   @default("#FF0000")
  visible    Boolean  @default(true)
  locked     Boolean  @default(false)
  opacity    Float    @default(1.0)
  sortOrder  Int      @default(0)
  scope      String   @default("document")
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  Document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Creator    User     @relation("MarkupLayerCreatedBy", fields: [createdBy], references: [id])
  Markups    Markup[]

  @@unique([documentId, name])
}

model MarkupCalibration {
  id                  String   @id @default(cuid())
  documentId          String
  projectId           String
  pageNumber          Int
  point1X             Float
  point1Y             Float
  point2X             Float
  point2Y             Float
  realDistance         Float
  realUnit            String   @default("ft")
  pdfUnitsPerRealUnit Float    @default(0)
  confidence          Float    @default(1.0)
  createdBy           String
  createdAt           DateTime @default(now())

  Document            Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Creator             User     @relation("MarkupCalibrationCreatedBy", fields: [createdBy], references: [id])
  Markups             Markup[]

  @@unique([documentId, pageNumber])
}

model MarkupToolPreset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  shapeType String
  style     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model MarkupSession {
  id              String   @id @default(cuid())
  documentId      String
  projectId       String
  userId          String
  sessionId       String
  markupsCreated  Int      @default(0)
  markupsEdited   Int      @default(0)
  markupsDeleted  Int      @default(0)
  startedAt       DateTime @default(now())
  lastActiveAt    DateTime @default(now())

  Document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, sessionId])
}
