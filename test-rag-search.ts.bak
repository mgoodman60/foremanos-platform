import { PrismaClient } from '@prisma/client';
const prisma = new PrismaClient();

async function testRAG() {
  // Simulate a RAG search query
  const testQuery = 'what is sheet C-001';
  
  console.log(`🔍 Testing RAG search for: "${testQuery}"\n`);
  
  // Search chunks (simplified version of what the RAG system does)
  const chunks = await prisma.documentChunk.findMany({
    where: {
      OR: [
        { content: { contains: 'C-001', mode: 'insensitive' } },
        { sheetNumber: { contains: 'C-001', mode: 'insensitive' } }
      ],
      Document: {
        deletedAt: null,
        processed: true
      }
    },
    select: {
      content: true,
      metadata: true,
      Document: {
        select: { name: true, fileName: true }
      }
    },
    take: 3
  });
  
  console.log(`✅ Found ${chunks.length} relevant chunks\n`);
  
  chunks.forEach((chunk: any, i: number) => {
    const meta = chunk.metadata as any;
    console.log(`Chunk ${i + 1} from: ${chunk.document?.fileName || 'Unknown'}`);
    console.log(`  Sheet: ${meta?.sheetNumber || 'N/A'}`);
    console.log(`  Scale: ${meta?.scale || 'N/A'}`);
    console.log(`  Content preview: ${chunk.content?.substring(0, 200)}...\n`);
  });
  
  // Test budget search
  console.log('\n🔍 Testing budget search...\n');
  const budgetChunks = await prisma.documentChunk.findMany({
    where: {
      content: { contains: 'cost', mode: 'insensitive' },
      Document: {
        fileName: { contains: 'Budget' },
        processed: true
      }
    },
    take: 1
  });
  
  if (budgetChunks.length > 0) {
    console.log('✅ Budget data accessible');
    console.log(`   Preview: ${budgetChunks[0].content?.substring(0, 150)}...\n`);
  }
  
  await prisma.$disconnect();
}

testRAG();
