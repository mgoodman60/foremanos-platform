import { PrismaClient } from '@prisma/client';
import { getFileUrl } from './lib/s3';
import { exec } from 'child_process';
import { promisify } from 'util';
import { writeFile, unlink } from 'fs/promises';
import { tmpdir } from 'os';
import { join } from 'path';

const execPromise = promisify(exec);
const prisma = new PrismaClient();

async function checkPDF() {
  const doc = await prisma.document.findUnique({
    where: { id: 'cmk633er50001n508fpe1licm' },
    select: { 
      name: true, 
      cloud_storage_path: true, 
      isPublic: true,
      _count: { select: { chunks: true } }
    }
  });
  
  if (!doc || !doc.cloud_storage_path) {
    console.log('Document not found');
    return;
  }
  
  // Download and check actual page count
  const fileUrl = await getFileUrl(doc.cloud_storage_path, doc.isPublic);
  const response = await fetch(fileUrl);
  const buffer = Buffer.from(await response.arrayBuffer());
  
  const tempFile = join(tmpdir(), 'plans-check.pdf');
  await writeFile(tempFile, buffer);
  
  try {
    const { stdout } = await execPromise(`pdfinfo "${tempFile}" | grep Pages`);
    const actualPages = parseInt(stdout.split(':')[1].trim());
    
    console.log('\n📄 Plans.pdf Analysis:\n');
    console.log(`Actual PDF pages: ${actualPages}`);
    console.log(`Chunks in database: ${doc._count.chunks}`);
    console.log(`Missing: ${actualPages - doc._count.chunks} pages\n`);
    console.log(`Coverage: ${((doc._count.chunks / actualPages) * 100).toFixed(1)}% processed`);
    
  } catch (error) {
    console.error('Error checking PDF:', error);
  } finally {
    await unlink(tempFile);
  }
  
  await prisma.$disconnect();
}

checkPDF();
