import { PrismaClient } from '@prisma/client';
const prisma = new PrismaClient();

async function main() {
  // Test chat query against Plans.pdf chunks
  const chunks = await prisma.documentChunk.findMany({
    where: { 
      documentId: 'cmk633er50001n508fpe1licm',
      content: { contains: 'SHEET' }
    },
    select: {
      pageNumber: true,
      content: true,
      metadata: true
    },
    take: 3
  });

  console.log('✅ Found', chunks.length, 'searchable chunks for Plans.pdf');
  chunks.forEach((c: any, i: number) => {
    const meta = c.metadata as any;
    console.log(`\nChunk ${i + 1}: Sheet ${meta?.sheetNumber || 'unknown'}`);
    console.log(`  - Has dimensions: ${meta?.hasDimensions}`);
    console.log(`  - Has scale: ${meta?.hasScale}`);
    console.log(`  - Content: ${c.content?.substring(0, 100)}...`);
  });

  // Check document status
  const doc = await prisma.document.findUnique({
    where: { id: 'cmk633er50001n508fpe1licm' },
    select: { processed: true, pagesProcessed: true }
  });

  console.log('\n📄 Plans.pdf status:');
  console.log(`  - Processed: ${doc?.processed}`);
  console.log(`  - Pages: ${doc?.pagesProcessed}`);

  await prisma.$disconnect();
}

main();
