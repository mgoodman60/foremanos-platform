import { PrismaClient } from '@prisma/client';
import * as dotenv from 'dotenv';

dotenv.config();

const prisma = new PrismaClient();

async function checkQueue() {
  try {
    console.log('\n=== PROCESSING QUEUE STATUS ===\n');
    
    // Check all queue entries
    const queueEntries = await prisma.processingQueue.findMany({
      include: {
        Document: {
          select: {
            fileName: true,
            name: true
          }
        }
      },
      orderBy: { createdAt: 'desc' }
    });
    
    if (queueEntries.length === 0) {
      console.log('❌ No processing queue entries found');
      console.log('   The document processing may have been done before ProcessingQueue was added.\n');
    } else {
      console.log(`Found ${queueEntries.length} queue entries:\n`);
      
      for (const entry of queueEntries) {
        console.log(`📄 ${entry.document.name || entry.document.fileName}`);
        console.log(`   Status: ${entry.status}`);
        console.log(`   Progress: ${entry.pagesProcessed}/${entry.totalPages} (${Math.round((entry.pagesProcessed / entry.totalPages) * 100)}%)`);
        console.log(`   Batches: ${entry.currentBatch}/${entry.totalBatches}`);
        if (entry.lastError) {
          console.log(`   Last Error: ${entry.lastError.substring(0, 100)}...`);
        }
        console.log('');
      }
    }
    
    // Check if Plans.pdf chunks exist
    const plansChunks = await prisma.documentChunk.count({
      where: {
        Document: {
          fileName: 'Plans.pdf'
        }
      }
    });
    
    console.log(`\n📊 Plans.pdf Analysis:`);
    console.log(`   Chunks in database: ${plansChunks}`);
    
    if (plansChunks > 0) {
      // Get sample chunks to see what data we have
      const sampleChunk = await prisma.documentChunk.findFirst({
        where: {
          Document: {
            fileName: 'Plans.pdf'
          }
        },
        orderBy: { pageNumber: 'asc' }
      });
      
      if (sampleChunk) {
        console.log(`   First page: ${sampleChunk.pageNumber}`);
        console.log(`   Sheet number: ${sampleChunk.sheetNumber || 'N/A'}`);
        console.log(`   Discipline: ${sampleChunk.discipline || 'N/A'}`);
        console.log(`   Has scale data: ${sampleChunk.scaleData ? 'Yes' : 'No'}`);
        console.log(`   Has dimensions: ${sampleChunk.dimensions ? 'Yes' : 'No'}`);
      }
    }
    
  } catch (error) {
    console.error('Error:', error);
  } finally {
    await prisma.$disconnect();
  }
}

checkQueue();
