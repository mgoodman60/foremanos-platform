{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/documents/upload-complete/route.ts": {
      "maxDuration": 300
    },
    "app/api/documents/upload-chunk/route.ts": {
      "maxDuration": 30
    },
    "app/api/projects/*/enhance/route.ts": {
      "maxDuration": 60
    },
    "app/api/admin/finalize-reports/route.ts": {
      "maxDuration": 60
    },
    "app/api/documents/upload/route.ts": {
      "maxDuration": 300
    },
    "app/api/documents/retry-failed/route.ts": {
      "maxDuration": 300
    },
    "app/api/projects/[slug]/documents/[id]/reprocess/route.ts": {
      "maxDuration": 300
    },
    "app/api/documents/confirm-upload/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/process-queue/route.ts": {
      "maxDuration": 900
    }
  },
  "env": {
    "PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING": "1"
  },
  "crons": [
    {
      "path": "/api/admin/finalize-reports",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/admin/process-queue",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/photo-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/processing-queue-cleanup",
      "schedule": "0 4 * * *"
    }
  ]
}
